<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="droga_purchase_competitor_action" model="ir.actions.act_window">
        <field name="name">Competitor Registry</field>
        <field name="res_model">droga.purchase.competitors</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="droga_purchase_competitor_view_tree" model="ir.ui.view">
        <field name="name">droga.purchase.competitors.view.tree</field>
        <field name="model">droga.purchase.competitors</field>
        <field name="arch" type="xml">
            <list string="" editable="bottom">
                <field name="competitor_name"/>
                <field name="competitor_descr"/>
                <field name="status"/>
            </list>
        </field>
    </record>
</odoo>