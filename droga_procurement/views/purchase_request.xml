<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!-- action for rfq -->
    <record id="droga_purchase_request_rfq_action" model="ir.actions.act_window">
        <field name="name">Request for Quotation</field>
        <field name="res_model">droga.purhcase.request.rfq</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_purhcase_request_rfq_view_tree')}),
         (0, 0, {'view_mode': 'form', 'view_id': ref('droga_purhcase_rfq_view_form')})]"/>
        <field name="domain">[('purhcase_request_id', '=', active_id)]</field>
        <field name="context">{'default_purhcase_request_id': active_id}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Request for Quotation
            </p>
        </field>
    </record>

    <!-- tree view -->
    <record id="droga_purhcase_request_view_tree" model="ir.ui.view">
        <field name="name">droga.purhcase.request.view.tree</field>
        <field name="model">droga.purhcase.request</field>
        <field name="arch" type="xml">
            <tree string="Purhcase Request" delete="0">
                <field name="name"/>
                <field name="request_by"/>
                <field name="request_date"/>
                <field name="department"/>
                <field name="purpose"/>
                <field name="company_id"/>
                <field name="state" decoration-warning="state in('Draft')" decoration-info="state in('Submitted','Verified','Budget Checked')" decoration-danger="state == 'Cancel'" decoration-success="state == 'Approved'" widget="badge"/>
            </tree>
        </field>
    </record>


    <!-- Form view -->
    <record id="droga_purhcase_request_view_form" model="ir.ui.view">
        <field name="name">droga.purhcase.request.view.form</field>
        <field name="model">droga.purhcase.request</field>
        <field name="arch" type="xml">
            <form string="Purhcase Request" delete="0">
                <header>
                    <button name="submit_request" type="object" states="Draft" string="Submit" class="oe_highlight" id="submit_request" data-hotkey="v"/>
                    <button name="verify_request" type="object" states="Submitted" string="Verify" id="draft_request" class="oe_highlight" data-hotkey="v"/>
                    <button name="budget_checked_request" type="object" states="Verified" string="Budget Approved" id="budget_checked_request" class="oe_highlight" data-hotkey="v"/>
                    <button name="approve_request" type="object" states="Budget Approved" string="Approve" id="approve_request" class="oe_highlight" data-hotkey="v"/>


                    <button name="draft_request" type="object" states="Submitted" string="Draft" id="draft_request" data-hotkey="v"/>

                    <button name="reject_request" type="object" states="Submitted,Verified,Budget Approved" string="Reject" id="reject_request" data-hotkey="v" class="btn-warning" confirm="Are you sure you want to reject the request?"/>
                    <button name="cancel_request" type="object" states="Draft,Approved" string="Cancel" id="cancel_request" data-hotkey="v" confirm="Are you sure you want to cancel the request? once it cancelled you can't modify the form" class="btn-danger"/>

                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(droga_purchase_request_rfq_action)d" string="RFQ" type="action" class="oe_stat_button" icon="fa-arrows-v" attrs="{'invisible': [('buying_method', '!=', 'RFQ')]}"/>
                    </div>
                    <div class="oe_title">
                        <span class="o_form_label">Purchase Requistion</span>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="request_by" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="department" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="department_manager" readonly="1" invisible="1"/>
                            <field name="branch" options="{'no_create':True,'no_open':True}" required="1" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="request_type" invisible="1"/>
                        </group>
                        <group>

                            <field name="request_date" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="purpose" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="company_id" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="buying_method" attrs="{'invisible': [('state', 'not in', ('Approved'))]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="purhcase_request_lines" mode="tree" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}">
                                <tree editable="bottom">
                                    <field name="product_id" options="{'no_create':True,'no_open':True}" domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]"/>
                                    <field name="product_qty"/>
                                    <field name="unit_price"/>
                                    <field name="total_price"/>
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="product_uom" options="{'no_create':True,'no_open':True}" string="UoM"/>
                                    <field name="budgetary_position" required="1" options="{'no_create':True,'no_open':True}" string="Budget Category"/>
                                    <field name="expense_account" options="{'no_create':True,'no_open':True}" attrs="{'column_invisible': [('parent.state', 'not in', ('Verified'))]}"/>
                                    <field name="remaining_budget" attrs="{'column_invisible': [('parent.state', 'not in', ('Verified'))]}"/>
                                    <field name="remark"/>
                                </tree>

                            </field>
                        </page>
                        <!--<page string="Other Information" invisible="1">
                            <group>
                                <group>
                                    <field name="company_id" options="{'no_create':True,'no_open':True}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Buying Method" attrs="{'invisible': [('state', 'not in', ('Approved'))]}">
                            <group>
                                <field name="buying_method"/>

                            </group>
                            <field name="rfqs" mode="tree" attrs="{'invisible': [('buying_method', 'in', ('Bid'))]}">
                                <tree>
                                    <field name="name"/>
                                    <field name="date"/>
                                </tree>
                            </field>

                        </page>-->
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- search view -->
    <record id="droga_purhcase_reques_view_search" model="ir.ui.view">
        <field name="name">droga.purhcase.request.view.search</field>
        <field name="model">droga.purhcase.request</field>
        <field name="arch" type="xml">
            <search string="">
                <field name="name"/>
                <field name="request_by"/>
                <field name="request_date"/>
                <field name="department"/>
                <field name="purpose"/>
                <field name="company_id" />
                <field name="state"/>
                <separator/>
                <filter name="submitted" string="Submitted" domain="[('state', '=', 'Submitted')]" />
                <filter name="verified" string="Verified" domain="[('state', '=', 'Verified')]" />
                <filter name="budget" string="Budget Approved" domain="[('state', '=', 'Budget Approved')]" />
                <filter name="approved" string="Approved" domain="[('state', '=', 'Approved')]" />
                <filter name="canceled" string="Canceled" domain="[('state', '=', 'Canceled')]" />
                <separator />
                <filter name="request_date" string="Request Date" date="request_date"/>

                <group expand="0" string="Group By">
                    <filter string="Department" name="department" domain="[]" context="{'group_by': 'department'}"/>
                    <filter string="Request Date" name="request_date" domain="[]" context="{'group_by': 'request_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- purchase request tree for foregin procurement -->
    <record id="droga_purhcase_request_foregin_view_tree" model="ir.ui.view">
        <field name="name">droga.purhcase.request.view.foregin.tree</field>
        <field name="model">droga.purhcase.request</field>
        <field name="arch" type="xml">
            <tree string="Purhcase Request" delete="0">
                <field name="name"/>
                <field name="request_by"/>
                <field name="request_date"/>
                <field name="department"/>
                <field name="purpose"/>
                <field name="company_id"/>
                <field name="state" decoration-warning="state in('Draft')" decoration-info="state in('Submitted','Verified','Budget Checked')" decoration-danger="state == 'Cancel'" decoration-success="state == 'Approved'" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- purchase request form for foregin procurement -->
    <record id="droga_purhcase_request_foregin_view_form" model="ir.ui.view">
        <field name="name">droga.purhcase.request.foregin.view.form</field>
        <field name="model">droga.purhcase.request</field>
        <field name="arch" type="xml">
            <form string="Purhcase Request" delete="0">
                <header>
                    <button name="submit_request" type="object" states="Draft" string="Submit" class="oe_highlight" id="submit_request" data-hotkey="v"/>
                    <button name="verify_request" type="object" states="Submitted" string="Verify" id="draft_request" class="oe_highlight" data-hotkey="v"/>
                    <button name="budget_checked_request" type="object" states="Verified" string="Budget Approved" id="budget_checked_request" class="oe_highlight" data-hotkey="v"/>
                    <button name="approve_request" type="object" states="Budget Approved" string="Approve" id="approve_request" class="oe_highlight" data-hotkey="v"/>
                    <button name="draft_request" type="object" states="Submitted" string="Draft" id="draft_request" data-hotkey="v"/>


                    <button name="reject_request" type="object" states="Submitted,Verified,Budget Approved" string="Reject" id="reject_request" data-hotkey="v" class="btn-warning" confirm="Are you sure you want to reject the request?"/>
                    <button name="cancel_request" type="object" states="Draft,Approved" string="Cancel" id="cancel_request" data-hotkey="v" confirm="Are you sure you want to cancel the request? once it cancelled you can't modify the form" class="btn-danger"/>

                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(droga_purchase_request_rfq_foregin_action)d" string="RFQ" type="action" class="oe_stat_button" icon="fa-list" attrs="{'invisible': [('buying_method', '!=', 'RFQ')]}" context="{'default_currency_id': currency_id,'default_exchange_rate':exchange_rate}"/>
                    </div>
                    <div class="oe_title">
                        <span class="o_form_label">Purchase Requistion</span>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="request_by" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="department" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="currency_id" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="buying_method" attrs="{'invisible': [('state', 'not in', ('Approved'))],'readonly': [('state', 'in', ('Approved', 'Cancel'))]}" />
                            <field name="request_type" invisible="1"/>
                        </group>
                        <group>

                            <field name="request_date" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="purpose" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="exchange_rate" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="company_id" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="Products" name="products">
                            <field name="purhcase_request_lines" mode="tree" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}">
                                <tree editable="bottom">
                                    <field name="product_id" width="25" options="{'no_create':True,'no_open':True}" domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]"/>
                                    <field name="product_qty" width="5" string="Qty"/>
                                    <field name="product_uom" width="10" options="{'no_create':True,'no_open':True}" string="UoM"/>
                                    <field name="exchange_rate" width="10" invisible="1"/>
                                    <field name="unit_price_foregin" width="10"/>
                                    <field name="total_price_foregin" width="10"/>
                                    <field name="unit_price" width="10" string="Unit Price ETB" readonly="1"/>
                                    <field name="total_price" width="10" string="Total Price ETB"/>
                                    <field name="product_uom_category_id" invisible="1"/>


                                    <field name="budgetary_position" width="10" required="1" options="{'no_create':True,'no_open':True}" string="Budget Category"/>
                                    <field name="expense_account" width="10" options="{'no_create':True,'no_open':True}" attrs="{'column_invisible': [('parent.state', 'not in', ('Verified'))]}" />
                                    <field name="remaining_budget" attrs="{'column_invisible': [('parent.state', 'not in', ('Verified'))]}"/>
                                    <field name="remark" width="10"/>


                                    <field name="status" invisible="1"/>


                                    <!--<button icon="fa-credit-card-alt" type="object" string="Market analysis" name="open_market_analysis" class="oe_stat_button"/>
                                    <button icon="fa-credit-card-alt" type="object" string="Foregin supp. list" attrs="{'invisible': [('status', '=', 'Draft')]}" name="open_suppliers_list" class="oe_stat_button"/>
                                    <button icon="fa-credit-card-alt" type="object" string="Competitors comparative analysis" attrs="{'invisible': [('status', '=', 'Draft')]}" name="open_competitors_comparative_list" class="oe_stat_button"/>
                                    <button icon="fa-credit-card-alt" type="object" string="Expected Cost" attrs="{'invisible': [('status', '=', 'Draft')]}" name="open_expected_cost" class="oe_stat_button"/>-->

                                </tree>

                            </field>
                        </page>

                        <page string="Product Info" products="expected">
                            <field name="purhcase_request_lines_expectetd" mode="tree" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}">
                                <tree create="0" delete="0" editable="bottom">
                                    <field name="product_id" width="25" options="{'no_create':True,'no_open':True}" domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]" readonly="1"/>
                                    <field name="budget_product" width="15" string="Budget Product?"/>
                                    <field name="expected_average_mon_cons" width="15" string="Average Monthly Cons"/>
                                    <field name="current_stock_balance" width="15" string="Current Balance"/>
                                    <field name="selling_price_after_arrival" width="15" string="Selling Price"/>
                                    <field name="expected_margin" width="15" string="Margin"/>
                                    <field name="arrival_time" width="15" string="Arrival Time"/>
                                </tree>
                            </field>
                        </page>

                        <page string="Current Market Analysis">
                            <field name="purhcase_request_lines_market_analysis" mode="tree" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}">
                                <tree create="0" delete="0" editable="bottom">
                                    <field name="product_id" width="25" options="{'no_create':True,'no_open':True}" domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]" readonly="1"/>
                                    <field name="importer_name" width="15" />
                                    <field name="manufacturer" width="15" />
                                    <field name="unit" width="15" options="{'no_create':True,'no_open':True}"/>
                                    <field name="avail_stock" width="15" />
                                    <field name="sell_up" width="15" />
                                    <field name="epss_volume" width="15" />
                                    <field name="local_man_status" width="15" />
                                    <field name="market_analysis_remark" width="15" />
                                </tree>
                            </field>
                        </page>

                        <page string="Potential Competitors">
                            <field name="purhcase_request_lines_foregin_competitors" mode="tree" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}">
                                <tree create="0" delete="0" editable="bottom">
                                    <field name="product_id" width="25" options="{'no_create':True,'no_open':True}" domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]" readonly="1"/>
                                    <field name="comp_importer" width="15" />
                                    <field name="comp_manufacturer" width="15" />
                                    <field name="comp_unit" width="15" options="{'no_create':True,'no_open':True}"/>
                                    <field name="comp_p_up" width="15" />

                                    <field name="comp_p_qty" width="15" />
                                    <field name="comp_p_date" width="15" />
                                    <field name="comp_e_u_p" width="15" />
                                    <field name="comp_EPSA_winner" width="15" />
                                </tree>
                            </field>
                        </page>


                        <page string="Vendors">
                            <field name="purhcase_request_lines_foregin_supp_list" mode="tree" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}">
                                <tree create="0" delete="0" editable="bottom">
                                    <field name="product_id" width="25" options="{'no_create':True,'no_open':True}" domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]" readonly="1"/>
                                    <field name="foregin_manufacturer" width="15" />
                                    <field name="foregin_unit_price" width="15" invisible="1"/>
                                    <field name="foregin_shelf_life" width="15" />
                                    <field name="foregin_is_sup_regsitered" width="15" />
                                </tree>
                            </field>
                        </page>
                        <page string="Analysis Report">

                            <field name="purchase_analysis_report" mode="tree" readonly="1">
                                <tree create="0" delete="0">
                                    <field name="product_id" width="25" options="{'no_create':True,'no_open':True}" domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]" readonly="1"/>
                                    <field name="product_uom" width="10" options="{'no_create':True,'no_open':True}" string="UoM"/>
                                    <field name="product_qty" />
                                    <field name="current_stock_balance" string="Current Stock" decoration-success="current_stock_balance &lt;= four_month_order_qty" decoration-danger="current_stock_balance &gt; four_month_order_qty" widget="badge"/>
                                    <field name="expected_average_mon_cons" string="Monthly Consumption"/>
                                    <field name="order_qty_and_current_stcok" decoration-success="order_qty_and_current_stcok &lt;= six_month_order_qty" decoration-danger="order_qty_and_current_stcok &gt; six_month_order_qty" widget="badge"/>
                                    <field name="four_month_order_qty" decoration-success="four_month_order_qty &gt;= product_qty" decoration-danger="four_month_order_qty &lt; product_qty" widget="badge"/>
                                    <field name="six_month_order_qty" widget="badge"/>
                                </tree>
                            </field>
                        </page>

                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <!-- action for purhcase request -->
    <record id="droga_purhcase_request_action" model="ir.actions.act_window">
        <field name="name">Purhcase Request</field>
        <field name="res_model">droga.purhcase.request</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_purhcase_request_view_tree')}),
         (0, 0, {'view_mode': 'form', 'view_id': ref('droga_purhcase_request_view_form')})]"/>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="domain">[('request_type', '=', 'Local')]</field>
        <field name="context">{'default_request_type': 'Local'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No purchase requsition found. Let's create one!
            </p>
        </field>
    </record>


    <!-- action for foregin purhcase request -->
    <record id="droga_purhcase_request_foregin_action" model="ir.actions.act_window">
        <field name="name">Purhcase Request Foreign</field>
        <field name="res_model">droga.purhcase.request</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('request_type', '=', 'Foregin')]</field>
        <field name="context">{'default_request_type': 'Foregin','default_buying_method': 'RFQ'}</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_purhcase_request_foregin_view_tree')}),
         (0, 0, {'view_mode': 'form', 'view_id': ref('droga_purhcase_request_foregin_view_form')})]"/>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No purchase requsition found. Let's create one!
            </p>
        </field>
    </record>

    <!-- action for approval local purcjase request -->
    <record id="droga_purhcase_request_for_approval_action" model="ir.actions.act_window">
        <field name="name">Purhcase Request</field>
        <field name="res_model">droga.purhcase.request</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_purhcase_request_view_tree')}),
         (0, 0, {'view_mode': 'form', 'view_id': ref('droga_purhcase_request_view_form')})]" />
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="domain">[('request_type', '=', 'Local'),('state', 'not in', ('Draft','Approved','Canceled'))]</field>
        <field name="context">{'default_request_type': 'Local'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            No purchase requsition found for approval 
            </p>
        </field>
    </record>

    <!-- action for approval Foregin purcjase request -->
    <record id="droga_purhcase_request_foregin_for_approval_action" model="ir.actions.act_window">
        <field name="name">Purhcase Request</field>
        <field name="res_model">droga.purhcase.request</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_purhcase_request_view_tree')}),
         (0, 0, {'view_mode': 'form', 'view_id': ref('droga_purhcase_request_foregin_view_form')})]" />
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="domain">[('request_type', '=', 'Foregin'),('state', 'not in', ('Draft','Approved','Canceled'))]</field>
        <field name="context">{'default_request_type': 'Foregin'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            No purchase requsition found for approval 
            </p>
        </field>
    </record>


    <!-- rule for filtering data specific data -->
    <record model="ir.rule" id="droga_purhcase_request_rule">
        <field name="name">Purhcase Request multi-company</field>
        <field name="model_id" ref="model_droga_purhcase_request"/>
        <field name="global" eval="True"/>
