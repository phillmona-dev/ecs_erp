                <field name="request_date"/>
                <field name="department"/>
                <field name="purpose"/>
                <field name="company_id" />
                <field name="state" decoration-warning="state in('Draft')" decoration-info="state in('Submitted','Verified','Budget Checked')" decoration-danger="state == 'Cancel'" decoration-success="state == 'Approved'" widget="badge"/>
            </tree>
        </field>
    </record>

