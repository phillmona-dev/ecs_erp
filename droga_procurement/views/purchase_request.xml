<?xml version="1.0" encoding="utf-8"?>
<odoo>

    

    

    <!-- action for rfq -->
    <record id="droga_purchase_request_rfq_action" model="ir.actions.act_window">
        <field name="name">Request for Quotation</field>
        <field name="res_model">droga.purhcase.request.rfq</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_purhcase_request_rfq_view_tree')}),
         (0, 0, {'view_mode': 'form', 'view_id': ref('droga_purhcase_rfq_view_form')})]" />
        <field name="domain">[('purhcase_request_id', '=', active_id)]</field>
        <field name="context">{'default_purhcase_request_id': active_id}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Request for Quotation
            </p>
        </field>
    </record>

    <!-- tree view -->
    <record id="droga_purhcase_request_view_tree" model="ir.ui.view">
        <field name="name">droga.purhcase.request.view.tree</field>
        <field name="model">droga.purhcase.request</field>
        <field name="arch" type="xml">
            <tree string="Purhcase Request" delete="0">
                <field name="name"/>
                <field name="request_by"/>
                <field name="request_date"/>
                <field name="department"/>
                <field name="purpose"/>
                <field name="company_id" />
                <field name="state" decoration-warning="state in('Draft')" decoration-info="state in('Submitted','Verified','Budget Checked')" decoration-danger="state == 'Cancel'" decoration-success="state == 'Approved'" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- Form view -->
    <record id="droga_purhcase_request_view_form" model="ir.ui.view">
        <field name="name">droga.purhcase.request.view.form</field>
        <field name="model">droga.purhcase.request</field>
        <field name="arch" type="xml">
            <form string="Purhcase Request" delete="0">
                <header>
                    <button name="submit_request" type="object" states="Draft" string="Submit" class="oe_highlight" id="submit_request" data-hotkey="v"/>
                    <button name="verify_request" type="object" states="Submitted" string="Verify" id="draft_request" class="oe_highlight" data-hotkey="v"/>
                    <button name="budget_checked_request" type="object" states="Verified" string="Budget Checked" id="budget_checked_request" class="oe_highlight" data-hotkey="v"/>
                    <button name="approve_request" type="object" states="Budget Checked" string="Approve" id="approve_request" class="oe_highlight" data-hotkey="v"/>
                    <button name="draft_request" type="object" states="Submitted" string="Draft" id="draft_request" data-hotkey="v"/>

                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(droga_purchase_request_rfq_action)d" string="RFQ" type="action" class="oe_stat_button" icon="fa-arrows-v" attrs="{'invisible': [('buying_method', '!=', 'RFQ')]}"/>
                    </div>
                    <div class="oe_title">
                        <span class="o_form_label">Purchase Requistion</span>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group >
                            <field name="request_by" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="department" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                        </group>
                        <group>

                            <field name="request_date" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                            <field name="purpose" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="purhcase_request_lines" mode="tree" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancel'))]}">
                                <tree editable="bottom">
                                    <field name="product_id" options="{'no_create':True,'no_open':True}" context="{'company_id': parent.company_id}"/>
                                    <field name="product_qty" />
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="product_uom" options="{'no_create':True,'no_open':True}"/>
                                    <field name="remark" />
                                </tree>

                            </field>
                        </page>
                        <page string="Other Information">
                            <group>
                                <group>
                                    <field name="company_id" context="{'company_id': parent.company_id}" options="{'no_create':True,'no_open':True}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Buying Method" attrs="{'invisible': [('state', 'not in', ('Approved'))]}">
                            <group>
                                <field name="buying_method"/>

                            </group>
                            <field name="rfqs" mode="tree" attrs="{'invisible': [('buying_method', 'in', ('Bid'))]}">
                                <tree >
                                    <field name="name" />
                                    <field name="date" />
                                </tree>
                            </field>

                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- purchase request tree for foregin procurement -->
    <record id="droga_purhcase_request_foregin_view_tree" model="ir.ui.view">
        <field name="name">droga.purhcase.request.view.foregin.tree</field>
        <field name="model">droga.purhcase.request</field>
