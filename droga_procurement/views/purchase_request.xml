                        </page>
                        <page string="Buying Method" attrs="{'invisible': [('state', 'not in', ('Approved'))]}">
                            <group>
                                <field name="buying_method"/>

                            </group>
                            <field name="rfqs" mode="tree" attrs="{'invisible': [('buying_method', 'in', ('Bid'))]}">
                                <tree >
