<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- form view for lc -->
    <record id="droga_purchase_lc_view_form" model="ir.ui.view">
        <field name="name">droga.purchase.lc.view.form</field>
        <field name="model">droga.purchase.lc</field>
        <field name="arch" type="xml">
            <form string="" create="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="rfq_id" readonly="1" options="{'no_create':True,'no_open':True}"/>
                            <field name="purchase_order_id" readonly="1" options="{'no_create':True,'no_open':True}"/>
                            <field name="name" />
                        </group>
                        <group>
                            <field name="bank_name" />
                            <field name="state" />
                        </group>


                    </group>

                    <notebook>
                        <page string="LC Reconciliation">
                            <field name="lc_details" mode="tree">
                                <tree editable="bottom" create="0" delete="0">
                                    <field name="order" />
                                    <field name="name" />
                                    <field name="state" />
                                    <field name="remark" />
                                </tree>
                            </field>
                        </page>
                        <page string="Shipping Reconciliation">
                            <field name="shipping_details" mode="tree">
                                <tree editable="bottom" create="0" delete="0">
                                    <field name="order" />
                                    <field name="name" />
                                    <field name="state" />
                                    <field name="remark" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
