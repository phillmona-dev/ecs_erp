<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="droga_sales_subcontractor_issue_view_tree" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.issue.view.tree</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="arch" type="xml">
            <list string="" create="1" delete="0">
                <field name="name"/>
                <field name="customer" string="Cleaning unit"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="droga_sales_bag_issue_view_tree" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.issue.view.tree</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="arch" type="xml">
            <list string="" create="1" delete="0">
                <field name="name"/>
                <field name="consignment_reference"/>
                <field name="state"/>
            </list>
        </field>
    </record>


    <record id="droga_sales_subcontractor_issue_view_form" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.issue.view.form</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="arch" type="xml">
            <form string="Subcontractor issue" delete="0">
                <header>
                    <button name="request_mg" string="Request" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>
                    <button name="mg_approve" groups="droga_export.export_manager" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['mg'])"/>
                    <button name="amend" groups="droga_inventory.stores_manager,droga_inventory.marketing_manager" string="Amend" type="object" class="oe_highlight btn-warning" data-hotkey="v" invisible="(state not in ['mg', 'mtmg'])"/>
                    <button name="action_cancel" string="Cancel" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,mg,waiting,sc"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button icon="fa-credit-card-alt" type="object" string="Payment request" name="pay_req_open" class="oe_stat_button"/>
                        <button icon="fa-credit-card-alt" type="object" string="Cost build-up" name="cost_buildup" class="oe_stat_button"/>
                        <button icon="fa-credit-card-alt" type="object" string="Cleaning unit return" name="sub_cont_return" class="oe_stat_button"/>
                        <button icon="fa-credit-card-alt" type="object" string="Recalculate WA" name="recalculate" class="oe_stat_button"/>
                    </div>
                    <group string="Cleaning unit issue">
                        <group>
                            <field name="customer" string="Cleaning unit" required="1" readonly="(state in ['waiting', 'mg', 'reject', 'cancel', 'done'])"/>
                            <field name="issue_type" required="True" readonly="True"/>
                            <field name="subcontract_issue_origin_form" readonly="1" options="{'no_create':True,'no_open':True}"/>
                        </group>
                        <group>
                            <field name="issue_date" readonly="(state in ['waiting', 'mg', 'reject', 'cancel', 'done'])"/>
                            <field name="consignment_reference"/>
                            <field name="remark"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="state" invisible="1"/>
                            <field name="detail_entries" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])">
                                <list editable="bottom">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_id" required="1" options="{'no_create':True,'no_open':True}" context="{'default_detailed_type': 'product'}"/>
                                    <field name="product_uom" options="{'no_create':True,'no_open':True}" readonly="1"/>
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="state" invisible="1"/>
                                    <field name="product_uom_qty" sum="Total" string="Quantity"/>
                                    <field name="proc_cost" sum="Total"/>
                                    <field name="tot_cost" sum="Total"/>
                                    <field name="product_uom" invisible="1"/>
                                    <field name="warehouse_id" string="Issuer warehouse" options="{'no_create':True,'no_open':True}" required="(state != 'draft')"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_sales_bag_issue_view_form" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.issue.view.form</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="arch" type="xml">
            <form string="Bag issue" delete="0">
                <header>
                    <button name="request_mg" string="Request" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>
                    <button name="mg_approve" groups="droga_export.export_manager" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['mg'])"/>
                    <button name="amend" groups="droga_inventory.stores_manager,droga_inventory.marketing_manager" string="Amend" type="object" class="oe_highlight btn-warning" data-hotkey="v" invisible="(state not in ['mg', 'mtmg'])"/>
                    <button name="action_cancel" string="Cancel" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,mg,waiting,sc"/>
                </header>
                <sheet>
                    <group string="Cleaning unit issue">
                        <group>
                            <field name="issue_type" required="True" readonly="True"/>
                            <field name="bag_issue_order" readonly="1" options="{'no_create':True,'no_open':True}"/>
                            <field name="remark"/>
                        </group>
                        <group>
                            <field name="issue_date" readonly="(state in ['waiting', 'mg', 'reject', 'cancel', 'done'])"/>
                            <field name="consignment_reference"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="state" invisible="1"/>
                            <field name="detail_entries" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])">
                                <list editable="bottom">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_id" required="1" options="{'no_create':True,'no_open':True}" context="{'default_detailed_type': 'product'}"/>
                                    <field name="product_uom" options="{'no_create':True,'no_open':True}"/>
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="state" invisible="1"/>
                                    <field name="product_uom_qty" sum="Total" string="Quantity"/>
                                    <field name="product_amt" sum="Total" string="Amount"/>
                                    <field name="warehouse_id" string="Issuer warehouse" options="{'no_create':True,'no_open':True}" required="(state != 'draft')"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_sales_subcontract_issue_action_sales" model="ir.actions.act_window">
        <field name="name">Cleaning unit items issuance</field>
        <field name="res_model">droga.inventory.consignment.issue</field>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_sales_subcontractor_issue_view_tree')}),                 (0, 0, {'view_mode': 'form', 'view_id': ref('droga_sales_subcontractor_issue_view_form')})]"/>
        <field name="context">{'default_issue_type': 'SUBL','default_warehouse_id':9}</field>
        <field name="domain">[('create_uid','=',uid),('issue_type','in',('BAGI','SUBL'))]</field>
    </record>


    <menuitem id="droga_export_clean_issue_menu" name="Cleaning unit issue and return" action="droga_export.droga_sales_subcontract_issue_action_sales" parent="stock.menu_stock_warehouse_mgmt" sequence="30"/>
</odoo>