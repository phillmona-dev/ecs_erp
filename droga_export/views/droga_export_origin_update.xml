<!--                </xpath>-->

<!--                The current issue is you're inheriting this from droga_finance view. Double inherit type of thing-->

<!--            </field>-->
<!--        </record>-->

        <record id="view_purchase_order_form_inherit_droga_export_context" model="ir.ui.view">
            <field name="name">purchase.order.form.inherit.droga.export.context</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='%(droga_finance.droga_account_payment_request1_action)d']" position="after">
                        <field name="export_origin_form" invisible="1"></field>
                    </xpath>
                <xpath expr="//button[@name='%(droga_finance.droga_account_payment_request1_action)d']" position="attributes">
                    <attribute name="context">
                        {'default_pay_to': partner_id, 'default_total_amount': amount_total, 'default_export_origin_form': export_origin_form}
                    </attribute>
                </xpath>

                <xpath expr="//button[@name='%(droga_finance.droga_account_payment_request_urgent1_action)d']" position="attributes">
                    <attribute name="context">
                        {'default_pay_to': partner_id, 'default_total_amount': amount_total, 'default_export_origin_form': export_origin_form}
                    </attribute>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
