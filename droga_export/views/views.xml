<?xml version='1.0' encoding='utf-8'?>
<odoo>
     <record id="product_template_product_form_inherit" model="ir.ui.view" > 
            <field name="name">product.template.product.form.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
            
                <xpath expr="//field[@name='name']" position="after">
              <field name="isprocessing" /> 
              
              
            </xpath>
           </field>
        </record>
  <record id="droga_mrp_bom_view_tree" model="ir.ui.view">
        <field name="name">droga.mrp.bom.view.tree</field>
        <field name="model">droga.mrp.bom</field>
        <field name="arch" type="xml">
            <tree string="Process Material">
                  
                        <field name="product_tmpl_id"/>
                            <field name="supplierinfo"/>
                            <field name="product_id"/>
                             <field name="wastage"/>
                             <field name="defect"/>
                          
            </tree>
        </field>
    </record>

<record id="droga_mrp_bom_view_form" model="ir.ui.view">
        <field name="name">droga_mrp_bom.view.form</field>
        <field name="model">droga.mrp.bom</field>
        <field name="arch" type="xml">
            <form string="">
                
                <sheet>
                
                    <group>
                        <group  >
                            <field name="product_tmpl_id"/>
                            <field name="supplierinfo"/>
                            <field name="product_id"/>
                            <field name="product_in"/>
                            <field name="product_out"/>
                            
                            

                          </group>
                          <group >
                            <field name="code"/>
                             <field name="wastage"/>
                             <field name="defect"/>
                             <field name="company_id"/>
                              
                              
                          </group>
                      </group>
                    
                    
                    <notebook>
                    <page string="Raw Producg=t">
                          
                            <field name="raw_ids" >
                                <tree  editable="bottom" >
                                    <field name="name"/>
                                    <field name="deusage"/>
                                     <field name="product_id"/>
                                     
                                    
                                </tree>
                            </field>
                            
                        </page>
                        <page string="defect_ids">
                            <!-- you can display child data like code below -->
                            <field name="defect_ids" >
                                <tree  editable="bottom"  >
                                    <field name="name"/>
                                    <field name="defect"/>
                                    
                                                                      
                                    
                                    
                                </tree>
                            </field>
                            
                        </page>
                    
                    
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="droga_mrp_bom_action" model="ir.actions.act_window">
    <field name="name">Process Material</field>
    <field name="res_model">droga.mrp.bom</field>
    <field name="view_mode">tree,form</field>
</record>


 <menuitem id="droga_mrp_bom_menu" action="droga_mrp_bom_action" parent="sale.menu_sales_config" sequence="1" 
 name="Process Materials" groups="sale_management.group_sale_order_template"/>


        </odoo>