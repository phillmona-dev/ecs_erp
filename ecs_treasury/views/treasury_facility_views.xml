<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ecs_treasury_facility_list" model="ir.ui.view">
        <field name="name">ecs.treasury.facility.list</field>
        <field name="model">ecs.treasury.facility</field>
        <field name="arch" type="xml">
            <list string="Treasury Facilities">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="facility_type"/>
                <field name="principal_amount"/>
                <field name="interest_rate"/>
                <field name="start_date"/>
                <field name="maturity_date"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_ecs_treasury_facility_form" model="ir.ui.view">
        <field name="name">ecs.treasury.facility.form</field>
        <field name="model">ecs.treasury.facility</field>
        <field name="arch" type="xml">
            <form string="Treasury Facility">
                <header>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" string="Close" type="object" invisible="state != 'active'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('closed', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="facility_type"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="currency_id"/>
                            <field name="principal_amount"/>
                            <field name="interest_rate"/>
                            <field name="start_date"/>
                            <field name="maturity_date"/>
                        </group>
                    </group>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ecs_treasury_facility" model="ir.actions.act_window">
        <field name="name">Treasury Facilities</field>
        <field name="res_model">ecs.treasury.facility</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
