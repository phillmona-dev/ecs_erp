<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="droga_inventory_consignment_receipt_action" model="ir.actions.act_window">
        <field name="name">Store consignment receipt order</field>
        <field name="res_model">droga.inventory.consignment.receive</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="droga_inventory_consignment_receive_view_tree" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.receive.view.tree</field>
        <field name="model">droga.inventory.consignment.receive</field>
        <field name="arch" type="xml">
            <tree string="">
                <field name="name"></field>
                <field name="supplier"></field>
                <field name="cons_ref" attrs="{'invisible': [('cons_ref', '=', False)]}" widget="many2many_tags" readonly="1"></field>
                <field name="state"></field>
            </tree>
        </field>
    </record>

    <record id="droga_inventory_consignment_receive_view_form" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.receive.view.form</field>
        <field name="model">droga.inventory.consignment.receive</field>
        <field name="arch" type="xml">
            <form string="Consignment receipt">
                <header>
                    <button name="action_send_to_store"
                            attrs="{'invisible': ['|',('state', 'in', ('waiting','reject','cancel','done')),('id','=',None)]}"
                            string="Send to store" type="object" class="oe_highlight" data-hotkey="v"/>
                    <button name="action_cancel"
                            attrs="{'invisible': ['|',('state', 'in', ('waiting','cancel','reject','done')),('id','=',None)]}"
                            string="Cancel" type="object" class="oe_highlight" data-hotkey="v"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="supplier"></field>
                            <field name="cons_ref" attrs="{'invisible': [('cons_ref', '=', False)]}" widget="many2many_tags" readonly="1"></field>
                        </group>
                        <group>
                            <field name="receipt_date" attrs="{'readonly': [('state', 'in', ('waiting','reject','cancel','done'))]}"></field>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="detail_entries" attrs="{'readonly': [('state', 'in', ('waiting','reject','cancel','done'))]}">
                                <tree editable="bottom">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_id" required="1" context="{'default_detailed_type': 'product'}"/>
                                    <field name="product_uom"/>
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="product_uom_qty" string="Quantity"/>
                                    <field name="price_unit"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="warehouse_id" string="Receipt warehouse"/>
                                </tree>
                            </field>
                        </page>

                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <menuitem
            id="droga_stock_cons_receive_menu"
            name="Store consignment receipt order"
            action="droga_inventory_consignment_receipt_action"
            groups="inventory_li,inventory_me,inventory_md,inventory_ms,inventory_os"
            parent="stock.menu_stock_warehouse_mgmt"/>
</odoo>
