<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_inventory_consignment_receipt_action" model="ir.actions.act_window">
        <field name="name">Store consignment receipt order</field>
        <field name="res_model">droga.inventory.consignment.receive</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('create_uid','=',uid)]</field>
    </record>

    <record id="droga_inventory_consignment_receive_view_tree" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.receive.view.tree</field>
        <field name="model">droga.inventory.consignment.receive</field>
        <field name="arch" type="xml">
            <list string="" delete="0">
                <field name="name"/>
                <field name="supplier"/>
                <field name="cons_ref" widget="many2many_tags" readonly="1" invisible="(cons_ref == False)"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="droga_inventory_consignment_receive_view_form" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.receive.view.form</field>
        <field name="model">droga.inventory.consignment.receive</field>
        <field name="arch" type="xml">
            <form string="Consignment receipt" delete="0">
                <header>
                    <button name="request" string="Request" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>
                    <button name="stmg_approve" groups="droga_inventory.stores_manager,droga_inventory.stores_manager_ws,droga_inventory.stores_manager_pt" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['stmg'])"/>
                    <button name="amend" groups="droga_inventory.stores_manager,droga_inventory.stores_manager_ws,droga_inventory.stores_manager_pt" string="Amend" type="object" class="oe_highlight btn-warning" data-hotkey="v" invisible="(state not in ['stmg', 'mtmg'])"/>
                    <button name="action_cancel" string="Cancel" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,stmg,waiting,done"/>
                </header>
                <sheet>
                    <group string="Store receive request">
                        <group>
                            <field name="supplier" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])"/>
                            <field name="issue_type" required="True" readonly="1"/>
                        </group>
                        <group>
                            <field name="receipt_date" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])"/>
                            <field name="cons_ref" widget="many2many_tags" readonly="1" invisible="(cons_ref == False)"/>
                            <field name="remark"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="detail_entries" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])">
                                <list editable="bottom">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_id" options="{'no_create':True,'no_open':True}" required="1" context="{'default_detailed_type': 'product'}"/>
                                    <field name="product_uom" options="{'no_create':True,'no_open':True}"/>
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="product_uom_qty" string="Quantity"/>
                                    <field name="price_unit_cons"/>
                                    <field name="available_qty" groups="droga_inventory.stores_manager,droga_inventory.stores_manager_pt,droga_inventory.stores_manager_ws"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="warehouse_id" options="{'no_create':True,'no_open':True}" string="Receipt warehouse"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>


</odoo>