<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<record id="product_template_inventory_extension" model="ir.ui.view">
        <field name="name">product.template.product.inventory.extension.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/notebook/page/group/group[@name='group_standard_price']/field[@name='categ_id']" position="replace">
                <field name="categ_id" string="Product Category" options="{'no_create':True,'no_open':True}" domain="[('complete_name','not like','All%')]"/>
            </xpath>
        </field>
    </record>

    </odoo>