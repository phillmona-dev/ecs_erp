<?xml version='1.0' encoding='utf-8'?>
<odoo>
    droga_inventory_stock_move_reservation_form

    <record id="droga_inventory_stock_move_reservation_form" model="ir.ui.view">
        <field name="name">stock.move.reservation.form</field>
        <field name="model">stock.move</field>
        <field name="arch" type="xml">
            <form create="False" delete="0">
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <record id="droga_inventory_stock_move_reservation_tree" model="ir.ui.view">
        <field name="name">stock.move.reservation.tree</field>
        <field name="model">stock.move</field>
        <field name="arch" type="xml">
            <list editable="bottom" create="0" delete="0">
                <field name="product_id" readonly="1"/>
                <field name="reference" readonly="1"/>
                <field name="origin" readonly="1"/>
                <field name="partner_id" string="Customer"/>
                <field name="reservation_discard_time"/>
                <field name="source_wh"/>
                <field name="reserve_indef"/>
                <field name="product_uom_qty" sum="Total" readonly="1"/>
                <field name="reserved_qty" sum="Total"/>
                <button icon="fa-credit-card-alt" type="object" string="View history" name="view_reg_hist" class="oe_stat_button"/>
            </list>
        </field>
    </record>

    <record id="droga_inventory_stock_move_reservation_search" model="ir.ui.view">
        <field name="name">stock.move.reservation.tree</field>
        <field name="model">stock.move</field>
        <field name="arch" type="xml">
            <search>
                <field name="product_id"/>
                <field name="reference"/>
                <field name="origin"/>
                <field name="source_wh"/>
                <field name="reserve_indef"/>
                <field name="product_uom_qty"/>
                <field name="reserved_qty"/>
            </search>
        </field>
    </record>

    <record id="droga_inventory_stock_move_reservation_action" model="ir.actions.act_window">
        <field name="name">Store reservation management</field>
        <field name="res_model">stock.move</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="droga_inventory_stock_move_reservation_search"/>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_inventory_stock_move_reservation_tree')}),                 (0, 0, {'view_mode': 'form', 'view_id': ref('droga_inventory_stock_move_reservation_form')})]"/>
        <field name="domain">[('has_read_access','=',True),('origin','like','SO%'),('location_id.usage', '=', 'internal'),('location_dest_id.usage', '!=', 'internal'),('state','not in',['done','cancel','draft'])]</field>
    </record>

    <menuitem id="droga_stock_reserve_management_menu" name="Store reservation management" action="droga_inventory_stock_move_reservation_action" groups="droga_inventory.stores_manager" parent="stock.menu_stock_warehouse_mgmt"/>
</odoo>
