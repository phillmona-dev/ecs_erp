<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- inherit  landed cost -->
    <record id="stock_landed_cost_inherited_form_view" model="ir.ui.view">
        <field name="name">stock.landed.cost.inherited</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_ids']" position="replace">
                <field name="target_model" required="True"></field>
                <field name="picking_ids" widget="many2many_tags"
                                    options="{'no_create':True,'no_open':True}" attrs="{'readonly': ['|',('state','=','done'),('target_model', '!=', 'picking')]}"
                                    domain="[('company_id', '=', company_id), ('move_ids.stock_valuation_layer_ids', '!=', False)]"/>
                <field name="purchase_orders" widget="many2many_tags"
                                    options="{'no_create':True,'no_open':True}" attrs="{'readonly': ['|',('state','=','done'),('target_model', '!=', 'pos')]}"
                                    domain="[('company_id', '=', company_id)]"/>
                <field name="lc" options="{'no_create':True,'no_open':True}" required="1"
                       attrs="{'readonly': [('state', '=', 'done')]}"/>
            </xpath>

            <xpath expr="//field[@name='vendor_bill_id']" position="after">
                <field name="grn_total" readonly="True"></field>
                <field name="purchase_total" readonly="True"></field>
                <field name="lc_rate" readonly="True"></field>
            </xpath>

            <xpath expr="//button[@name='button_validate']" position="after">

                <button name="button_update_analytics" string="Update Analytics" states="done" class="oe_highlight"
                        type="object"/>
            </xpath>
        </field>
    </record>
</odoo>