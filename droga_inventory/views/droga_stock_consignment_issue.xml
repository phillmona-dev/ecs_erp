<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="droga_inventory_consignment_issue_view_tree" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.issue.view.tree</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="arch" type="xml">
            <list string="" create="1" delete="0">
                <field name="name"/>
                <field name="customer"/>
                <field name="cons_ref" widget="many2many_tags" readonly="1" invisible="(cons_ref == False)"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="droga_inventory_consignment_issue_view_tree_sales" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.issue.view.tree.sales</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="arch" type="xml">
            <list string="" create="1" delete="0">
                <field name="name"/>
                <field name="customer"/>
                <field name="cons_ref" widget="many2many_tags" readonly="1" invisible="(cons_ref == False)"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="droga_inventory_consignment_issue_view_form" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.issue.view.form</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="arch" type="xml">
            <form string="Consignment issue" delete="0">
                <header>
                    <!-- Sales and crm header part  -->
                    <field name="menu_from" invisible="1"/>
                    <button name="request" string="Request" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft']) or (menu_from not in ['SR', 'PH'])"/>
                    <button name="stmg_approve" groups="droga_sales.sales_price_change_admin,droga_pharma.pharma_director" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['stmg'])"/>
                    <button name="amend" groups="droga_sales.sales_price_change_admin,droga_pharma.pharma_director" string="Amend" type="object" class="oe_highlight btn-warning" data-hotkey="v" invisible="(state not in ['stmg', 'mtmg'])"/>
                    <button name="action_cancel" string="Cancel" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft']) or (menu_from not in ['SR', 'PH'])"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,stmg,waiting,processed" invisible="(menu_from not in ['SR', 'PH'])"/>

                </header>
                <sheet>
                    <group string="Store issue request">
                        <group>
                            <field name="customer" readonly="(state in ['waiting', 'stmg', 'reject', 'cancel', 'done', 'processed'])"/>
                            <field name="issue_type" required="True" readonly="1"/>
                        </group>
                        <group>
                            <field name="issue_date" readonly="(state in ['waiting', 'stmg', 'reject', 'cancel', 'done', 'processed'])"/>
                            <field name="cons_ref" widget="many2many_tags" readonly="1" invisible="(cons_ref == False)"/>
                            <field name="remark"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="state" invisible="1"/>
                            <field name="detail_entries" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])">
                                <list editable="bottom">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_id" required="1" options="{'no_create':True,'no_open':True}" context="{'default_detailed_type': 'product'}"/>
                                    <field name="product_uom" options="{'no_create':True,'no_open':True}"/>
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="state" invisible="1"/>
                                    <field name="product_uom_qty" string="Quantity"/>
                                    <field name="available_qty" groups="droga_sales.sales_price_change_admin"/>
                                    <field name="warehouse_id" string="Issuer warehouse" options="{'no_create':True,'no_open':True}"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_inventory_consignment_issue_action" model="ir.actions.act_window">
        <field name="name">Store issue order</field>
        <field name="res_model">droga.inventory.consignment.issue</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('create_uid','=',uid)]</field>
    </record>

    <record id="droga_inventory_consignment_issue_action_sales" model="ir.actions.act_window">
        <field name="name">Sales promotion items issuance</field>
        <field name="res_model">droga.inventory.consignment.issue</field>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_inventory_consignment_issue_view_tree_sales')}),                 (0, 0, {'view_mode': 'form', 'view_id': ref('droga_inventory_consignment_issue_view_form')})]"/>
        <field name="context">{'default_issue_type': 'SIF'}</field>
        <field name="domain">[('create_uid','=',uid)]</field>
    </record>


</odoo>