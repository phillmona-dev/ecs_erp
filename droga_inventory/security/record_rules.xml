    <record id = "inventory_warehouse_read_access" model = "ir.rule">
        <field name = "name"> Every store keeper can create read other warehouse for inter-store request issuance </field>
        <field name = "model_id" search="[('model','=','stock.warehouse')]" />
        <field name = "groups" eval = "[(4, ref ('stock.group_stock_user'))]" />
        <field name = "perm_read" eval = "True" />
        <field name = "perm_write" eval = "False" />
        <field name = "perm_create" eval = "False" />
        <field name = "perm_unlink" eval = "False" />
        <field name = "domain_force"> ['|','|','|','|','|','|',('code', '=', 'MD'),('code', '=', 'WS'),('code', '=', 'OF'),('code', '=', 'OS'),('code', '=', 'ME'),('code', '=', 'LI'),('code', '=', 'MS')] </field>
    </record>




