<odoo>
    <record id = "inventory_ms_warehouse_access" model = "ir.rule">
        <field name = "name"> Store keeper can only access his/her own warehouse only </field>
        <field name = "model_id" search="[('model','=','stock.warehouse')]"/>
        <field name = "groups" eval = "[(4, ref ('inventory_ms'))]" />
        <field name = "perm_read" eval = "True" />
        <field name = "perm_write" eval = "True" />
        <field name = "perm_create" eval = "True" />
        <field name = "perm_unlink" eval = "True" />
        <field name = "domain_force"> [('code', '=', 'MS')] </field>
    </record>

