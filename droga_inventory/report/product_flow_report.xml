<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="droga_inventory_reports_product_flow_excel_action" model="ir.actions.act_window">
        <field name="name">Product flow - Excel</field>
        <field name="res_model">droga.inventory.reports.product.flow.excel</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="droga_inventory_reports_product_flow_excel_form" model="ir.ui.view">
        <field name="name">droga.inventory.reports.product.flow.excel.view.form</field>
        <field name="model">droga.inventory.reports.product.flow.excel</field>
        <field name="arch" type="xml">
            <form string="" delete="0">
                <group>
                    <group>
                        <field name="warehouse" domain="[('has_access','=',True),'|',('active','=',True),('active','=',False)]" options="{'no_create':True,'no_open':True}"/>
                        <field name="date_from"/>
                    </group>
                    <group>
                        <field name="category_id" options="{'no_create':True,'no_open':True}"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <group>
                    <field name="sort_by"/>
                </group>
                <footer>
                    <button name="action_get_xls" string="Get Excel" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <menuitem
            id="droga_inventory_reports_product_flow_excel"
            name="Product flow - Excel"
            action="droga_inventory_reports_product_flow_excel_action"
            parent="stock.menu_warehouse_report"
            groups="droga_inventory.inventory_product_flow_report"
            sequence="10002"/>
</odoo>
