<?xml version='1.0' encoding='utf-8'?>
<odoo>
        <record id="droga_report_total_tender" model="ir.ui.view">
            <field name="name">droga.report.total.tender</field>
            <field name="model">droga.tender.master</field>
            <field name="arch" type="xml">
                <list string="" create="false" delete="false" expand="1">
                    <field name="customer"/>
                    <field name="customer_type"/>
                    <field name="ten_id" string="Tender ID"/>
                    <button icon="fa-edit" string="" type="object" name="open_tender" class="oe_stat_button"/>
                    <field name="item_types"/>
                    <field name="posted_date_gre" string="Floated date"/>
                    <field name="closing_date_gre" string="Closing date"/>
                    <field name="bid_security_amount_char"/>
                    <field name="bid_doc_purch_price"/>
                    <field name="phone_add"/>
                </list>
            </field>
        </record>

        <record id="droga_tender_report_total_tenders" model="ir.actions.act_window">
            <field name="name">Total tenders</field>
            <field name="res_model">droga.tender.master</field>
            <field name="view_mode">list</field>
            <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_report_total_tender')})]"/>
        </record>
</odoo>