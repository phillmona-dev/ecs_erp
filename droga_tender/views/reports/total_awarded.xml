<?xml version='1.0' encoding='utf-8'?>
<odoo>
        <record id="droga_report_total_awarded_tender" model="ir.ui.view">
            <field name="name">droga.report.total.awarded.tender</field>
            <field name="model">droga.tender.master</field>
            <field name="arch" type="xml">
                <list string="" create="false" delete="false" expand="1">
                    <field name="ten_id" string="Tender ID"/>
                    <field name="customer"/>
                    <field name="closing_date_gre" string="Closing date"/>
                    <field name="award_folder"/>
                    <field name="procurement_title"/>
                    <field name="awarded_amt_total"/>
                    <field name="remark"/>
                </list>
            </field>
        </record>

    <record id="droga_tender_awarded_search_tree" model="ir.ui.view">
        <field name="name">droga.tender.awarded.search.tree</field>
        <field name="model">droga.tender.master</field>
        <field name="arch" type="xml">
            <search string="Upcoming Tenders">
                <field name="customer"/>
                <field name="ten_id"/>
                <field name="award_folder"/>
                <field name="closing_date_gre"/>
                <field name="procurement_title"/>
                <field name="awarded_amt_total"/>
                <filter string="Awarded tenders" domain="[('awarded_amt_total', '&gt;',0)]" name="awarded_tenders"/>

                <filter name="group_type_customer_type" string="Customer type" context="{'group_by':'customer_type'}"/>

                <separator/>

                <filter string="Current week closed tenders" domain="[                         ('closing_date_gre', '&gt;=', (datetime.datetime.combine(context_today() + relativedelta(weeks=-1,days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S')),                         ('closing_date_gre', '&lt;', (datetime.datetime.combine(context_today() + relativedelta(days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S'))]" name="current_week_tenders"/>
                <filter string="Current month closed tenders" domain="[('closing_date_gre', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]" name="current_month_tenders"/>
                <filter string="Previous week closed tenders" domain="[('closing_date_gre', '&lt;=', (context_today() - relativedelta(weeks=1,weekday=-1)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(weeks=2,weekday=0)).strftime('%Y-%m-%d'))]" name="previous_week_tenders"/>
                <filter string="Previous month closed tenders" domain="[('closing_date_gre', '&lt;=', (context_today() + relativedelta(months=-1,day=31)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(months=1,day=1)).strftime('%Y-%m-%d'))]" name="previous_month_tenders"/>
                <filter string="Next month closing tenders" domain="[('closing_date_gre', '&lt;=', (context_today() + relativedelta(months=1,day=31)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]" name="next_month_tenders"/>
            </search>
        </field>
    </record>

    <record id="droga_tender_report_total_awarded" model="ir.actions.act_window">
            <field name="name">Total awarded</field>
            <field name="res_model">droga.tender.master</field>
            <field name="view_mode">list</field>
            <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_report_total_awarded_tender')})]"/>
            <field name="search_view_id" ref="droga_tender_awarded_search_tree"/>
        <field name="context">{'search_default_awarded_tenders': 1}</field>
        </record>

        <!-->
        <menuitem
            id="droga_report_total_awarded_menu"
            name="Total awarded"
            action="droga_tender_report_total_awarded"
            parent="tender_reports"
            groups="tender_user"
            sequence="11"/>
            <-->
</odoo>