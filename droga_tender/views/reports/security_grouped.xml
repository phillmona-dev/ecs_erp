<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_report_security_grouped_tree" model="ir.ui.view">
        <field name="name">droga.tender.security.detail.grouped.tree</field>
        <field name="model">droga.tender.security.detail</field>
        <field name="arch" type="xml">
            <list string="" create="false" delete="false" expand="1">
                <field name="tender_id"/>
                <field name="cus_type"/>
                <field name="security_type"/>
                <field name="security_for"/>
                <field name="security_amount"/>
                <field name="bank"/>
                <field name="bank_number"/>
                <field name="issue_date"/>
                <field name="starting_date"/>
                <field name="security_period_in_days"/>
                <field name="dead_line_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="droga_report_security_grouped_search" model="ir.ui.view">
        <field name="name">droga.tender.security.detail.grouped.search</field>
        <field name="model">droga.tender.security.detail</field>
        <field name="arch" type="xml">
            <search string="Upcoming Tenders">
                <field name="tender_id"/>
                <field name="cus_type"/>
                <field name="security_type"/>
                <field name="security_for"/>
                <field name="security_amount"/>
                <field name="bank"/>
                <field name="bank_number"/>
                <field name="issue_date"/>
                <field name="starting_date"/>
                <field name="security_period_in_days"/>
                <field name="dead_line_date"/>
                <field name="status"/>

                <filter string="Bid security" domain="[('security_for', '=','Bid security')]" name="bid_security"/>
                <filter string="Advance security" domain="[('security_for', '=','Advance security')]" name="advance_security"/>
                <filter string="Performance security" domain="[('security_for', '=','Performance Security')]" name="performance_security"/>

                <separator/>
                
                <filter string="Current week deadlines" domain="[                         ('dead_line_date', '&gt;=', (datetime.datetime.combine(context_today() + relativedelta(weeks=-1,days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S')),                         ('dead_line_date', '&lt;', (datetime.datetime.combine(context_today() + relativedelta(days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S'))]" name="current_week_tenders"/>
                <filter string="Next week deadlines" domain="[                     ('dead_line_date', '&lt;', (context_today() + relativedelta(weeks=1, weekday=6)).strftime('%Y-%m-%d 00:00:00')),                     ('dead_line_date', '&gt;', (context_today() + relativedelta(weeks=0, weekday=6)).strftime('%Y-%m-%d 00:00:00')),]" name="next_week_tenders"/>
                <filter string="Current month deadlines" domain="[('dead_line_date', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d')),('dead_line_date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]" name="current_month_tenders"/>
                <filter string="Previous week deadlines" domain="[('dead_line_date', '&lt;=', (context_today() - relativedelta(weeks=1,weekday=-1)).strftime('%Y-%m-%d')),('dead_line_date', '&gt;=', (context_today() - relativedelta(weeks=2,weekday=0)).strftime('%Y-%m-%d'))]" name="previous_week_tenders"/>
                <filter string="Previous month deadlines" domain="[('dead_line_date', '&lt;=', (context_today() + relativedelta(months=-1,day=31)).strftime('%Y-%m-%d')),('dead_line_date', '&gt;=', (context_today() - relativedelta(months=1,day=1)).strftime('%Y-%m-%d'))]" name="previous_month_tenders"/>
                <filter string="Next month deadlines" domain="[('dead_line_date', '&lt;=', (context_today() + relativedelta(months=1,day=31)).strftime('%Y-%m-%d')),('dead_line_date', '&gt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]" name="next_month_tenders"/>
                
                <filter name="group_type" string="Security type" context="{'group_by':'security_type'}"/>
                <filter name="group_status" string="Status" context="{'group_by':'status'}"/>
                <filter name="group_bank" string="Bank" context="{'group_by':'bank'}"/>
                <filter name="group_custype" string="Customer type" context="{'group_by':'cus_type'}"/>
            </search>
        </field>
    </record>

    <record id="droga_report_security_grouped_action" model="ir.actions.act_window">
        <field name="name">Securities summary</field>
        <field name="res_model">droga.tender.security.detail</field>
        <field name="view_mode">list</field>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_report_security_grouped_tree')})]"/>
        <field name="search_view_id" ref="droga_report_security_grouped_search"/>
        <field name="context">{'search_default_group_type': 1}</field>
    </record>

    <menuitem id="droga_report_security_grouped_menu" name="Securities summary" action="droga_report_security_grouped_action" parent="tender_reports" groups="tender_user" sequence="11"/>
</odoo>