        <field name="name">Awarded Tenders</field>
        <field name="res_model">droga.awarded.tenders.view</field>
        <field name="view_mode">tree</field>
    </record>

    <record id="droga_tender_awarded_tenders_view_tree" model="ir.ui.view">
        <field name="name">droga.tender.awarded.tender.view.tree</field>
        <field name="model">droga.awarded.tenders.view</field>
        <field name="arch" type="xml">
            <tree string="">
                <field name="cust_name"></field>
                <field name="award_folder_no"></field>
                <field name="procurement_title"></field>
                <field name="amt"></field>
            </tree>
        </field>
    </record>

    <menuitem
            id="droga_tender_awarded_tenders"
            name="Awarded Tenders"
            action="droga_tender_awarded_tenders_action"
            parent="tender_reports"
            sequence="19"/>
