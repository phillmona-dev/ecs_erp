<?xml version='1.0' encoding='utf-8'?>
<odoo>


    <record id="droga_report_total_tender_performance" model="ir.ui.view">
        <field name="name">droga.report.total.tender.performance</field>
        <field name="model">droga.tender.master</field>
        <field name="arch" type="xml">
            <list string="" create="false" delete="false" expand="1">
                <field name="ten_id" string="Tender ID"/>
                <field name="customer"/>
                <field name="procurement_title"/>
                <field name="closing_date_gre"/>
                <field name="tender_amt_participated"/>
                <field name="performance_amt_award"/>
                <field name="performance_pct"/>
                <field name="total_delivered_amount"/>
                <field name="performance_pct_delivery"/>
                <field name="remark"/>
                <button icon="fa-credit-card-alt" type="object" string="Details" name="sub_detail_open" class="oe_stat_button"/>
            </list>
        </field>
    </record>

    <record id="droga_report_total_tender_performance_per_item" model="ir.ui.view">
        <field name="name">droga.report.total.tender.performance.per.item</field>
        <field name="model">droga.tender.performance.evaluation</field>
        <field name="arch" type="xml">
            <list string="" create="false" delete="false" expand="1">
                <field name="parent_tender_performance" string="Tender ID" optional="hide"/>
                <button icon="fa-credit-card-alt" type="object" name="open_tender" class="oe_stat_button"/>
                <field name="customer"/>
                <field name="item_des_list" string="Item requested"/>
                <field name="item_pro" string="Item proposed"/>
                <field name="droga_product"/>
                <field name="type_item"/>
                <field name="procurement_title"/>
                <field name="latest_invoice_date"/>
                <field name="amount"/>
                <field name="award_cost"/>
                <field name="performance_pct"/>
                <field name="total_delivered_amount"/>
                <field name="performance_pct_delivery"/>
            </list>
        </field>
    </record>
    
    <record id="droga_report_total_tender_participated_for_all" model="ir.ui.view">
        <field name="name">droga.report.total.tender.performance.for.all</field>
        <field name="model">droga.tender.submission.detail</field>
        <field name="arch" type="xml">
            <list string="" create="false" delete="false" expand="1">
                <field name="parent_tender_submission" string="Tender ID" optional="hide"/>
                <button icon="fa-credit-card-alt" type="object" name="open_tender" class="oe_stat_button"/>
                <field name="customer"/>
                <field name="item_des_list" string="Item requested"/>
                <field name="item_pro" string="Item proposed"/>
                <field name="type_item"/>
                <field name="status"/>
                <field name="procurement_title"/>
                <field name="closing_date_gre"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <record id="droga_report_total_tender_participated_minimum_column" model="ir.ui.view">
        <field name="name">droga.report.total.tender.performance.min.col</field>
        <field name="model">droga.tender.submission.detail</field>
        <field name="arch" type="xml">
            <list string="" create="false" delete="false" expand="1">
                <button icon="fa-credit-card-alt" type="object" name="open_tender" class="oe_stat_button"/>
                <field name="item_des_list" string="Item requested"/>
                <field name="item_pro" string="Item proposed"/>
                <field name="customer"/>
                <field name="status"/>
                <field name="uom_reg_field"/>
                <field name="quantity"/>
                <field name="unit_price"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <record id="droga_tender_performance_search_tree" model="ir.ui.view">
        <field name="name">droga.tender.tender.performance.search.tree</field>
        <field name="model">droga.tender.master</field>
        <field name="arch" type="xml">
            <search string="Upcoming Tenders">
                <field name="ten_id" string="Tender ID"/>
                <field name="customer"/>
                <field name="procurement_title"/>
                <field name="awarded_amt_total"/>
                <field name="closing_date_gre"/>
                <field name="tender_amt_participated"/>
                <field name="performance_pct"/>
                <field name="cus_type" invisible="1"/>
                <field name="remark"/>
                <filter string="Performance eval" domain="[('performance_amt_award', '&gt;',0)]" name="performance_list"/>
                <filter name="group_cust" string="Customer type" context="{'group_by':'cus_type'}"/>

                <separator/>

                <filter string="Current week performance" domain="[                         ('closing_date_gre', '&gt;=', (datetime.datetime.combine(context_today() + relativedelta(weeks=-1,days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S')),                         ('closing_date_gre', '&lt;', (datetime.datetime.combine(context_today() + relativedelta(days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S'))]" name="current_week_tenders"/>
                <filter string="Current month performance" domain="[('closing_date_gre', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]" name="current_month_tenders"/>
                <filter string="Previous week performance" domain="[('closing_date_gre', '&lt;=', (context_today() - relativedelta(weeks=1,weekday=-1)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(weeks=2,weekday=0)).strftime('%Y-%m-%d'))]" name="previous_week_tenders"/>
                <filter string="Previous month performance" domain="[('closing_date_gre', '&lt;=', (context_today() + relativedelta(months=-1,day=31)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(months=1,day=1)).strftime('%Y-%m-%d'))]" name="previous_month_tenders"/>
            </search>
        </field>
    </record>

    <record id="droga_tender_performance_search_tree_item" model="ir.ui.view">
        <field name="name">droga.tender.tender.performance.search.tree.item</field>
        <field name="model">droga.tender.performance.evaluation</field>
        <field name="arch" type="xml">
            <search string="Upcoming Tenders">
                <field name="parent_tender_performance" string="Tender ID"/>
                <field name="customer"/>
                <field name="item_des_list" string="Item requested"/>
                <field name="item_pro" string="Item proposed"/>
                <field name="droga_product"/>
                <field name="procurement_title"/>
                <field name="closing_date_gre"/>
                <field name="amount"/>
                <field name="award_cost"/>
                <field name="performance_pct"/>
                <field name="total_delivered_amount"/>
                <field name="cus_type"/>
                <field name="performance_pct_delivery"/>
                <filter string="Performance eval" domain="[('award_cost', '&gt;',0)]" name="performance_list"/>
                <filter name="group_cust" string="Customer type" context="{'group_by':'cus_type'}"/>

                <separator/>

                <filter string="Current week performance" domain="[                         ('closing_date_gre', '&gt;=', (datetime.datetime.combine(context_today() + relativedelta(weeks=-1,days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S')),                         ('closing_date_gre', '&lt;', (datetime.datetime.combine(context_today() + relativedelta(days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S'))]" name="current_week_tenders"/>
                <filter string="Current month performance" domain="[('closing_date_gre', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]" name="current_month_tenders"/>
                <filter string="Previous week performance" domain="[('closing_date_gre', '&lt;=', (context_today() - relativedelta(weeks=1,weekday=-1)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(weeks=2,weekday=0)).strftime('%Y-%m-%d'))]" name="previous_week_tenders"/>
                <filter string="Previous month performance" domain="[('closing_date_gre', '&lt;=', (context_today() + relativedelta(months=-1,day=31)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(months=1,day=1)).strftime('%Y-%m-%d'))]" name="previous_month_tenders"/>
            </search>
        </field>
    </record>
    
    <record id="droga_tender_participated_search_for_all" model="ir.ui.view">
        <field name="name">droga.tender.submission.detail.search.tree.item</field>
        <field name="model">droga.tender.submission.detail</field>
        <field name="arch" type="xml">
            <search string="All tenders">
                <field name="parent_tender_submission" string="Tender ID"/>
                <field name="customer"/>
                <field name="item_des_list" string="Item requested"/>
                <field name="item_pro" string="Item proposed"/>
                <field name="type_item"/>
                <field name="procurement_title"/>
                <field name="closing_date_gre"/>
                <field name="amount"/>
                
                <filter name="group_cust" string="Customer type" context="{'group_by':'cus_type'}"/>

                <filter string="Participated" domain="[('unit_price', '&gt;',0)]" name="participated"/>
                <filter string="Not participated" domain="[('unit_price', '=',0)]" name="not_participated"/>
                <separator/>
                <filter string="Awarded" domain="[('status', '=','awarded')]" name="awarded"/>
                <filter string="Cancelled" domain="[('status', '=','cancelled')]" name="cancelled"/>
                <filter string="Under evaluation" domain="[('status', '=','undeva')]" name="undeva"/>
                <filter string="Failed tender" domain="[('status', '=','faiten')]" name="faiten"/>
                <filter string="Lost" domain="[('status', '=','lost')]" name="lost"/>

                <separator/>

                <filter string="Current week performance" domain="[                         ('closing_date_gre', '&gt;=', (datetime.datetime.combine(context_today() + relativedelta(weeks=-1,days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S')),                         ('closing_date_gre', '&lt;', (datetime.datetime.combine(context_today() + relativedelta(days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S'))]" name="current_week_tenders"/>
                <filter string="Current month performance" domain="[('closing_date_gre', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]" name="current_month_tenders"/>
                <filter string="Previous week performance" domain="[('closing_date_gre', '&lt;=', (context_today() - relativedelta(weeks=1,weekday=-1)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(weeks=2,weekday=0)).strftime('%Y-%m-%d'))]" name="previous_week_tenders"/>
                <filter string="Previous month performance" domain="[('closing_date_gre', '&lt;=', (context_today() + relativedelta(months=-1,day=31)).strftime('%Y-%m-%d')),('closing_date_gre', '&gt;=', (context_today() - relativedelta(months=1,day=1)).strftime('%Y-%m-%d'))]" name="previous_month_tenders"/>
            </search>
        </field>
    </record>
    
    <record id="droga_tender_report_tender_performance_status" model="ir.actions.act_window">
        <field name="name">Total performance</field>
        <field name="res_model">droga.tender.master</field>
        <field name="view_mode">list</field>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_report_total_tender_performance')})]"/>
        <field name="search_view_id" ref="droga_tender_performance_search_tree"/>
        <field name="context">{'search_default_group_cust': 1,'search_default_performance_list': 1}</field>
    </record>

    <menuitem id="droga_report_total_tender_status" name="Total perfromance" action="droga_tender_report_tender_performance_status" parent="tender_reports" groups="tender_user" sequence="11"/>

    <record id="droga_tender_report_tender_performance_status_item" model="ir.actions.act_window">
        <field name="name">Total performance per item</field>
        <field name="res_model">droga.tender.performance.evaluation</field>
        <field name="view_mode">list,pivot</field>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_report_total_tender_performance_per_item')})]"/>
        <field name="search_view_id" ref="droga_tender_performance_search_tree_item"/>
        <field name="context">{'search_default_group_cust': 1,'search_default_performance_list': 1}</field>
    </record>
    
    <record id="droga_tender_report_tender_participated_status_item" model="ir.actions.act_window">
        <field name="name">Total participated per item</field>
        <field name="res_model">droga.tender.submission.detail</field>
        <field name="view_mode">list,pivot</field>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_report_total_tender_participated_for_all')})]"/>
        <field name="search_view_id" ref="droga_tender_participated_search_for_all"/>
    </record>

    <record id="droga_tender_report_tender_participated_non_participated_summary" model="ir.actions.act_window">
        <field name="name">Total per item aggregate</field>
        <field name="res_model">droga.tender.submission.detail</field>
        <field name="view_mode">list,pivot</field>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_report_total_tender_participated_minimum_column')})]"/>
        <field name="search_view_id" ref="droga_tender_participated_search_for_all"/>
        <field name="context">{'search_default_participated': 1}</field>
    </record>
    
    <menuitem id="droga_report_total_tender_status_item" name="Total perfromance per item" action="droga_tender_report_tender_performance_status_item" parent="tender_reports" groups="tender_user" sequence="12"/>

    <menuitem id="droga_report_total_tender_participated_status_item" name="Total participated per item" action="droga_tender_report_tender_participated_status_item" parent="tender_reports" groups="tender_user" sequence="12"/>

    <menuitem id="droga_report_total_tender_participated_aggregate" name="Total per item aggregate" action="droga_tender_report_tender_participated_non_participated_summary" parent="tender_reports" groups="tender_user" sequence="12"/>
</odoo>