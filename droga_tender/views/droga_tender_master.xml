<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_tender_master_view_tree" model="ir.ui.view">
        <field name="name">droga.tender.master.view.tree</field>
        <field name="model">droga.tender.master</field>
        <field name="arch" type="xml">
            <list string="" delete="0" default_order="write_date desc">
                <field name="ten_id" string="Tender ID"/>
                <button icon="fa-credit-card-alt" type="object" string="Submission details" name="sub_detail_open" class="oe_stat_button"/>
                <field name="customer"/>
                <field name="posted_date_gre" string="Floated date"/>
                <field name="closing_date_gre" string="Closing date"/>
                <field name="open_date_gre" invisible="1"/>
                <field name="extension_date_gre" invisible="1"/>
                <field name="extension_date_eth" invisible="1"/>
                <field name="open_date_eth" invisible="1"/>
                <field name="closing_date_eth" invisible="1"/>
                <field name="float_period" invisible="1"/>
                <field name="bid_submit_place" invisible="1"/>
                <field name="price_validity_period" invisible="1"/>
                <field name="remark"/>
                <field name="customer_tender_no" invisible="1"/>
                <field name="period_type" invisible="1"/>
                <field name="bid_type" invisible="1"/>
                <field name="bid_doc_purch_price" invisible="1"/>
                <field name="refloat" invisible="1"/>
                <field name="status" decoration-success="status == 'active'" decoration-muted="status == 'closed'" widget="badge"/>
            </list>
        </field>
    </record>


    <record id="droga_tender_master_view_form" model="ir.ui.view">
        <field name="name">droga.tender.master.view.form</field>
        <field name="model">droga.tender.master</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <form string="" delete="0">

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button icon="fa-credit-card-alt" type="object" string="Bond request" name="bond_request" class="oe_stat_button"/>
                        <button icon="fa-credit-card-alt" type="object" string="Sample request" name="consignment_open" class="oe_stat_button"/>
                        <button icon="fa-credit-card-alt" type="object" string="Payment request" name="pay_req_open" class="oe_stat_button"/>
                        <button icon="fa-credit-card-alt" type="object" string="Purchase request" name="pur_req_open" class="oe_stat_button"/>
                        <button icon="fa-credit-card-alt" type="object" string="Submission details" name="sub_detail_open" class="oe_stat_button"/>

                    </div>


                    <group>
                        <group style="white-space:nowrap" col="1">

                            <group string="Customer info">
                                <field name="media" options="{'no_create':True,'no_open':True}" domain="[('status', '=', 'Active')]"/>
                                <field name="customer" options="{'no_create':True,'no_open':True}" domain="[('company_id', '=', company_id)]"/>
                                <field name="company_id" invisible="1"/>
                                <field name="customer_tender_no"/>

                                <field name="procurement_title"/>

                                <field name="assigned_person" options="{'no_create':True,'no_open':True}"/>
                                <field name="posted_date_gre"/>
                                <field name="float_period"/>
                                <field name="period_type"/>
                            </group>
                            <group string="GRE dates">
                                <field name="closing_date_gre"/>
                                <field name="ext_period"/>
                                <field name="extension_date_gre"/>
                                <field name="open_date_gre"/>
                                <field name="refloat"/>
                            </group>

                        </group>
                        <group style="white-space:nowrap" col="1">
                            <group string="Bid info">
                                <field name="price_validity_period"/>
                                <field name="bid_type"/>
                                <field name="bid_doc_purch_price" widget="monetary"/>
                                <field name="security_period_in_days"/>
                                <field name="bid_security_amount_char"/>
                                <field name="posted_date_eth"/>
                                <field name="bid_submit_place" options="{'no_create':True,'no_open':True}" domain="[('status', '=', 'Active')]"/>
                                <field name="remark"/>

                            </group>
                            <group string="ETH dates">
                                <field name="closing_date_eth"/>
                                <field name="ext_period_type"/>
                                <field name="extension_date_eth"/>
                                <field name="open_date_eth"/>
                                <field name="status"/>
                            </group>

                        </group>


                    </group>

                    <notebook>
                        <page string="Tender Detail">
                            <field name="detail_tenders" mode="tree">
                                <list editable="bottom">
                                    <field name="lot_number"/>
                                    <field name="type_item" widget="many2many_tags" options="{'no_create':True,'no_open':True}"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>

    </record>

    <record id="droga_tender_master_action" model="ir.actions.act_window">
        <field name="name">Tender master registry</field>
        <field name="res_model">droga.tender.master</field>
        <field name="view_mode">activity,list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_tender_master_view_tree')}),                 (0, 0, {'view_mode': 'form', 'view_id': ref('droga_tender_master_view_form')})]"/>
    </record>

    <menuitem id="droga_tender_master_menu" name="Tender Master Registry" action="droga_tender_master_action" parent="tender_main_menu" groups="tender_user" sequence="11"/>
</odoo>