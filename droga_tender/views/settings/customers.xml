<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_tender_settings_customers_action" model="ir.actions.act_window">
        <field name="name">Customers registry</field>
        <field name="res_model">droga.tender.settings.customers</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="droga_tender_settings_customers_view_tree" model="ir.ui.view">
        <field name="name">droga.tender.settings.customers.view.tree</field>
        <field name="model">droga.tender.settings.customers</field>
        <field name="arch" type="xml">
            <list string="" delete="0">
                <field name="name"/>
                <field name="customer_type"/>
                <field name="tin_no"/>
                <field name="master_cust_id" string="Linked customer"/>
                <button icon="fa-credit-card-alt" type="object" string="Request registry" name="request_reg" class="oe_stat_button" invisible="(master_cust_id != False)"/>
            </list>
        </field>
    </record>

    <record id="droga_tender_settings_customer_view_form" model="ir.ui.view">
        <field name="name">droga.tender.settings.customer.view.form</field>
        <field name="model">droga.tender.settings.customers</field>
        <field name="arch" type="xml">
            <form string="" delete="0">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="customer_type" options="{'no_create':True,'no_open':True}"/>
                        <field name="tin_no"/>
                        <field name="master_cust_id" string="Linked customer" options="{'no_create':True,'no_open':True}" domain="[('company_id', '=', company_id)]"/>
                        <field name="company_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="droga_tender_settings_customers" name="Customers Registry" action="droga_tender_settings_customers_action" parent="tender_settings_menu" groups="tender_user" sequence="18"/>
</odoo>