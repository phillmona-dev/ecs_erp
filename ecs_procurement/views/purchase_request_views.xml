<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ecs_purchase_request_list" model="ir.ui.view">
        <field name="name">ecs.purchase.request.list</field>
        <field name="model">ecs.purchase.request</field>
        <field name="arch" type="xml">
            <list string="Purchase Requests">
                <field name="name"/>
                <field name="request_date"/>
                <field name="request_type"/>
                <field name="requester_employee_id"/>
                <field name="department_id"/>
                <field name="purpose"/>
                <field name="total_amount"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_ecs_purchase_request_form" model="ir.ui.view">
        <field name="name">ecs.purchase.request.form</field>
        <field name="model">ecs.purchase.request</field>
        <field name="arch" type="xml">
            <form string="Purchase Request">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="state not in ('submitted', 'verified', 'budget_approved')" groups="ecs_approvals.group_ecs_procurement_approver,ecs_approvals.group_ecs_procurement_manager"/>
                    <button name="action_create_rfq" string="Create RFQ" type="object" invisible="state != 'approved'"/>
                    <button name="action_create_purchase_orders" string="Create Purchase Order" type="object" invisible="state != 'approved'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('approved', 'cancelled')"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,verified,budget_approved,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="purchase_order_count == 0">
                            <field name="purchase_order_count" widget="statinfo" string="Purchase Orders"/>
                        </button>
                        <button name="action_view_rfqs" type="object" class="oe_stat_button" icon="fa-list" invisible="rfq_count == 0">
                            <field name="rfq_count" widget="statinfo" string="RFQs"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="request_type"/>
                            <field name="purchase_type"/>
                            <field name="buying_method"/>
                            <field name="request_purpose"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id"/>
                            <field name="exchange_rate"/>
                            <field name="request_date"/>
                            <field name="bypass_budget_check"/>
                        </group>
                    </group>
                    <group>
                        <field name="requester_employee_id"/>
                        <field name="department_id"/>
                        <field name="purpose"/>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="product_uom_id"/>
                                    <field name="quantity"/>
                                    <field name="estimated_unit_price"/>
                                    <field name="subtotal"/>
                                    <field name="vendor_id"/>
                                    <field name="date_required"/>
                                </list>
                            </field>
                        </page>
                        <page string="Approval History">
                            <field name="approval_log_ids" readonly="1">
                                <list>
                                    <field name="action_date"/>
                                    <field name="action"/>
                                    <field name="level"/>
                                    <field name="user_id"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ecs_purchase_request_search" model="ir.ui.view">
        <field name="name">ecs.purchase.request.search</field>
        <field name="model">ecs.purchase.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="requester_employee_id"/>
                <field name="department_id"/>
                <field name="purpose"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="submitted" string="Submitted" domain="[('state','=','submitted')]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <separator/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_type" string="Request Type" context="{'group_by': 'request_type'}"/>
                    <filter name="group_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_ecs_purchase_request" model="ir.actions.act_window">
        <field name="name">Purchase Requests</field>
        <field name="res_model">ecs.purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ecs_purchase_request_search"/>
    </record>

    <record id="action_ecs_purchase_request_local" model="ir.actions.act_window">
        <field name="name">Local Purchase Requests</field>
        <field name="res_model">ecs.purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('request_type','=','local')]</field>
        <field name="context">{'default_request_type': 'local'}</field>
    </record>

    <record id="action_ecs_purchase_request_foreign" model="ir.actions.act_window">
        <field name="name">Foreign Purchase Requests</field>
        <field name="res_model">ecs.purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('request_type','=','foreign')]</field>
        <field name="context">{'default_request_type': 'foreign'}</field>
    </record>

</odoo>
