<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ecs_purchase_rfq_list" model="ir.ui.view">
        <field name="name">ecs.purchase.rfq.list</field>
        <field name="model">ecs.purchase.rfq</field>
        <field name="arch" type="xml">
            <list string="Requests for Quotation">
                <field name="name"/>
                <field name="request_id"/>
                <field name="request_type"/>
                <field name="rfq_date"/>
                <field name="deadline"/>
                <field name="selected_total"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_ecs_purchase_rfq_form" model="ir.ui.view">
        <field name="name">ecs.purchase.rfq.form</field>
        <field name="model">ecs.purchase.rfq</field>
        <field name="arch" type="xml">
            <form string="Request for Quotation">
                <header>
                    <button name="action_generate_quote_lines" string="Generate Quote Lines" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_mark_sent" string="Mark Sent" type="object" invisible="state != 'draft'"/>
                    <button name="action_mark_received" string="Quotes Received" type="object" invisible="state != 'sent'"/>
                    <button name="action_pick_lowest_quotes" string="Pick Lowest Quotes" type="object" invisible="state not in ('received', 'sent')"/>
                    <button name="action_create_purchase_orders" string="Create Purchase Orders" type="object" invisible="state != 'selected'" groups="ecs_approvals.group_ecs_procurement_manager"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('po_created', 'cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,sent,received,selected,po_created"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="purchase_order_count == 0">
                            <field name="purchase_order_count" widget="statinfo" string="Purchase Orders"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="request_id"/>
                            <field name="request_type"/>
                            <field name="rfq_date"/>
                            <field name="deadline"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id"/>
                            <field name="selected_vendor_ids" widget="many2many_tags" readonly="1"/>
                            <field name="selected_total"/>
                        </group>
                    </group>
                    <group>
                        <field name="supplier_ids" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Vendor Quotes">
                            <field name="quote_line_ids">
                                <list editable="bottom" decoration-success="is_selected">
                                    <field name="vendor_id"/>
                                    <field name="request_line_id"/>
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="product_uom_id"/>
                                    <field name="unit_price"/>
                                    <field name="subtotal"/>
                                    <field name="delivery_days"/>
                                    <field name="payment_terms"/>
                                    <field name="is_selected"/>
                                    <button name="action_select_winner" string="Select" type="object" icon="fa-check" column_invisible="parent.state in ('po_created', 'cancelled')"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ecs_purchase_rfq_search" model="ir.ui.view">
        <field name="name">ecs.purchase.rfq.search</field>
        <field name="model">ecs.purchase.rfq</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="request_id"/>
                <field name="supplier_ids"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="selected" string="Winner Selected" domain="[('state','=','selected')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_type" string="Request Type" context="{'group_by': 'request_type'}"/>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ecs_purchase_rfq" model="ir.actions.act_window">
        <field name="name">Requests for Quotation</field>
        <field name="res_model">ecs.purchase.rfq</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ecs_purchase_rfq_search"/>
    </record>
</odoo>
