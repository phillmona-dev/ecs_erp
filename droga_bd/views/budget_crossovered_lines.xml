<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="droag_budget_crossovered_budget_lines_view_tree" model="ir.ui.view">
        <field name="name">droga.budget.crossovered.budget.lines.view.list</field>
        <field name="model">crossovered.budget.lines</field>
        <field name="arch" type="xml">
            <list string="Budget Category" editable="bottom">
                <field name="general_budget_id" string="Budget Category" options="{'no_create': True, 'no_open': True}"/>
                <field name="analytic_account_id" string="Analytic" options="{'no_create': True, 'no_open': True}"/>
                <field name="fiscal_year" invisible="1"/>
                <field name="period" options="{'no_create': True, 'no_open': True}"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="planned_amount" sum="Planned Amount"/>
                <field name="reallaocation_addition" readonly="1"/>
                <field name="addition" readonly="1" sum="Addition"/>
                <field name="revised_budget" readonly="1" sum="Revised"/>
                <field name="commitment_budget" readonly="1" sum="Commitment"/>
                <field name="practical_amount" sum="Practical Amount"/>
                <field name="remaining_balance" readonly="1" sum="Remaining Balance"/>
                <button name="open_detail_budget" type="object" icon="fa-align-justify"/>
                <button type="object" name="action_open_budget_entries" string="Entries..." icon="fa-arrow-circle-o-right"/>
                <field name="crossovered_budget_id" invisible="1"/>
                <field name="paid_date" groups="base.group_no_one" invisible="1"/>
                <field name="currency_id" invisible="1"/>
                <field name="theoritical_amount" invisible="1"/>
                <field name="percentage" widget="percentage" invisible="1"/>
                <field name="is_above_budget" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="action_import_budget_details" model="ir.actions.client">
        <field name="name">Budget Import</field>
        <field name="tag">import</field>
        <field name="params">{'model': 'crossovered.budget.lines'}</field>
    </record>

    <record id="droga_budget_category_detail_action" model="ir.actions.act_window">
        <field name="name">Budget Category</field>
        <field name="res_model">crossovered.budget.lines</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="droag_budget_crossovered_budget_lines_view_tree"/>
        <field name="domain">[('crossovered_budget_id', '=', active_id)]</field>
        <field name="context">{'default_crossovered_budget_id': active_id}</field>
    </record>

    <record id="inherit_for_crossovered_budget_form" model="ir.ui.view">
        <field name="name">crossovered.budget.view.form</field>
        <field name="model">crossovered.budget</field>
        <field name="arch" type="xml">
            <form string="Budget">
                <header>
                    <button string="Reset to Draft" name="action_budget_draft" type="object" class="btn-primary"
                            invisible="state == 'draft'"/>
                    <button string="Confirm" name="action_budget_confirm" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button string="Validate" name="action_budget_validate" type="object" class="btn-secondary"
                            invisible="state != 'confirm'"/>
                    <button string="Done" name="action_budget_done" type="object" class="btn-secondary"
                            invisible="state != 'validate'"/>
                    <button string="Cancel" name="action_budget_cancel" type="object" class="btn-secondary"
                            invisible="state in ('cancel', 'done')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,validate,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_import_budget_details)d" type="action" string="Import" class="oe_stat_button" icon="fa-list"/>
                        <button name="%(droga_budget_category_detail_action)d" type="action" string="Budget" class="oe_stat_button" icon="fa-list"/>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="state == 'done'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="fiscal_year" options="{'no_create': True, 'no_open': True}" required="1"/>
                            <field name="user_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id" groups="base.group_multi_company"
                                   options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Budget Lines">
                            <field name="crossovered_budget_line" nolabel="1" readonly="state == 'done'">
                                <list editable="bottom">
                                    <field name="general_budget_id" string="Category" width="25"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="analytic_account_id" string="Analytic" width="25"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="fiscal_year" invisible="1"/>
                                    <field name="period" width="20" required="1"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="date_from" invisible="1"/>
                                    <field name="date_to" invisible="1"/>
                                    <field name="planned_amount" string="Budget" width="20" sum="Total"/>
                                    <field name="reallaocation_addition" string="Reallocation" width="20" readonly="1"/>
                                    <field name="addition" width="20" readonly="1"/>
                                    <field name="revised_budget" width="20" sum="Total" readonly="1"/>
                                    <field name="commitment_budget" width="20" sum="Total" readonly="1"/>
                                    <field name="practical_amount" string="Actual" width="20" sum="Total"/>
                                    <field name="remaining_balance" width="20" sum="Total" readonly="1"/>
                                    <button name="open_detail_budget" type="object" icon="fa-align-justify"/>
                                    <button name="action_open_budget_entries" type="object" icon="fa-arrow-circle-o-right" string="Entries"/>
                                    <field name="crossovered_budget_id" invisible="1"/>
                                    <field name="paid_date" groups="base.group_no_one" invisible="1"/>
                                    <field name="currency_id" invisible="1"/>
                                    <field name="theoritical_amount" invisible="1"/>
                                    <field name="percentage" invisible="1"/>
                                    <field name="is_above_budget" invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="inherit_for_crossovered_budget_tree" model="ir.ui.view">
        <field name="name">crossovered.budget.view.list</field>
        <field name="model">crossovered.budget</field>
        <field name="arch" type="xml">
            <list string="Budgets">
                <field name="name"/>
                <field name="fiscal_year"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="user_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="crossovered_budget_view_search" model="ir.ui.view">
        <field name="name">crossovered.budget.view.search</field>
        <field name="model">crossovered.budget</field>
        <field name="arch" type="xml">
            <search string="Budgets">
                <field name="name"/>
                <field name="fiscal_year"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="user_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirm" domain="[('state', '=', 'confirm')]"/>
                <filter string="Validated" name="validate" domain="[('state', '=', 'validate')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="cancel" domain="[('state', '=', 'cancel')]"/>
            </search>
        </field>
    </record>

    <record id="act_crossovered_budget_view" model="ir.actions.act_window">
        <field name="name">Budgets</field>
        <field name="res_model">crossovered.budget</field>
        <field name="view_mode">list,form,activity</field>
        <field name="view_id" ref="inherit_for_crossovered_budget_tree"/>
        <field name="search_view_id" ref="crossovered_budget_view_search"/>
    </record>

    <record id="crossovered_budget_lines_view_form" model="ir.ui.view">
        <field name="name">crossovered.budget.lines.view.form</field>
        <field name="model">crossovered.budget.lines</field>
        <field name="arch" type="xml">
            <form string="Budget Detail">
                <sheet>
                    <group>
                        <field name="general_budget_id" options="{'no_create': True, 'no_open': True}" readonly="1"/>
                    </group>
                    <notebook>
                        <page name="name" string="Detail Budget">
                            <field name="budget_line_details" mode="tree">
                                <list editable="bottom">
                                    <field name="account" width="20" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="budget_amount" width="15" sum="Total"/>
                                    <field name="commitment_budget" width="15" sum="Total" readonly="1"/>
                                    <field name="reallaocation" width="15" sum="Total" readonly="1"/>
                                    <field name="addition" width="15" sum="Total" readonly="1"/>
                                    <field name="revised_budget" width="15" sum="Total" readonly="1"/>
                                    <field name="actual" width="15" sum="Total" readonly="1"/>
                                    <field name="remaining_balance" width="15" sum="Total" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
