<?xml version="1.0" encoding="UTF-8" ?>
<templates id="pos_report_template" xml:space="preserve">
    <t t-name="droga_sales.PosReportFormView" t-inherit="web.FormView" t-inherit-mode="primary" owl="1">



         <xpath expr="(//div[last()])" position="inside">

            <button class="btn btn-info" type="button" t-on-click="OnClickPrint"
                    groups="purchase.group_purchase_manager">
                Print
            </button>

        </xpath>

        <xpath expr="//ActionMenus" position="after">

            <button class="btn btn-info" type="button" t-on-click="OnClickPrint"
                    groups="purchase.group_purchase_manager">
                Print
            </button>

        </xpath>

    </t>
</templates>