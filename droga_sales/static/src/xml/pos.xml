<?xml version="1.0" encoding="UTF-8" ?>
<templates id="pos_template" xml:space="preserve">
    <t t-name="droga_sales.PosFormView" t-inherit="web.FormView" t-inherit-mode="primary" owl="1">


         <xpath expr="//ActionMenus" position="after">

            <button class="btn btn-info" type="button" t-on-click="PrintToPos"
                    groups="purchase.group_purchase_manager" id="btnPosPrint">
                Print to POS
            </button>
             

             <button class="btn btn-info" type="button" t-on-click="CancelPosTransaction"
                     groups="purchase.group_purchase_manager" id="btnPosCancel">
                Cancel
            </button>





        </xpath>



    </t>
</templates>