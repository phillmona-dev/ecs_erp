<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="account_read_only_sales" model="ir.ui.view">
            <field name="name">sales.account.move.form</field>
            <field name="model">account.move</field>
            <field name="arch" type="xml">
                <form string="Account Entry" edit="false" create="false" delete="false">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="move_type" invisible="1"/>
                            <field name="name" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="invoice_date" readonly="1"/>
                            <field name="invoice_date_due" readonly="1"/>
                            <field name="invoice_payment_term_id" readonly="1"/>
                            <field name="payment_state" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Invoice Lines">
                                <field name="invoice_line_ids" readonly="1">
                                    <list>
                                        <field name="sequence" widget="handle"/>
                                        <field name="product_id"/>
                                        <field name="name"/>
                                        <field name="quantity"/>
                                        <field name="product_uom_id" groups="uom.group_uom"/>
                                        <field name="price_unit"/>
                                        <field name="discount"/>
                                        <field name="tax_ids" widget="many2many_tags"/>
                                        <field name="price_subtotal"/>
                                        <field name="price_total"/>
                                    </list>
                                </field>
                                <field name="narration" readonly="1"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" groups="base.group_user"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
    </data>
</odoo>
