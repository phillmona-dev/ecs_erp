<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="droga_sales_waiter_view_tree" model="ir.ui.view">
        <field name="name">sale.order.line.view.tree</field>
        <field name="model">sale.order.line</field>
        <field name="arch" type="xml">
            <tree default_order='date_order_det,order_partner_id,order_id' string="" create="false" delete="false">
                <field name="sales_initiator_det" string="WaiterName"></field>
                <field name="sales_dept" string="SalesMemo"></field>
                <field name="order_id" string="InvoiceNumber"></field>
                <field name="itemcode" string="ItemCode"></field>
                <field name="itemdesc" string="ItemDescription"></field>
                <field name="crm_group1" string="CRMCategory"></field>
                <field name="itemcateg" string="INVCategory"></field>
                <field name="cash_or_credit" string="PaymentType"></field>
                <field name="order_partner_id" string="BuyerName"></field>
                <field name="cust_type_ext_det"></field>
                <field name="cust_location" string="City"></field>
                <field name="qty_invoiced" string="Qty"></field>
                <field name="invoiced_amt" string="Grand Total"></field>
                <field name="invoice_date" string="Invoice Date"></field>

                <field name="product_uom" string="UOM" optional="hide"></field>
                <field name="crm_group1" optional="hide"></field>
                <field name="is_core" optional="hide"></field>
                <field name="date_order_det" string="Date" optional="hide"></field>
                <field name="order_from_det" optional="hide"></field>
                <field name="payment_term_det" optional="hide"></field>

                <field name="qty_delivered" optional="hide"></field>
                <field name="product_uom_qty" string="Qty ordered" optional="hide"></field>

                <field name="store_placement" optional="hide"></field>
                <field name="wareh" optional="hide" string="Warehouse"></field>
                <field name="price_unit" optional="hide"></field>
                <field name="state" optional="hide"></field>
                <field name="invoice_status" optional="hide"></field>
            </tree>
        </field>
    </record>

    <record id="droga_sales_waiter_search_tree" model="ir.ui.view">
        <field name="name">sale.order.line.search.tree</field>
        <field name="model">sale.order.line</field>
        <field name="arch" type="xml">
            <search string="Sales report">
                <field name="order_partner_id"></field>
                <field name="cust_type_ext_det"></field>
                <field name="order_id"></field>
                <field name="product_id"></field>
                <field name="name"></field>
                <field name="date_order_det" string="Date"></field>
                <field name="order_from_det"></field>
                <field name="payment_term_det"></field>
                <field name="crm_group1"></field>
                <field name="is_core"></field>

                <filter name="group_customer" string="By customer" context="{'group_by':'order_partner_id'}"/>
                <filter name="group_location" string="By location" context="{'group_by':'cust_location'}"/>
                <filter name="group_order_id" string="By sales order" context="{'group_by':'order_id'}"/>
                <filter name="group_prod_group" string="By product group" context="{'group_by':'crm_group1'}"/>
                <filter name="group_prod_id" string="By product" context="{'group_by':'product_id'}"/>
                <filter name="group_pay_term" string="By payment term" context="{'group_by':'payment_term_det'}"/>
                <filter name="group_order_from" string="By order from" context="{'group_by':'order_from_det'}"/>

                <separator/>

                <filter name="app_so" string="Sales orders" domain="[('state', '=', 'sale')]"/>
                <filter name="pro_so" string="Workflow pending SO" domain="[('state', '!=', 'sale')]"/>
                <filter name="core_only" string="Core products" domain="[('is_core', '=', True)]"/>
                <filter name="non_core" string="Non-core products" domain="[('is_core', '=', False)]"/>
                <filter name="import_whole" string="Import and wholesale only" domain="[('order_from_det', 'in', ('IM-IM','IM-WS'))]"/>
                <filter name="physio" string="Physiotherapy only" domain="[('order_from_det', 'in', ('PT-4 Kilo','PT-Bole'))]"/>
                <filter name="invoiced" string="Invoiced" domain="[('qty_invoiced','>',0)]"/>

                <separator/>

                <filter string="Today sales"
                        domain="[('date_order_det', '&gt;=', context_today().strftime('%Y-%m-%d')), ('date_order_det', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d'))]"
                        name="today_sales"></filter>
                <filter string="Current week sales"
                        domain="[('date_order_det', '&lt;=', (context_today() + relativedelta(weeks=0,weekday=-1)).strftime('%Y-%m-%d')),('date_order_det', '&gt;=', (context_today() - relativedelta(weeks=1,weekday=0)).strftime('%Y-%m-%d'))]"
                        name="current_week_sales"></filter>
                <filter string="Current month sales"
                        domain="[('date_order_det', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d')),('date_order_det', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]"
                        name="current_month_sales"></filter>
                <filter string="Previous week sales"
                        domain="[('date_order_det', '&lt;=', (context_today() - relativedelta(weeks=1,weekday=-1)).strftime('%Y-%m-%d')),('date_order_det', '&gt;=', (context_today() - relativedelta(weeks=2,weekday=0)).strftime('%Y-%m-%d'))]"
                        name="previous_week_sales"></filter>
                <filter string="Previous month sales"
                        domain="[('date_order_det', '&lt;=', (context_today() + relativedelta(months=-1,day=31)).strftime('%Y-%m-%d')),('date_order_det', '&gt;=', (context_today() - relativedelta(months=1,day=1)).strftime('%Y-%m-%d'))]"
                        name="previous_month_sales"></filter>
            </search>
        </field>
    </record>

    <record id="droga_sales_waiter_action" model="ir.actions.act_window">
        <field name="name">Sales waiter report</field>
        <field name="res_model">sale.order.line</field>
        <field name="view_mode">tree,pivot</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_sales_waiter_view_tree')})]"/>
        <field name="search_view_id" ref="droga_sales_waiter_search_tree"></field>
        <field name="domain">[('state', '!=', 'cancel'),('has_access','=',True)]</field>
        <field name="context">{'search_default_invoiced':1,'search_default_import_whole':1,'search_default_today_sales': 1}</field>
    </record>

    <menuitem
            id="droga_sales_waiter_report_menu"
            name="Sales waiter report"
            action="droga_sales_waiter_action"
            parent="droga_sales.droga_sales_reports_menu"
            groups="droga_crm.crm_sr"
            sequence="17"/>
</odoo>
