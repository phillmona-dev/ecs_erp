<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- action for Sales Attachment -->
    <record id="droga_sales_pos_attachment_action" model="ir.actions.report">
        <field name="name">Sales Attachment</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">droga_sales.droga_sales_pos_attachment_report</field>
        <field name="report_file">droga_sales.droga_sales_pos_attachment_report</field>
        <field name="print_report_name">'Sales Attachment - %s' % (object.name)
        </field>
        <field name="binding_model_id" ref="model_account_move"/>
        <field name="binding_type">report</field>
    </record>

    <template id="droga_sales_pos_attachment_report" name="Sales Attachment">

        <t t-call="web.html_container">

            <t t-call="web.basic_layout">

                <t t-foreach="docs" t-as="o">

                    <!-- Store and Sales Represnetataives -->
                    <t t-set="store" t-value=""/>
                    <t t-set="sales_representative" t-value=""/>
                    <t t-set="order_type" t-value=""/>

                    <t t-foreach="request.env['sale.order'].search([('name', '=', o.invoice_origin)])"
                       t-as="sale_order">
                        <t t-set="sales_order_no" t-value="sale_order.name"/>
                        <t t-set="sales_representative" t-value="sale_order.sales_initiator"/>
                        <t t-set="store" t-value="sale_order.order_type"/>
                        <t t-set="order_type" t-value="sale_order.sales_type"/>
                    </t>

                    <div class="header">
                        <div class="row">
                            <div class="col-2 bm-2">
                                <img
                                        t-attf-src="data:image/*;base64,{{o.company_id.logo}}"
                                        t-att-alt="o.company_id.name"
                                        t-field-options='{"widget": "image", "style":"width: 150px;height: 150px"}'
                                />
                            </div>
                            <t t-if="store=='IM'">
                                <div class="col-10 bm-2">
                                    <h2>
                                        <span t-esc="o.company_id.name"/>
                                    </h2>
                                    <h6>
                                        Sub City: Gulele     Kebele: 09          Bldg/H.No. New
                                    </h6>
                                    <h6>Tel 1: +251939323232 +251913667537   Tel 2: +251929908565/66 - Tel 3:
                                        +251974858585
                                    </h6>
                                    <h6>
                                        TIN: 0045080232      VAT Reg. No. :
                                    </h6>

                                </div>
                            </t>

                            <t t-if="store=='WS'">
                                <div class="col-10 bm-2">
                                    <h2>
                                        <span t-esc="o.company_id.name"/>
                                    </h2>
                                    <h6>
                                        Addis Ababa,  Sub City: A/Ketema  W.06  H.NO 133
                                    </h6>
                                    <h6>
                                        Tel. +251 960424242 /+251 929 90 85 65/66 /+251 913 66 75 37
                                    </h6>
                                    <h6>
                                        TIN: 0045080232      VAT Reg. No. :
                                    </h6>

                                </div>
                            </t>

                        </div>

                    </div>
                    <div class="mt-5">
                        <div class="page">

                            <div class="oe_structure"/>


                            <div id="informations" class="row mt32 mb32 text-center">
                                <div class="col-12 bm-2">
                                    <t t-if="order_type=='Cash sales'">
                                        <h2>Cash Sales Attachment</h2>
                                    </t>
                                    <t t-if="order_type=='Credit sales'">
                                        <h2>Credit Sales Attachment</h2>
                                    </t>
                                </div>
                            </div>

                            <br/>
                            <div id="informations" class="row mt32 mb32">
                                <div class="col-4 bm-2">
                                    <strong>Shop/Store:</strong>
                                    <span t-esc="store"/>

                                </div>
                                <div class="col-8 bm-2">
                                    <strong>Sales Agent/Representative:</strong>
                                    <span t-esc="sales_representative"/>

                                </div>


                            </div>
                            <br/>


                            <table class="table  table-bordered table-sm o_main_table "
                                   style="page-break-inside: avoid;">
                                <tr>
                                    <td>
                                        <strong>Date:</strong>
                                        <span class="small" t-esc="o.FTimeStamp"
                                              t-options='{"widget": "datetime","format": "MM-dd-yyyy h:mm a"}'/>
                                    </td>
                                    <td>
                                        <strong>Fs No.:</strong>
                                        <span class="small" t-esc="o.FSInvoiceNumber"/>
                                    </td>
                                    <td>
                                        <strong>Invoice No.:</strong>
                                        <span class="small" t-esc="o.name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="2">
                                        <strong>Customer Information</strong>
                                    </td>
                                    <td>
                                        <strong>Order No.:</strong>
                                        <span class="small" t-esc="sales_order_no"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="2">
                                        <strong>Customer Name:</strong>
                                        <span class="small" t-esc="o.partner_id.name"/>
                                    </td>

                                    <td>
                                        <strong>TIN.:</strong>
                                        <span class="small" t-esc="o.partner_id.vat"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>ID No.:</strong>
                                    </td>
                                    <td colspan="2"></td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>Address:</strong>
                                        <span t-esc="o.partner_id.street"/>
                                    </td>
                                    <td colspan="2">
                                        <strong>City:</strong>
                                        <span t-esc="o.partner_id.city"/>
                                    </td>
                                </tr>
                            </table>

                            <div class="watermark"
                                 style="position:absolute;opacity:0.1;font-size:3em;height:100%width:100%;text-align:center;z-index:1000;border:0; transform: rotate(-45deg); -webkit-transform: rotate(-45deg);">
                                <span style="font-size:120px; transform: rotate(45deg);  ">Attachement</span>
                            </div>

                            <table class="table table-bordered o_main_table table-sm">
                                <thead class="thead-dark">
                                    <tr>

                                        <th scope="col" class="text-start">Code</th>
                                        <th scope="col" class="text-start">Item Description</th>
                                        <th scope="col">Batch #</th>
                                        <th scope="col">Expiry Date</th>
                                        <th scope="col" class="text-center">UoM</th>
                                        <th scope="col" class="text-center">Qty</th>
                                        <th scope="col" class="text-end">Unit Price</th>
                                        <th scope="col" class="text-end">Total Price</th>
                                    </tr>
                                </thead>
                                <tbody class="invoice_tbody">
                                    <t t-foreach="o.invoice_line_ids" t-as="line">
                                        <t t-if="line.price_unit!=0">

                                            <!-- get batch no and expiry date -->
                                            <t t-set="batch_no" t-value=""/>
                                            <t t-set="expiry_date" t-value=""/>

                                            <t t-foreach="request.env['sale.order'].search([('name', '=', o.invoice_origin)])"
                                               t-as="sale_order">
                                                <t t-foreach="sale_order.order_line" t-as="sale_order_line">
                                                    <t t-if="sale_order_line.product_id.id==line.product_id.id">
                                                        <t t-set="batch_no" t-value="sale_order_line.batch_html"/>
                                                        <t t-set="expiry_date"
                                                           t-value="sale_order_line.expiry_date_html"/>
                                                    </t>
                                                </t>
                                            </t>
                                            <tr>

                                                <td class="text-start">
                                                    <span class="small"
                                                          t-esc="line.product_id.product_tmpl_id.default_code"/>
                                                </td>
                                                <td>
                                                    <span class="small" t-esc="line.name"/>
                                                </td>
                                                <td>
                                                    <span class="small">
                                                        <t t-esc="batch_no"/>
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="small">
                                                        <t t-esc="expiry_date"/>
                                                    </span>
                                                </td>
                                                <td class="text-center">
                                                    <t t-if="not line.item_uom_alternate">
                                                        <span class="small" t-esc="line.product_uom_id.name"/>
                                                    </t>
                                                      <t t-if="line.item_uom_alternate">
                                                        <span class="small" t-esc="line.item_uom_alternate"/>
                                                    </t>

                                                </td>
                                                <td class="text-center">
                                                    <span class="small" t-esc="line.quantity"/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-esc="'{0:,.2f}'.format(line.price_unit)"
                                                          class="small"/>
                                                </td>
                                                <td class="text-end">
                                                    <span t-esc="'{0:,.2f}'.format(line.price_subtotal)"
                                                          class="small"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>

                                    <tr class="is-subtotal text-end">
                                        <td colspan="7">
                                            <strong class="mr16">Sub Total</strong>

                                        </td>
                                        <td>
                                            <strong t-esc="'{0:,.2f}'.format(o.amount_total)"
                                                    class="small"/>
                                        </td>
                                    </tr>
                                    <tr class="is-subtotal text-end">
                                        <td colspan="7">
                                            <strong class="mr16">Non Tax (%)</strong>

                                        </td>
                                        <td>
                                            <strong class="small">0.00</strong>
                                        </td>
                                    </tr>
                                    <tr class="is-subtotal text-end">

                                        <td colspan="7">
                                            <strong class="mr16">Grand Total</strong>

                                        </td>
                                        <td>
                                            <strong t-esc="'{0:,.2f}'.format(o.amount_total)"
                                                    class="small"/>
                                        </td>
                                    </tr>

                                </tbody>

                            </table>


                            <br/>
                            <div id="informations" class="row mt32 mb32">
                                <div class="col-12 bm-2">
                                    <strong>Total Amount in Words:</strong>
                                    <span t-esc="o.total_amount_word"/>
                                </div>
                            </div>
                            <br/>
                            <div id="informations" class="row mt32 mb32">
                                <div class="col-12 bm-2">
                                    <strong>I received the above goods/services in good
                                        condition._______________________________
                                    </strong>
                                </div>
                            </div>
                            <br/>
                            <div id="informations" class="row mt32 mb32">
                                <div class="col-12 bm-2">
                                    <span>Memo / Note:</span>
                                </div>
                            </div>
                            <hr></hr>
                            <div id="informations" class="row mt32 mb32">
                                <div class="col-6 bm-2">
                                    <span>Prepared By :</span>
                                    <u t-esc="o.create_uid.name"/>
                                </div>
                                <div class="col-6 bm-2">
                                    <span>Checked By :________________________</span>
                                </div>
                            </div>
                            <br/>
                            <div id="informations" class="row mt32 mb32">
                                <div class="col-6 bm-2">
                                    <span>Approved By :________________________</span>
                                </div>
                                <div class="col-6 bm-2">
                                    <span>Received By :________________________</span>
                                </div>
                            </div>
                            <br/>
                            <div id="informations" class="row mt32 mb32">
                                <div class="col-6 bm-2">
                                    <span>Signature :___________________________</span>
                                </div>

                            </div>
                            <hr></hr>
                            <div id="informations" class="row mt32 mb32">
                                <div class="col-12 bm-2 text-center">
                                    <strong>This receipt is not valid unless the fiscal receipt is attached!</strong>

                                </div>

                            </div>
                            <br/>
                            <div id="informations" class="row mt32 mb32">
                                <div class="col-12 bm-2 text-center">
                                    <span t-esc="o.FPMachineID"/>
                                </div>

                            </div>


                        </div>
                    </div>
                    <div class="footer">
                        <hr></hr>
                        <div class="row">
                            <div class="col-12 bm-2 text-center">
                                <h6>
                                    email:-
                                    <span t-esc="o.company_id.email"/>
                                    website:-
                                    <span t-esc="o.company_id.website"/>
                                </h6>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>


</odoo>