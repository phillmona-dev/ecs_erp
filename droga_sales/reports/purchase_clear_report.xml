<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_account_move_line_purchase" model="ir.ui.view">
        <field name="name">account.move.line.purchase.tree</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <tree create="0" default_order="inv_origin desc">
                <field name="account_id"/>
                <field name="move_id" widget="many2one" options='{"no_open": False}'/>
                <field name="date"/>
                <field name="amount_currency" sum="Amount"/>
                <field name="inv_origin"/>
                <field name="create_date" optional="hide"></field>
                <field name="create_uid" optional="hide"></field>
                <field name="journal_id" optional="hide"></field>
                <field name="stat" widget="badge" decoration-success="stat=='Matched'" decoration-warning="stat=='Unmatched'"></field>
            </tree>
        </field>
    </record>

    <record id="view_account_move_line_purchase_search" model="ir.ui.view">
        <field name="name">account.move.line.purchase.search</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="account_id"/>
                <field name="move_id"/>
                <field name="date"/>
                <field name="amount_currency" sum="Total"/>
                <field name="inv_origin"/>
                <field name="stat"/>

                <filter name="unmatched" string="Unmatched" domain="[('stat', '=', 'Unmatched')]"/>
                <filter name="matched" string="Matched" domain="[('stat', '=', 'Matched')]"/>

                <separator/>

                <filter name="local" string="Local" domain="[('account_id', '=', 2468)]"/>
                <filter name="foreign" string="Foreign" domain="[('account_id', '=', 990)]"/>
                <filter name="export" string="Export" domain="[('account_id', '=', 4221)]"/>

                <group expand="1" string="Group By">
                    <filter string="Purchase order" name='group_inv_origin' context="{'group_by':'inv_origin'}"/>
                </group>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="view_account_move_line_purchase_action">
        <field name="name">Local/Foreign/Export purchase clearing report</field>
        <field name="res_model">account.move.line</field>
        <field name="context">{'search_default_unmatched':1,'search_default_group_inv_origin':1}</field>
        <field name="view_mode">tree,pivot</field>
        <field name="view_id" ref="view_account_move_line_purchase"/>
        <field name="search_view_id" ref="view_account_move_line_purchase_search"/>
        <field name="domain">[('account_id','in',(990,4221,2468))]</field>
    </record>

    <menuitem id="droga_purchase_clearing" name="Local/Foreign/Export purchase clearing report"
                  action="view_account_move_line_purchase_action"
                parent="droga_finance.droga_payables_report"
                  groups="account.group_account_manager,droga_inventory.inv_prod_fin" sequence="2"/>
</odoo>