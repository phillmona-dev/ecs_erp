<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="item_issue_request_report" model="ir.actions.report">
        <field name="name">Requisition Form</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">droga_sales.issue_report_template</field>
        <field name="report_file">droga_sales.issue_report_template</field>
        <field name="print_report_name">(object.name)</field>
        <field name="binding_model_id" ref="model_sale_order"/>
        <field name="binding_type">report</field>
    </record>
    <template id="issue_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="o">
                    <style>
                        table,th,td{
                        font-size: 15px;
                        }
                    </style>
                    <div class="page">
                        <div class="col-lg-12">
                            <div style="margin-top: 2em;">
                                <table class="table" style="border: 0px solid none;">
                                    <tr>
                                        <td>Name Of Institution</td>
                                        <td>
                                            <t t-esc="o.partner_id.name"/>
                                        </td>
                                        <td>TIN NO.</td>
                                        <td>
                                            <t t-esc="o.Vat_no"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Address</td>
                                        <td>
                                            <t t-esc="o.partner_id.location"/>
                                        </td>
                                        <td>Mode Of Payment.</td>
                                        <td>
                                            <t t-esc="o.payment_term_id.name"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>Expected Delivery Time</td>
                                    </tr>
                                </table>
                            </div>
                            <div style="margin-top: 2em;">
                                <table class="table table-border" style="border: 1px solid black;">
                                    <tr>
                                        <th>No.</th>
                                        <th>Item Code</th>
                                        <th>Description</th>
                                        <th>UOM</th>
                                        <th>Quantity</th>
                                        <th>Batch No.</th>
                                        <th>Expiry Date</th>
                                        <th>Unit Price</th>
                                        <th>Total Amount</th>
                                        <th>Remark</th>
                                    </tr>
                                    <t t-set="index" t-value="1"/>
                                    <t t-set="grand_total" t-value="0"/>
                                    <t t-foreach="o.order_line" t-as="order_line">
                                        <tr>
                                            <td>
                                                <t t-esc="index"/>
                                            </td>
                                            <td>
                                                <t t-esc="order_line.product_id.default_code"/>
                                            </td>
                                            <td>
                                                <t t-esc="order_line.product_id.name"/>
                                            </td>

                                            <td>
                                                <t t-esc="order_line.product_uom.name"/>
                                            </td>
                                            <td>
                                                <t t-esc="order_line.product_uom_qty"/>
                                            </td>

                                            <td>
                                                <t t-esc="order_line.batch_html"/>
                                            </td>
                                            <td>
                                                <t t-esc="order_line.expiry_date_html"/>
                                            </td>
                                            <td>
                                                <t t-esc="order_line.price_unit"/>
                                            </td>
                                            <td>
                                                <t t-esc="order_line.price_subtotal"/>
                                            </td>
                                            <td>
                                                Remark
                                            </td>
                                        </tr>
                                        <t t-set="grand_total"
                                           t-value="grand_total+order_line['price_subtotal']"/>
                                        <t t-set="index" t-value="index+1"/>
                                    </t>
                                    <tr>
                                        <td colspan="8" style="text-align: right;">Grand Total
                                        </td>
                                        <td colspan="2">
                                            <t t-esc="grand_total"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                            <div>
                                <div>
                                    <table class="table" style="border: 0px solid none;">
                                        <tr>
                                            <td>Requested By:</td>
                                            <td>Approved By:</td>
                                        </tr>
                                        <tr>
                                            <td>Signature:</td>
                                            <td>Signature:</td>
                                        </tr>
                                        <tr>
                                            <td>Date:</td>
                                            <td>Date:</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>