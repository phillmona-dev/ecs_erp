<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id = "Sales_rep_Own_access_only" model = "ir.rule">
        <field name = "name"> Sales rep can only access his or her own sales only </field>
        <field name = "model_id" search="[('model','=','sale.order')]"/>
        <field name = "groups" eval = "[(4, ref ('droga_crm.crm_sales_rep'))]" />
        <field name = "perm_read" eval = "True" />
        <field name = "perm_unlink" eval = "True" />
        <field name = "perm_create" eval = "False" />
        <field name = "perm_write" eval = "False" />
        <field name = "domain_force"> [('is_record_owner', '=', True)] </field>
    </record>

    <record id = "Sales_rep_create_access" model = "ir.rule">
        <field name = "name"> Everyone can create sales order.</field>
        <field name = "model_id" search="[('model','=','sale.order')]"/>
        <field name = "groups" eval = "[(4, ref ('droga_crm.crm_sales_rep'))]" />
        <field name = "perm_create" eval = "True" />
        <field name = "perm_write" eval = "True" />
        <field name = "perm_read" eval = "False" />
        <field name = "perm_unlink" eval = "False" />
        <field name = "domain_force"> [(1, '=', 1)] </field>
    </record>

    
</odoo>
