<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- inherited for view of account.move -->
    <record id="inherit_for_xml_account_move_form" model="ir.ui.view">
        <field name="name">Account Move XML Generator Button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">

            <!-- <xpath expr="//button[@name='button_draft']" position="after">
                 <button string="Print to POS" type="object" class="oe_highlight" name="generate_sales_xml"/>
             </xpath>

             <xpath expr="//button[@name='button_draft']" position="after">
                 <button string="PEDS" type="object" class="oe_highlight" name="print_to_pos_peds"/>
             </xpath>-->

            <xpath expr="//form/sheet/notebook/page[@name='other_info']" position="after">
                <page string="FS Info">
                    <group>
                        <group>
                            <field name="FSInvoiceNumber" string="FS Number"/>
                            <field name="FTimeStamp" string="Timestamp"/>
                        </group>
                        <group>
                            <field name="FPMachineID" string="MachineID" readonly="1"/>
                            <field name="EJNumber" string="EJ Number"/>
                        </group>
                    </group>
                </page>
            </xpath>


        </field>
    </record>


    <record id="inherit_for_xml_account_move_tree" model="ir.ui.view">
        <field name="name">Account Move XML Generator Button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="FSInvoiceNumber" string="FS Number"/>
            </xpath>
        </field>
    </record>
</odoo>
