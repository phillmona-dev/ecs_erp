<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="droga_sale_order_warehouse_line" model="ir.ui.view">
        <field name="name">Sales order line warehouse extension</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <xpath expr = "//form/sheet/notebook/page/field[@name='order_line']/tree/field[@name='product_uom_readonly']" position = "after">
                <field name="wareh" string="Warehouse" options="{'no_create': True}"/>
            </xpath>

            <xpath expr = "//form/sheet/div/button[@name='action_preview_sale_order']" position = "before">
                    <field name="show_invoice_button" invisible="1"></field>
                    <button icon="fa-credit-card-alt" attrs="{'invisible': [('show_invoice_button', '=', False)]}"
                        type="object" string=" Matured invoices"
                        name="action_view_matured" class="oe_stat_button"/>

            </xpath>

            <xpath expr = "//form/sheet/group/group/field[@name='payment_term_id']" position="after">
                <field name="show_invoice_button" invisible="1"></field>
                <field name="matured_amount" attrs="{'invisible': [('show_invoice_button', '=', False)]}"></field>
            </xpath>

            <xpath expr = "//form/sheet/notebook/page/group/group/field[@name='note']" position = "replace">
                <field name="core_sum" string="Core sum" readonly="1"/>
                <field name="non_core_sum" string="Non-core sum" readonly="1"/>
                <field name="total_discount" string="Total discount" readonly="1"/>
            </xpath>
            <xpath expr = "//form/header/button[@name='action_draft']" position="after">
                <button name="store_issue_placement_order" type="object"
                        string="Store placement issue"/>
            </xpath>
            <xpath expr = "//form/sheet/group/group/field[@name='partner_id']" position = "after">
                <field name="pay_type" invisible="1"/>
                <field name="cash_upfront" attrs="{'invisible': [('pay_type', '=', False)],'readonly': [('state','!=', 'draft')]}"/>
                <field name="available_amount" attrs="{'invisible': [('pay_type', '=', False)]}" string="Credit balance" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>

    <record id="droga_sale_order_warehouse_readonly_disable" model="ir.ui.view">
        <field name="name">Sales order warehouse disable extension</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock" />
        <field name="priority" eval="100000000"/>
        <field name="arch" type="xml">
            <xpath expr = "//field[@name='warehouse_id'][@force_save='1']" position = "attributes">
                <attribute name="required">False</attribute>
            </xpath>
        </field>
    </record>

    <record id="droga_sales_placement_extension" model="ir.ui.view">
        <field name="name">droga.inventory.sales.issue.inherited</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="inherit_id" ref="droga_inventory.droga_inventory_consignment_issue_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group/group/field[@name='issue_type']" position="after">
                <field string='Sales origin' name="sales_placement_origin_form" attrs="{'invisible': [('sales_placement_origin_form', '=', False)]}"></field>
            </xpath>
        </field>
    </record>

    <record id="droga_tender_sample_request_tree_sales" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.issue.inherited.tree.sales</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="inherit_id" ref="droga_inventory.droga_inventory_consignment_issue_view_tree_sales"/>
        <field name="arch" type="xml">
            <xpath expr="//tree/field[@name='customer']" position="after">
                <field string='Sales origin' name="sales_placement_origin_form" attrs="{'invisible': [('sales_placement_origin_form', '=', False)]}"></field>
            </xpath>
        </field>
    </record>

    <menuitem
        id="droga_sales_SIV_menu"
        name="SIV without sales order"
        action="droga_inventory.droga_inventory_consignment_issue_action_sales"
        parent="sale.sale_order_menu"
        sequence="20"/>

</odoo>
