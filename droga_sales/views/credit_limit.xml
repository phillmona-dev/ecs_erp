<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_sales_credit_limit_tree" model="ir.ui.view">
        <field name="name">res.partner.credit.limit.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list create="0" editable="bottom" delete="0">
                <field name="name" readonly="1"/>
                <field name="vat" string="Tin No"/>
                <field name="city_name" string="City/sub-city"/>
                <field name="property_supplier_payment_term_id" string="Payment terms" options="{'no_create':True,'no_open':True}"/>
                <field name="cust_credit_limit"/>
                <field name="unsettled_amount" readonly="1"/>
                <field name="available_amount"/>
            </list>
        </field>
    </record>

    <record id="droga_sales_credit_limit_search" model="ir.ui.view">
        <field name="name">res.partner.credit.limit.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="vat"/>
                <field name="city_name" string="City/sub-city"/>
                <field name="property_supplier_payment_term_id"/>
                <field name="cust_credit_limit"/>
                <field name="unsettled_amount"/>
                <field name="available_amount"/>
            </search>
        </field>
    </record>

    <record id="droga_sales_credit_limit_action" model="ir.actions.act_window">
        <field name="name">Credit limit</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list</field>
        <field name="view_ids" eval="[(5, 0, 0),(0, 0, {'view_mode': 'list', 'view_id': ref('droga_sales_credit_limit_tree')})]"/>
    </record>

    <record id="account_invoice_addfilters_inherit" model="ir.ui.view">
        <field name="name">account.move.filter.add</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='late']" position="after">
                <filter string="Due in 10 days" name="in_10_days" domain="[                         ('invoice_date_due', '&lt;', (context_today() + relativedelta(days=10)).strftime('%Y-%m-%d')),                         ('invoice_date_due', '&gt;', context_today().strftime('%Y-%m-%d')),                         ('state', '=', 'posted'),                         ('payment_state', 'in', ('not_paid', 'partial'))                     ]"/>
            </xpath>
        </field>
    </record>

    <record id="droga_sales_payment_term_exclusion" model="ir.ui.view">
        <field name="name">Apply credit limit</field>
        <field name="model">account.payment.term</field>
        <field name="inherit_id" ref="account.view_payment_term_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='display_on_invoice']" position="after">
                <label for="apply_credit_limit"/>
                <field name="apply_credit_limit"/>
                <label for="deliv_after_payment"/>
                <field name="deliv_after_payment"/>
                <label for="min_amount"/>
                <field name="min_amount"/>
                <label for="used_under"/>
                <field name="used_under"/>
                <label for="allowed_terms"/>
                <field name="allowed_terms" widget="many2many_tags"/>
            </xpath>
            <xpath expr="//form/sheet" position="after">
                <div class="oe_chatter">
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </xpath>
        </field>
    </record>

    <menuitem id="droga_sales_credit_limit_menu" name="Credit limit" action="droga_sales_credit_limit_action" parent="account.account_invoicing_menu" sequence="20"/>

</odoo>
