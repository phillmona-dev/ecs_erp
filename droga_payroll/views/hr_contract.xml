<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="inherit_hr_contract_view_action" model="ir.actions.act_window">
        <field name="name">Salary Detail</field>
        <field name="res_model">hr.job.salary</field>
        <field name="view_mode">form</field>
        <field name="domain">[]</field>
        <field name="target">new</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Salary Detail
            </p>
        </field>
    </record>

    <!--inherit contract -->
    <record id="inherit_hr_contract_view_form" model="ir.ui.view">
        <field name="name">Contract</field>
        <field name="model">hr.version</field>
        <field name="priority" eval="1"/>
        <field name="inherit_id" ref="hr.hr_contract_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='contract']" position="inside">
                <separator name="custom_payroll" string="Custom Payroll"/>
                <field name="custom_salary_structure" string="Custom Salary"/>
                <field name="pension_contribution"/>
                <field name="sales"/>
                <field name="canteen"/>
                <field name="sales_commission"/>
                <field name="has_company_vehicle"/>
                <field name="paid_by_usd"/>
                <field name="payments_deduction_links" widget="many2many_tags" options="{'no_create': true, 'no_open': true}"/>
            </xpath>
            <xpath expr="//page[@name='information']" position="inside">
                <group string="Salary and Benefits" cols="1">
                    <field name="salary_structure" mode="tree" invisible="(custom_salary_structure == True)">
                        <list editable="bottom">
                            <field name="name"/>
                            <field name="date_from" required="1"/>
                            <field name="date_to"/>
                            <field name="state"/>
                        </list>
                    </field>
                    <field name="salary_structure_custom" mode="tree" invisible="(custom_salary_structure == False)">
                        <list context="{'default_contract_id': id, 'default_job_id': job_id}">
                            <field name="job_id" invisible="1"/>
                            <field name="name"/>
                            <field name="date_from" required="1"/>
                            <field name="date_to"/>
                            <field name="state"/>
                        </list>
                    </field>
                    <field name="payment_deductions" mode="tree" string="Payment and Deductions">
                        <list editable="bottom">
                            <field name="input_type" string="PD"/>
                            <field name="input_types" string="PD Type"/>
                            <field name="date_from" string="Date From"/>
                            <field name="date_to" string="Date To"/>
                            <field name="amount" string="Amount"/>
                            <field name="total_amount" string="Total Amount"/>
                            <field name="rem_amount" readonly="1"/>
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
