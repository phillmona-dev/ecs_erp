<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- tree view -->
    <record id="hr_payroll_rate_tree_view" model="ir.ui.view">
        <field name="name">hr.payroll.rate</field>
        <field name="model">hr.payroll.rate</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="code"/>
                <field name="rate"/>
                <field name="date_from"/>
                <field name="date_to"/>

            </list>
        </field>
    </record>

    <!-- action for the tree view -->
    <record id="hr_payroll_rate_tree_action" model="ir.actions.act_window">
        <field name="name">Payroll Rates</field>
        <field name="res_model">hr.payroll.rate</field>
        <field name="view_mode">list</field>
        <field name="view_ids" eval="[(5, 0, 0),         (0, 0, {'view_mode': 'list', 'view_id': ref('hr_payroll_rate_tree_view')})]"/>
    </record>


    <!-- rule for filtering data specific data -->
    <record model="ir.rule" id="droga_hr_payroll_rate_rule">
        <field name="name">Payroll Rate multi-company</field>
        <field name="model_id" ref="model_hr_payroll_rate"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

</odoo>