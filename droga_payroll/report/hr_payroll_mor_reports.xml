<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- for generating income tax report for MOR -->
    <record id="hr_payslip_run_report_tax_form" model="ir.ui.view">
        <field name="name">Income Tax Report</field>
        <field name="model">hr.payslip.run.report</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="fiscal_year" required="1"/>
                        <field name="period" required="1"/>
                        <field name="report_type" required="1"/>
                        <field name="company_id" required="1" readonly="1" options="{'no_create': true, 'no_open': true}"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_payroll_tax_report" string="Print" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- action for income tax and pension report generation -->
    <record id="hr_payslip_run_report_tax_action" model="ir.actions.act_window">
        <field name="name">Tax Report MOR - Excel</field>
        <field name="res_model">hr.payslip.run.report</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hr_payslip_run_report_tax_form"/>
        <field name="target">new</field>
    </record>
</odoo>