<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- inherited for view of purchase.order -->
    <record id="inherit_for_hr_payslip_run_form" model="ir.ui.view">
        <field name="name">Payslip Run</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_draft']" position="after">
                <button string="Report" name="droga_payroll_sheet_report_action" type="object"/>
                <button string="Send Payslip email" name="action_send_payslip_email" type="object"/>
            </xpath>
        </field>
    </record>

    <!-- action -->
    <record id="hr_employee_payroll_rate_run_action" model="ir.actions.act_window">
        <field name="name">Employee Payroll Rate - Excel</field>
        <field name="res_model">hr.employee.payroll.rate.run</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- -->
    <record id="hr_employee_payroll_rate_run_form" model="ir.ui.view">
        <field name="name">hr.employee.payroll.rate.run.view.form</field>
        <field name="model">hr.employee.payroll.rate.run</field>
        <field name="arch" type="xml">
            <form string="" delete="0">
                <group>
                    <group>
                        <field name="company_id"/>
                    </group>

                </group>
                <footer>
                    <button name="action_generate_payroll_rate_report" string="Get Excel" type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>