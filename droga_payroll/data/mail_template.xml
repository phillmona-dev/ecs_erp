<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="email_template_payslip" model="mail.template">
            <field name="name">Payslip Notification</field>
            <field name="model_id" ref="hr_payroll.model_hr_payslip"/>
            <field name="subject">Your Payslip for {{ object.employee_id.name }} - {{ object.date_from.strftime('%B %Y') }}</field>
            <field name="email_from">{{ object.company_id.email or 'noreply@%s' % object.company_id.name.lower().replace(' ', '.') }}</field>
            <field name="email_to">{{ object.employee_id.work_email.strip() }}</field>
            <field name="description">Payslip email for {{ object.employee_id.name }}</field>
            <field name="lang">{{ object.employee_id.lang }}</field>
            <field name="report_name">Payslip_{{ object.employee_id.name }}_{{ object.date_from.strftime('%B_%Y') }}</field>
            <field name="auto_delete" eval="False"/>
            <field name="body_html" type="html"><![CDATA[
                <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
                    <p>Dear <t t-out="object.employee_id.name"/>,</p>
                    <p>We hope this message finds you well.</p>
                    <p>Please find attached your payslip for the period from
                        <t t-out="object.date_from.strftime('%B %d, %Y')"/> to
                        <t t-out="object.date_to.strftime('%B %d, %Y')"/>. Below is a summary of your earnings and deductions:</p>
                    <div style="overflow-x: auto;">
                        <table style="width: 100%; border-collapse: collapse; font-size: 13px; margin: 20px 0;">
                            <thead style="background-color: #343a40; color: #fff;">
                                <tr>
                                    <th style="padding: 10px; border: 1px solid #dee2e6; text-align: left;">Description</th>
                                    <th style="padding: 10px; border: 1px solid #dee2e6; text-align: right;">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="object.line_ids.filtered(lambda line: line.appears_on_payslip)" t-as="line">
                                    <tr>
                                        <td style="padding: 10px; border: 1px solid #dee2e6;">
                                            <t t-out="line.name"/>
                                        </td>
                                        <td style="padding: 10px; border: 1px solid #dee2e6; text-align: right;">
                                            <t t-esc="'{:,.2f}'.format(line.total)"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr style="background-color: #f8f9fa; font-weight: bold;">
                                    <td style="padding: 10px; border: 1px solid #dee2e6;">Net Pay</td>
                                    <td style="padding: 10px; border: 1px solid #dee2e6; text-align: right;">
                                        <t t-esc="'{:,.2f}'.format(object.net_wage)"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <p>If you have any questions, please contact HR at
                        <a t-att-href="'mailto:%s' % object.company_id.email"><t t-out="object.company_id.email"/></a>.</p>
                    <p>Thank you for your dedication to <t t-out="object.company_id.name.strip()"/>.</p>
                    <p>Best regards,<br/>
                        <t t-out="object.company_id.name.strip()"/><br/>
                        HR Department</p>
                </div>
            ]]></field>
            <field name="attachment_ids" eval="[(6, 0, [])]"/>
        </record>
    </data>
</odoo>