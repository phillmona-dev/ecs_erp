<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_ecs_sales" model="ir.module.category">
            <field name="name">ECS Sales</field>
            <field name="sequence">35</field>
        </record>

        <record id="group_sales_manager" model="res.groups">
            <field name="name">Sales Manager</field>
            <field name="category_id" ref="module_category_ecs_sales"/>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        </record>

        <record id="group_sales_user" model="res.groups">
            <field name="name">Sales User</field>
            <field name="category_id" ref="module_category_ecs_sales"/>
            <field name="implied_ids" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <!-- Discount Rule: company isolation -->
        <record id="rule_sales_discount_rule_company" model="ir.rule">
            <field name="name">Sales Discount Rule: Company Isolation</field>
            <field name="model_id" ref="model_ecs_sales_discount_rule"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
