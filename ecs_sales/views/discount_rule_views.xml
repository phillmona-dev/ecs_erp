<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sales_discount_rule_tree" model="ir.ui.view">
        <field name="name">ecs.sales.discount.rule.tree</field>
        <field name="model">ecs.sales.discount.rule</field>
        <field name="arch" type="xml">
            <list string="Discount Rules">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="categ_id"/>
                <field name="payment_term_id"/>
                <field name="discount_percentage" string="Discount (%)"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_sales_discount_rule_form" model="ir.ui.view">
        <field name="name">ecs.sales.discount.rule.form</field>
        <field name="model">ecs.sales.discount.rule</field>
        <field name="arch" type="xml">
            <form string="Discount Rule">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. 10% Wholesale cash discount"/></h1>
                    </div>
                    <group>
                        <group string="Match Criteria">
                            <field name="partner_id" placeholder="All Customers"/>
                            <field name="product_id" placeholder="All Products"/>
                            <field name="categ_id" placeholder="All Categories" invisible="product_id"/>
                            <field name="payment_term_id" placeholder="All Payment Terms"/>
                        </group>
                        <group string="Configuration">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="discount_percentage"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sales_discount_rule_search" model="ir.ui.view">
        <field name="name">ecs.sales.discount.rule.search</field>
        <field name="model">ecs.sales.discount.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="categ_id"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
                <group expand="1" string="Group By">
                    <filter string="Customer" name="by_customer" context="{'group_by':'partner_id'}"/>
                    <filter string="Payment Term" name="by_term" context="{'group_by':'payment_term_id'}"/>
                    <filter string="Company" name="by_company" context="{'group_by':'company_id'}"
                            groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sales_discount_rule" model="ir.actions.act_window">
        <field name="name">Discount Rules</field>
        <field name="res_model">ecs.sales.discount.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sales_discount_rule_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
