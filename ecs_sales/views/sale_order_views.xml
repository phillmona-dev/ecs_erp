<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_ecs_sales" model="ir.ui.view">
        <field name="name">sale.order.form.ecs.sales</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="partner_cust_credit_limit"
                       invisible="not payment_term_id or not partner_id"/>
                <field name="partner_available_amount"
                       invisible="not payment_term_id or not partner_id"/>
            </xpath>
        </field>
    </record>
</odoo>
