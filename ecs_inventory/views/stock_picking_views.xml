<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_ecs_inventory" model="ir.ui.view">
        <field name="name">stock.picking.form.ecs.inventory</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='origin']" position="after">
                <field name="ecs_request_reference"/>
                <field name="ecs_inventory_request_id" readonly="1"/>
                <field name="ecs_transaction_type_id"/>
                <field name="ecs_is_locked_period" readonly="1"/>
                <field name="ecs_locked_period_id" readonly="1" invisible="not ecs_is_locked_period"/>
            </xpath>
        </field>
    </record>
</odoo>
