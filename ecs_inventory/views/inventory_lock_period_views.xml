<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ecs_inventory_lock_period_list" model="ir.ui.view">
        <field name="name">ecs.inventory.lock.period.list</field>
        <field name="model">ecs.inventory.lock.period</field>
        <field name="arch" type="xml">
            <list string="Inventory Lock Periods">
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_ecs_inventory_lock_period_form" model="ir.ui.view">
        <field name="name">ecs.inventory.lock.period.form</field>
        <field name="model">ecs.inventory.lock.period</field>
        <field name="arch" type="xml">
            <form string="Inventory Lock Period">
                <header>
                    <button name="action_lock" string="Lock" type="object" class="btn-primary" invisible="state != 'draft'" groups="ecs_approvals.group_ecs_inventory_manager"/>
                    <button name="action_unlock" string="Unlock" type="object" invisible="state != 'locked'" groups="ecs_approvals.group_ecs_inventory_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,locked"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="excluded_user_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ecs_inventory_lock_period_search" model="ir.ui.view">
        <field name="name">ecs.inventory.lock.period.search</field>
        <field name="model">ecs.inventory.lock.period</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="locked" string="Locked" domain="[('state','=','locked')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ecs_inventory_lock_period" model="ir.actions.act_window">
        <field name="name">Lock Periods</field>
        <field name="res_model">ecs.inventory.lock.period</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ecs_inventory_lock_period_search"/>
    </record>
</odoo>
