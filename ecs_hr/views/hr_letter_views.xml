<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_letter_tree" model="ir.ui.view">
        <field name="name">ecs.hr.letter.tree</field>
        <field name="model">ecs.hr.letter</field>
        <field name="arch" type="xml">
            <list string="HR Letters">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="letter_type"/>
                <field name="addressed_to"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'issued'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_hr_letter_form" model="ir.ui.view">
        <field name="name">ecs.hr.letter.form</field>
        <field name="model">ecs.hr.letter</field>
        <field name="arch" type="xml">
            <form string="HR Letter">
                <header>
                    <button name="action_issue" string="Issue Letter" type="object"
                            class="btn-primary" invisible="state != 'draft'"
                            groups="ecs_approvals.group_ecs_hr_user,ecs_approvals.group_ecs_hr_manager"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,issued"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="employee_id"/>
                            <field name="letter_type"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="addressed_to"/>
                            <field name="issued_by"/>
                        </group>
                    </group>
                    <group string="Purpose / Body Note">
                        <field name="purpose" nolabel="1" placeholder="Additional notes for the letter..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_hr_letter" model="ir.actions.act_window">
        <field name="name">HR Letters</field>
        <field name="res_model">ecs.hr.letter</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
