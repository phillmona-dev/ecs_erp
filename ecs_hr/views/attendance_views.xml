<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Attendance Report List -->
    <record id="view_attendance_report_tree" model="ir.ui.view">
        <field name="name">ecs.hr.attendance.report.tree</field>
        <field name="model">ecs.hr.attendance.report</field>
        <field name="arch" type="xml">
            <list string="Attendance Report"
                  decoration-danger="is_absent == True"
                  decoration-warning="late_minutes &gt; 5">
                <field name="date"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="check_in" widget="datetime"/>
                <field name="check_out" widget="datetime"/>
                <field name="real_hours" string="Real Hrs"/>
                <field name="overtime_hours" string="OT Hrs"/>
                <field name="late_minutes" string="Late (min)"/>
                <field name="is_absent" widget="boolean"/>
                <field name="attendance_from"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_attendance_report_search" model="ir.ui.view">
        <field name="name">ecs.hr.attendance.report.search</field>
        <field name="model">ecs.hr.attendance.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="date"/>
                <field name="department_id"/>
                <filter string="Absent" name="absent" domain="[('is_absent','=',True)]"/>
                <filter string="Late" name="late" domain="[('late_minutes','&gt;',5)]"/>
                <filter string="Today" name="today"
                        domain="[('date','=',context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                    <filter string="Employee" name="by_emp" context="{'group_by':'employee_id'}"/>
                    <filter string="Department" name="by_dept" context="{'group_by':'department_id'}"/>
                    <filter string="Date" name="by_date" context="{'group_by':'date:day'}"/>
            </search>
        </field>
    </record>

    <record id="action_attendance_report" model="ir.actions.act_window">
        <field name="name">Attendance Report</field>
        <field name="res_model">ecs.hr.attendance.report</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_attendance_report_search"/>
        <field name="context">{'search_default_today': 1}</field>
    </record>
</odoo>
