<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_headcount_tree" model="ir.ui.view">
        <field name="name">ecs.hr.headcount.request.tree</field>
        <field name="model">ecs.hr.headcount.request</field>
        <field name="arch" type="xml">
            <list string="Headcount Requests"
                  decoration-info="state == 'submitted'"
                  decoration-success="state == 'approved'">
                <field name="name"/>
                <field name="request_date"/>
                <field name="department_id"/>
                <field name="job_id"/>
                <field name="requested_count"/>
                <field name="employment_type"/>
                <field name="needed_by_date"/>
                <field name="state" widget="badge"
                       decoration-info="state in ('submitted','verified','budget_approved')"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_headcount_form" model="ir.ui.view">
        <field name="name">ecs.hr.headcount.request.form</field>
        <field name="model">ecs.hr.headcount.request</field>
        <field name="arch" type="xml">
            <form string="Headcount Request">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-success"
                            invisible="state not in ('submitted','verified','budget_approved')"
                            groups="ecs_approvals.group_ecs_hr_manager"/>
                    <button name="action_reject" string="Reject" type="object"
                            class="btn-danger"
                            invisible="state not in ('submitted','verified','budget_approved')"
                            groups="ecs_approvals.group_ecs_hr_manager"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('approved','cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Request Details">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="department_id"/>
                            <field name="division_id"/>
                            <field name="job_id"/>
                            <field name="request_date"/>
                            <field name="needed_by_date"/>
                        </group>
                        <group string="Position Details">
                            <field name="requested_count"/>
                            <field name="employment_type"/>
                            <field name="budget_approved"/>
                            <field name="replacement_for"/>
                        </group>
                    </group>
                    <group string="Justification">
                        <field name="reason" nolabel="1"
                               placeholder="Explain why this headcount is needed..."/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_log_ids" readonly="1">
                                <list create="false" delete="false">
                                    <field name="action_date"/>
                                    <field name="action"/>
                                    <field name="user_id"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_headcount_request" model="ir.actions.act_window">
        <field name="name">Headcount Requests</field>
        <field name="res_model">ecs.hr.headcount.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
