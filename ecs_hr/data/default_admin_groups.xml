<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <function model="res.users" name="write">
        <value model="res.users" search="[('id', '=', ref('base.user_admin'))]"/>
        <value eval="{
            'group_ids': [
                (4, ref('hr.group_hr_manager')),
                (4, ref('ecs_approvals.group_ecs_hr_manager')),
                (4, ref('ecs_approvals.group_ecs_payroll_manager')),
            ],
        }"/>
    </function>
</odoo>
