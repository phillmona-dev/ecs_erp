<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_ecs_form" model="ir.ui.view">
        <field name="name">hr.payslip.ecs.form</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="ecs_period_id"/>
                <field name="ecs_days_outside_contract"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_payslip_line_ecs_list" model="ir.ui.view">
        <field name="name">hr.payslip.line.ecs.list</field>
        <field name="model">hr.payslip.line</field>
        <field name="arch" type="xml">
            <list string="Payslip Lines">
                <field name="ecs_period_id"/>
                <field name="badge_id"/>
                <field name="employee_id"/>
                <field name="code"/>
                <field name="name"/>
                <field name="quantity"/>
                <field name="amount"/>
                <field name="total"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_hr_payslip_line_ecs_search" model="ir.ui.view">
        <field name="name">hr.payslip.line.ecs.search</field>
        <field name="model">hr.payslip.line</field>
        <field name="arch" type="xml">
            <search string="Payslip Lines">
                <field name="ecs_period_id"/>
                <field name="badge_id"/>
                <field name="employee_id"/>
                <field name="code"/>
                <field name="name"/>
                <filter string="Period" name="group_by_ecs_period" context="{'group_by':'ecs_period_id'}"/>
                <filter string="Employee" name="group_by_employee" context="{'group_by':'employee_id'}"/>
                <filter string="Company" name="group_by_company" context="{'group_by':'company_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_hr_payslip_line_ecs" model="ir.actions.act_window">
        <field name="name">Payslip Lines</field>
        <field name="res_model">hr.payslip.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_hr_payslip_line_ecs_list"/>
        <field name="search_view_id" ref="view_hr_payslip_line_ecs_search"/>
    </record>
</odoo>
