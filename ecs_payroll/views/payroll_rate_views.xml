<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ecs_payroll_rate_list" model="ir.ui.view">
        <field name="name">ecs.payroll.rate.list</field>
        <field name="model">ecs.payroll.rate</field>
        <field name="arch" type="xml">
            <list string="Payroll Rates" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="rate"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ecs_payroll_rate_search" model="ir.ui.view">
        <field name="name">ecs.payroll.rate.search</field>
        <field name="model">ecs.payroll.rate</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <separator/>
                    <filter name="group_code" string="Code" context="{'group_by': 'code'}"/>
            </search>
        </field>
    </record>

    <record id="action_ecs_payroll_rate" model="ir.actions.act_window">
        <field name="name">Payroll Rates</field>
        <field name="res_model">ecs.payroll.rate</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_ecs_payroll_rate_search"/>
    </record>
</odoo>
