<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ecs_payroll_recurring_input_list" model="ir.ui.view">
        <field name="name">ecs.payroll.recurring.input.list</field>
        <field name="model">ecs.payroll.recurring.input</field>
        <field name="arch" type="xml">
            <list string="Recurring Payroll Inputs">
                <field name="employee_id"/>
                <field name="contract_id"/>
                <field name="input_category"/>
                <field name="input_type_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="amount"/>
                <field name="total_amount"/>
                <field name="paid_amount"/>
                <field name="remaining_amount"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_ecs_payroll_recurring_input_form" model="ir.ui.view">
        <field name="name">ecs.payroll.recurring.input.form</field>
        <field name="model">ecs.payroll.recurring.input</field>
        <field name="arch" type="xml">
            <form string="Recurring Payroll Input">
                <sheet>
                    <group>
                        <group>
                            <field name="contract_id"/>
                            <field name="employee_id" readonly="1"/>
                            <field name="input_category"/>
                            <field name="input_type_id"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="amount"/>
                            <field name="total_amount"/>
                            <field name="paid_amount" readonly="1"/>
                            <field name="remaining_amount" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ecs_payroll_recurring_input" model="ir.actions.act_window">
        <field name="name">Recurring Payments and Deductions</field>
        <field name="res_model">ecs.payroll.recurring.input</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
