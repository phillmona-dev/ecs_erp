<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_payroll_period_company" model="ir.rule">
        <field name="name">Payroll Period: Company Isolation</field>
        <field name="model_id" ref="model_ecs_payroll_period"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

