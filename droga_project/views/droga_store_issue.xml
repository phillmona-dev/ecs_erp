<odoo>
    <record id="droga_project_inventory_consignment_issue_view_form" model="ir.ui.view">
        <field name="name">droga.project.inventory.consignment.issue.view.form</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="inherit_id" ref="droga_inventory.droga_inventory_consignment_issue_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">

                <!-- Project contractor part  -->
                <button name="request_pr" string="Request" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft']) or (menu_from != 'PR')"/>
                <button name="stmg_approve" groups="droga_project.proj_engineer" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['pmg']) or (menu_from != 'PR')"/>
                <button name="amend" groups="droga_project.proj_engineer" string="Amend" type="object" class="oe_highlight btn-warning" data-hotkey="v" invisible="(state not in ['stmg', 'mtmg']) or (menu_from != 'PR')"/>
                <button name="action_cancel" string="Cancel" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft']) or (menu_from != 'PR')"/>

                <field name="state" widget="statusbar" statusbar_visible="draft,pmg,waiting,processed" invisible="(menu_from != 'PR')"/>

            </xpath>
        </field>
    </record>
</odoo>