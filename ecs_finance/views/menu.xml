<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Root ECS Finance Menu ─────────────────────────────────────── -->
    <menuitem id="menu_ecs_finance_root"
              name="Finance"
              sequence="10"
              web_icon="account,static/description/icon.png"
              groups="ecs_approvals.group_ecs_finance_user"/>

    <!-- ── Operations ───────────────────────────────────────────────── -->
    <menuitem id="menu_ecs_finance_operations"
              name="Operations"
              parent="menu_ecs_finance_root"
              sequence="10"/>

    <menuitem id="menu_payment_requests"
              name="Payment Requests"
              parent="menu_ecs_finance_operations"
              action="action_payment_request"
              sequence="10"/>

    <!-- ── Accounting (links to native Odoo accounting menus) ────────── -->
    <menuitem id="menu_ecs_finance_accounting"
              name="Accounting"
              parent="menu_ecs_finance_root"
              sequence="20"/>

    <!-- ── Configuration ────────────────────────────────────────────── -->
    <menuitem id="menu_ecs_finance_config"
              name="Configuration"
              parent="menu_ecs_finance_root"
              sequence="90"
              groups="ecs_approvals.group_ecs_finance_manager"/>

    <menuitem id="menu_withholding_config"
              name="Withholding Tax Configuration"
              parent="menu_ecs_finance_config"
              action="action_withholding_config"
              sequence="10"/>

    <menuitem id="menu_transaction_types"
              name="Transaction Types"
              parent="menu_ecs_finance_config"
              action="action_transaction_type"
              sequence="20"/>
</odoo>
