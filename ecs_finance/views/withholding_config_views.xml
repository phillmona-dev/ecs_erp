<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Withholding Config List ──────────────────────────────────── -->
    <record id="view_withholding_config_tree" model="ir.ui.view">
        <field name="name">ecs.finance.withholding.config.tree</field>
        <field name="model">ecs.finance.withholding.config</field>
        <field name="arch" type="xml">
            <list string="Withholding Configurations">
                <field name="name"/>
                <field name="partner_type"/>
                <field name="rate" string="Rate (%)"/>
                <field name="account_id"/>
                <field name="journal_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ── Withholding Config Form ──────────────────────────────────── -->
    <record id="view_withholding_config_form" model="ir.ui.view">
        <field name="name">ecs.finance.withholding.config.form</field>
        <field name="model">ecs.finance.withholding.config</field>
        <field name="arch" type="xml">
            <form string="Withholding Configuration">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Goods Supplier 2%"/></h1>
                    </div>
                    <group>
                        <group string="Configuration">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="partner_type"/>
                            <field name="rate" string="Rate (%)"/>
                        </group>
                        <group string="Accounting">
                            <field name="account_id"/>
                            <field name="journal_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note" nolabel="1" placeholder="Internal notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_withholding_config" model="ir.actions.act_window">
        <field name="name">Withholding Tax Configuration</field>
        <field name="res_model">ecs.finance.withholding.config</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
    </record>
</odoo>
