<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_payment_request_company" model="ir.rule">
        <field name="name">Payment Request: Company Isolation</field>
        <field name="model_id" ref="model_ecs_finance_payment_request"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_payment_request_self_service_own" model="ir.rule">
        <field name="name">Payment Request: Self Service Own Records</field>
        <field name="model_id" ref="model_ecs_finance_payment_request"/>
        <field name="domain_force">['|', ('create_uid', '=', user.id), ('submitted_by', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('ecs_approvals.group_ecs_self_service'))]"/>
    </record>

    <record id="rule_transaction_type_company" model="ir.rule">
        <field name="name">Transaction Type: Company Isolation</field>
        <field name="model_id" ref="model_ecs_finance_transaction_type"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_withholding_config_company" model="ir.rule">
        <field name="name">Withholding Config: Company Isolation</field>
        <field name="model_id" ref="model_ecs_finance_withholding_config"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_finance_commitment_company" model="ir.rule">
        <field name="name">Finance Commitment: Company Isolation</field>
        <field name="model_id" ref="model_ecs_finance_commitment"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
