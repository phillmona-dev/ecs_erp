<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <!-- inherited for view of purchase.order -->
    <record id="inherit_for_account_move_form" model="ir.ui.view">
        <field name="name">Account Move</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr = "//field[@name='ref']" position = "after">
                <field name="transaction_type" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('transaction_no', '!=', 'New')]}"/>
                <field name="transaction_no" readonly="1"/>
            </xpath>
        </field>
    </record>

    

    <record id="inherit_for_account_move_tree" model="ir.ui.view">
        <field name="name">Account Move</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree" />
        <field name="arch" type="xml">
            <xpath expr = "//field[@name='name']" position = "after">
                <field name="transaction_type" />
                <field name="transaction_no"/>
            </xpath>
        </field>
    </record>

</odoo>
