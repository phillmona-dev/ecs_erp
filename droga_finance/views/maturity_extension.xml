<?xml version="1.0" encoding="utf-8" ?>
<odoo>
<record id="view_invoice_extension_tree" model="ir.ui.view">
    <field name="name">invoice.extension.tree</field>
    <field name="model">invoice.extension</field>
    <field name="arch" type="xml">
        <tree editable="bottom" delete="0">
            <field name="invoice_id"/>
            <field name="extension_days"/>
            <field name="new_due_date"/>
            <field name="state"/>
        </tree>
    </field>
</record>


<record id="action_invoice_extension" model="ir.actions.act_window">
    <field name="name">Invoice Extensions</field>
    <field name="res_model">invoice.extension</field>
    <field name="view_mode">tree</field>
</record>


<menuitem id="menu_invoice_extension" parent="droga_finance.droga_reciveables_report" action="action_invoice_extension" sequence="27" name="Invoice Date Extensions"/>
</odoo>
