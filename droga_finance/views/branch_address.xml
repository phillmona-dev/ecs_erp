<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- tree view -->
    <record id="droga_sales_branch_address_view_tree" model="ir.ui.view">
        <field name="name">Branch Address</field>
        <field name="model">droga.sales.branch.address</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="profit_center"/>
                <field name="sub_city"/>
                <field name="woreda"/>
                <field name="house_no"/>
                <field name="telephone1"/>
                <field name="telephone2"/>
                <field name="fax"/>
            </list>
        </field>
    </record>


      <!-- action -->
    <record id="droga_sales_branch_address_view_action" model="ir.actions.act_window">
        <field name="name">Branch Address</field>
        <field name="res_model">droga.sales.branch.address</field>
        <field name="view_mode">list</field>
    </record>

    <!-- menu -->



</odoo>