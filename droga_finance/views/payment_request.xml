<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- tree view for payment request -->
    <record id="droga_account_payment_request_view_tree" model="ir.ui.view">
        <field name="name">droga.account.payment.request.view.tree</field>
        <field name="model">droga.account.payment.request</field>
        <field name="arch" type="xml">
            <tree string="Payment Request">
                <field name="name" />
                <field name="payment_type" />
                <field name="request_by" />
                <field name="department" />
                <field name="request_date" />
                <field name="purpose" />
                <field name="company_id" />
                <field name="currency_id" />
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- form view for payment request -->
    <record id="droga_account_payment_request_view_form" model="ir.ui.view">
        <field name="name">droga.account.payment.request.view.form</field>
        <field name="model">droga.account.payment.request</field>
        <field name="arch" type="xml">
            <form string="Payment Request" create="0">
                <header>
                    <button name="submit_request" type="object" states="Draft" string="Submit" class="oe_highlight" id="submit_request" data-hotkey="v"/>
                    <button name="approve_request" type="object" states="Submitted" string="Approve" class="oe_highlight" id="approve_request" data-hotkey="v"/>
                    <button name="cancel_request" type="object" states="Submitted" string="Cancel" id="cancel_request" data-hotkey="v"/>

                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <span class="o_form_label">Payment Request</span>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group >
                            <field name="purchase_order_id"  readonly="1"/>
                            <field name="payment_type" readonly="1"/>
                            <field name="request_by" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                            <field name="department" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                            <field name="request_date" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                        </group>
                        <group>
                            <field name="purpose" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                            <field name="company_id" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                            <field name="currency_id" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                        </group>
                        <group string="Pay To">
                            <field name="pay_to" options="{'no_create':True,'no_open':True}" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                            <field name="payment_due_date" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                        </group>
                        <group string="Amount">
                            <field name="total_amount" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                            <field name="exchange_rate" attrs="{'readonly': [('state', 'in', ('Approved', 'Cancelled'))]}"/>
                            <field name="total_amount_etb" readonly="1"/>
                            <field name="amount_in_word" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>

