<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Add Telebirr button to form view -->
        <record id="view_move_form_telebirr" model="ir.ui.view">
            <field name="name">account.move.form.telebirr</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <!-- Add button to button box -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_send_to_telebirr"
                            type="object"
                            string="Send to Telebirr"
                            class="btn-primary"
                            icon="fa-phone"
                            attrs="{'invisible': [ ('telebirr_status', '=', 'success')]}"/>
                </xpath>

                <!-- Add Telebirr fields after invoice date -->
                <xpath expr="//field[@name='invoice_date']" position="after">
<!--                    <group string="Telebirr Information" attrs="{'invisible': [('telebirr_conversation_id', '=', False)]}">-->
                    <field name="mobile_no"></field>
                    <field name="telebirr_conversation_id" attrs="{'invisible': [('telebirr_conversation_id', '=', False)]}" string="Telebirr ID" readonly="1"/>
                    <field name="telebirr_status" attrs="{'invisible': [('telebirr_conversation_id', '=', False)]}"/>
                    <field name="telebirr_transaction_id" readonly="1" attrs="{'invisible': [('telebirr_conversation_id', '=', False)]}"/>
                    <field name="telebirr_response_date" readonly="1" attrs="{'invisible': [('telebirr_conversation_id', '=', False)]}"/>

                </xpath>
            </field>
        </record>

        <!-- Add status field to tree view -->
        <record id="view_move_tree_telebirr" model="ir.ui.view">
            <field name="name">account.move.tree.telebirr</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='amount_total_signed']" position="after">
                    <field name="telebirr_status"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>