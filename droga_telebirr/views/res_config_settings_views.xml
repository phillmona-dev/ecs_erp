<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_res_config_settings_telebirr_form" model="ir.ui.view">
            <field name="name">res.config.settings.telebirr.form.inherit</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='general_settings']" position="inside">
                    <block title="Telebirr USSD Integration" name="telebirr_ussd">
                        <setting id="telebirr_relay_url_setting" string="Relay Service URL" help="URL of the relay service that connects to Telebirr via VPN">
                            <field name="telebirr_relay_url" placeholder="http://localhost:5000"/>
                        </setting>
                        <setting id="telebirr_callback_base_setting" string="Callback Base URL" help="Base URL for callback endpoints used in result_url">
                            <field name="telebirr_callback_base" placeholder="http://localhost:5000"/>
                        </setting>
                        <setting id="telebirr_relay_user_setting" string="Relay Auth User" help="Basic authentication username for the relay service">
                            <field name="telebirr_relay_user" placeholder="username"/>
                        </setting>
                        <setting id="telebirr_relay_password_setting" string="Relay Auth Password" help="Basic authentication password for the relay service">
                            <field name="telebirr_relay_password" password="True" placeholder="password"/>
                        </setting>
                        <setting id="telebirr_notes_setting" string="Configuration Notes">
                            <div class="text-muted">
                                The relay service must be reachable from Odoo and have VPN access to Telebirr.
                            </div>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
