<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id = "CRM_PR_Own_access_only" model = "ir.rule">
        <field name = "name"> CRM PR can only access his/her own plan only </field>
        <field name = "model_id" search="[('model','=','droga.customer.visit.header')]"/>
        <field name = "groups" eval = "[(4, ref ('crm_pr'))]" />
        <field name = "perm_read" eval = "True" />
        <field name = "perm_unlink" eval = "True" />
        <field name = "domain_force"> [('is_record_owner', '=', True)] </field>
    </record>

    <record id = "CRM_PR_create_acess" model = "ir.rule">
        <field name = "name"> Everyone can create its own plan. Not sure why the upper one is not working. </field>
        <field name = "model_id" search="[('model','=','droga.customer.visit.header')]"/>
        <field name = "groups" eval = "[(4, ref ('crm_pr'))]" />
        <field name = "perm_create" eval = "True" />
        <field name = "perm_write" eval = "True" />
        <field name = "domain_force"> [(1, '=', 1)] </field>
    </record>

    <menuitem name="CRM"
            id="crm.crm_menu_root"
            groups="sales_team.group_sale_salesman,sales_team.group_sale_manager,crm_pr"
            sequence="25"/>
    <menuitem
        id="crm.crm_menu_sales"
        name="Sales"
        parent="crm.crm_menu_root"
        groups="crm_sales_rep"
        sequence="1"/>
</odoo>
