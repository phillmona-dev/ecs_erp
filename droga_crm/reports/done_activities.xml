<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="done_activities_tree" model="ir.ui.view">
        <field name="name">droga.crm.done.activity.tree</field>
        <field name="model">droga.crm.done.activity</field>
        <field name="arch" type="xml">
            <tree string="" expand="1" create="0" delete="0">
                <field name="source_name"/>
                <field name="sales_rep"/>
                <field name="pr_team_custom"/>
                <field name="activity_date" string="Plan date"/>
                <field name="check_in" string="Check in"/>
                <field name="check_out" string="Check out"/>
                <field name="res_model_descr" string="Type"/>
                <field name="sales_area" string="Area"/>
                <field name="type" optional="hide"/>
                <field name="state" decoration-success="state == 'Done'" decoration-warning="state=='Pending'" decoration-info="state == 'Open'" decoration-danger="state == 'Cancelled'" widget="badge"/>
                <field name="from_visit_plan"/>
                <field name="act_note" widget="html" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="done_activities_search" model="ir.ui.view">
        <field name="name">droga.crm.done.activity.search</field>
        <field name="model">droga.crm.done.activity</field>
        <field name="arch" type="xml">
            <search string="Done Activities">
                <field name="source_name"/>
                <field name="state"/>
                <field name="sales_area"/>
                <field name="sales_rep" string="User"/>
                <field name="activity_date"/>
                <field name="action_date"/>
                <field name="res_model_descr"/>
                <field name="act_note"/>
                <filter name="open" string="Open activities" domain="[('state', '=', 'Open')]" />
                <filter name="cancel" string="Cancelled activities" domain="[('state', '=', 'Cancelled')]" />
                <filter name="Done" string="Done activities" domain="[('state', '=', 'Done')]" />
                <filter name="group_user" string="User" context="{'group_by':'sales_rep'}"/>
                <filter name="group_team" string="Sales Team" context="{'group_by':'pr_team_custom'}"/>

                <filter string="Today activities"
                        domain="[('activity_date', '&gt;=', context_today().strftime('%Y-%m-%d')), ('activity_date', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d'))]"
                        name="today_sales"></filter>

                <filter string="Current week activities"
                    domain="[
                        ('activity_date', '>=', (datetime.datetime.combine(context_today() + relativedelta(weeks=-1,days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S')),
                        ('activity_date', '&lt;', (datetime.datetime.combine(context_today() + relativedelta(days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S'))]"
                    name="current_week_sales"></filter>

                <filter string="Previous week activities"
                       domain="[('activity_date', '&gt;=', ((context_today()+relativedelta(weeks=-2, days=1, weekday=0)).strftime('%%Y-%%m-%%d'))),
                       ('activity_date', '&lt;=', ((context_today()+relativedelta(weeks=-1, weekday=6)).strftime('%%Y-%%m-%%d')))]"
                        name="previous_week_sales"></filter>

                <filter string="Current month activities"
                        domain="[('activity_date','&lt;',(context_today()+relativedelta(months=1)).strftime('%%Y-%%m-01')),
                        ('activity_date','&gt;=',time.strftime('%%Y-%%m-01'))]"
                        name="current_month_sales"></filter>

                <filter string="Previous month activities"
                        domain="[('activity_date','&gt;=',(context_today()-relativedelta(months=1)).strftime('%%Y-%%m-01')),
                        ('activity_date','&lt;',time.strftime('%%Y-%%m-01'))]"
                name="previous_month_sales"></filter>

                <filter name="unplanned" string="Unplanned Act." domain="[('from_visit_plan', '=', False)]" />
                <filter name="planned" string="Planned Act." domain="[('from_visit_plan', '=', True)]" />

            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="action_done_activity">
        <field name="name">CRM Activities</field>
        <field name="res_model">droga.crm.done.activity</field>
        <field name="view_mode">tree</field>
        <field name="context">{"search_default_today_sales":1,'search_default_group_user': 1}</field>
        <field name="domain">[('res_model', 'in', ('crm.lead','res.partner')),('has_access','=',True)]</field>
    </record>

    <record model="ir.rule" id="activity_per_company">
        <field name="name">Activity multi-company</field>
        <field name="model_id" ref="model_droga_crm_done_activity"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>

    <menuitem
            id="menu_done_activity"
            name="Activities"
            parent="menu_inq_vist_reports"
            sequence="20"
            action="action_done_activity"/>

    <menuitem
            id="menu_done_activity"
            name="Activities"
            parent="crm.crm_menu_root"
            sequence="25"
            action="action_done_activity"/>
</odoo>
