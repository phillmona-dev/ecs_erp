<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_crm_required_vs_planned_tree" model="ir.ui.view">
        <field name="name">droga.crm.grade.vs.schedule.view.tree</field>
        <field name="model">droga.crm.grade.vs.schedule.trans</field>
        <field name="priority">2</field>
        <field name="arch" type="xml">
            <list string="" expand="1" create="0" delete="0">
                <field name="cust_type"/>
                <field name="visit_header_id" invisible="1"/>
                <field name="pr_sales" invisible="1"/>
                <field name="cust_name"/>
                <field name="customer_type"/>
                <field name="grade"/>
                <field name="required_visits"/>
                <field name="planned_visits"/>
                <field name="planned_visits_all"/>
                <field name="required_vs_planned_status" invisible="1"/>
                <field name="diff" invisible="1"/>
                <field name="required_vs_planned" decoration-success="required_vs_planned_status == 'greater'" decoration-muted="required_vs_planned_status == 'equal'" decoration-danger="required_vs_planned_status == 'less_than'" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="droga_crm_required_vs_planned_search" model="ir.ui.view">
        <field name="name">droga.crm.grade.vs.schedule.view.search</field>
        <field name="model">droga.crm.grade.vs.schedule.trans</field>
        <field name="arch" type="xml">
            <search>
                <field name="cust_type"/>
                <field name="cust_name"/>
                <field name="pr_sales"/>
                <field name="customer_type"/>
                <field name="grade"/>
                <field name="required_visits"/>
                <field name="planned_visits"/>
                <field name="planned_visits_all"/>
                <field name="required_vs_planned"/>
                <filter name="group_cust_type" string="Customer type" context="{'group_by':'cust_type'}"/>
                <filter string="To revise plans" domain="[('diff', '&lt;', 0)]" name="to_revise_plans"/>
                <filter string="Contacts only" domain="[('cust_type', '=', 'Contact')]" name="cont_only"/>
                <filter string="Customers only" domain="[('cust_type', '=', 'Customer')]" name="cust_only"/>
            </search>
        </field>
    </record>

    <record id="droga_crm_required_vs_planned" model="ir.actions.act_window">
        <field name="name">Plan vs required visits</field>
        <field name="res_model">droga.crm.grade.vs.schedule.trans</field>
        <field name="view_mode">list,kanban</field>
    </record>

    <record id="droga_crm_grade_vs_schedule_view_view_kanban" model="ir.ui.view">
        <field name="name">droga_crm_grade_vs_schedule_view.view.kanban</field>
        <field name="model">droga.crm.grade.vs.schedule.trans</field>
        <field name="priority">111</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" create="0">
                <field name="cust_type"/>
                <field name="visit_header_id" invisible="1"/>
                <field name="pr_sales"/>
                <field name="cust_name"/>
                <field name="month" invisible="1"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="month_des"/>
                <field name="year"/>
                <field name="customer_type"/>
                <field name="grade"/>
                <field name="required_visits"/>
                <field name="planned_visits"/>
                <field name="planned_visits_all"/>
                <field name="required_vs_planned_status" invisible="1"/>
                <field name="diff" invisible="1"/>
                <field name="required_vs_planned" decoration-success="required_vs_planned_status == 'greater'" decoration-muted="required_vs_planned_status == 'equal'" decoration-danger="required_vs_planned_status == 'less_than'" widget="badge"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <ul>
                                    <li>
                                        <strong class="o_kanban_record_title">
                                            <field name="cust_type"/> :
                                            <field name="cust_name"/>
                                        </strong>
                                    </li>
                                    <li>
                                        Required visits:
                                        <field name="required_visits"/>
                                    </li>
                                    <li>
                                        Planned visits:
                                        <field name="planned_visits"/>
                                    </li>
                                    <li>
                                        Planned visits everyone:
                                        <field name="planned_visits_all"/>
                                    </li>

                                    <li>
                                        Req vs planned:
                                        <field name="required_vs_planned" decoration-success="required_vs_planned_status == 'greater'" decoration-muted="required_vs_planned_status == 'equal'" decoration-danger="required_vs_planned_status == 'less_than'" widget="badge"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>


            </kanban>
        </field>
    </record>

</odoo>