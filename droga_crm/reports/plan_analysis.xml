<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="droga_crm_required_vs_planned_tree" model="ir.ui.view">
        <field name="name">droga.crm.grade.vs.schedule.view.tree</field>
        <field name="model">droga.crm.grade.vs.schedule.view</field>
        <field name="priority">2</field>
        <field name="arch" type="xml">
            <tree string="" expand="1" create="0">
                <field name="cust_type"></field>
                <field name="visit_header_id" invisible="1"></field>
                <field name="userid" invisible="1"></field>
                <field name="cust_name"></field>
                <field name="customer_type"></field>
                <field name="grade"></field>
                <field name="required_visits"></field>
                <field name="planned_visits"></field>
                <field name="required_vs_planned_status" invisible="1"></field>
                <field name="diff" invisible="1"></field>
                <field name="required_vs_planned" decoration-success="required_vs_planned_status == 'greater'" decoration-muted="required_vs_planned_status == 'equal'" decoration-danger="required_vs_planned_status == 'less_than'" widget="badge"></field>
            </tree>
        </field>
    </record>

    <record id="droga_crm_required_vs_planned_tree_with_month" model="ir.ui.view">
        <field name="name">droga.crm.grade.vs.schedule.view.tree.month</field>
        <field name="model">droga.crm.grade.vs.schedule.view</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree string="" expand="1" create="0">
                <field name="cust_type"></field>
                <field name="visit_header_id" invisible="1"></field>
                <field name="userid"></field>
                <field name="cust_name"></field>
                <field name="month" invisible="1"></field>
                <field name="date_from"></field>
                <field name="date_to"></field>
                <field name="month_des"></field>
                <field name="year"></field>
                <field name="customer_type"></field>
                <field name="grade"></field>
                <field name="required_visits"></field>
                <field name="planned_visits"></field>
                <field name="required_vs_planned_status" invisible="1"></field>
                <field name="diff" invisible="1"></field>
                <field name="required_vs_planned" decoration-success="required_vs_planned_status == 'greater'" decoration-muted="required_vs_planned_status == 'equal'" decoration-danger="required_vs_planned_status == 'less_than'" widget="badge"></field>
            </tree>
        </field>
    </record>

    <record id="droga_crm_required_vs_planned_search" model="ir.ui.view">
        <field name="name">droga.crm.grade.vs.schedule.view.search</field>
        <field name="model">droga.crm.grade.vs.schedule.view</field>
        <field name="arch" type="xml">
            <search>
                <field name="cust_type"></field>
                <field name="cust_name"></field>
                <field name="customer_type"></field>
                <field name="grade"></field>
                <field name="required_visits"></field>
                <field name="planned_visits"></field>
                <field name="required_vs_planned"></field>
                <filter name="group_user" string="User" context="{'group_by':'userid'}"/>
                <filter name="group_cust_type" string="Customer type" context="{'group_by':'cust_type'}"/>
                <filter string="To revise plans"
                        domain="[('diff', '&lt;', 0)]"
                        name="to_revise_plans"></filter>
            </search>
        </field>
    </record>

    <record id="droga_crm_required_vs_planned_menu" model="ir.actions.act_window">
        <field name="name">Plan vs required visits</field>
        <field name="res_model">droga.crm.grade.vs.schedule.view</field>
        <field name="view_mode">tree</field>
        <field name="context">{'search_default_group_cust_type':1,'search_default_group_user':1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_crm_required_vs_planned_tree_with_month')})]"/>
    </record>

    <record id="droga_crm_required_vs_planned" model="ir.actions.act_window">
        <field name="name">Plan vs required visits</field>
        <field name="res_model">droga.crm.grade.vs.schedule.view</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem
            id="droga_crm_monthly_plans_crm_menu"
            name="Monthly plans"
            action="droga_crm_required_vs_planned_menu"
            parent="menu_inq_vist_reports"
            groups="crm_user"
            sequence="10"/>
</odoo>
