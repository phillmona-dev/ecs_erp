<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_eod_report_wizard_form" model="ir.ui.view">
    <field name="name">droga.crm.eod.wizard.form</field>
    <field name="model">droga.crm.eod.wizard</field>
    <field name="arch" type="xml">
      <form string="End of day Report Wizard">
        <sheet>
            <group>
                  <group>
                      <field name="employee_id" options="{'no_create':True,'no_open':True}" readonly="1"/>
                      <field name="employee_id" groups="droga_crm.crm_emp_administrator" options="{'no_create':True,'no_open':True}"></field>
                  </group>
                  <group>
                      <field name="date_to"/>
                      <field name="all_emps" groups="droga_crm.crm_emp_administrator"></field>
                      <field name="fileout" filename="filename" readonly="1" widget="binary" invisible="1"/>
                  </group>
            </group>
          <footer>
            <button string="Generate Report" type="object" name="action_generate_report" class="btn-primary"/>
            <button string="Close" class="btn-secondary" special="cancel"/>
          </footer>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_eod_report_wizard" model="ir.actions.act_window">
        <field name="name">Generate EOD Report</field>
        <field name="res_model">droga.crm.eod.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

  <menuitem
        id="report_wizard"
        name="End of day Report"
        parent="droga_crm.menu_visit_reports"
        groups="crm_mr"
        sequence="90"/>
    <menuitem
        id="menu_eod_report_wizard"
        name="End of day Report"
        parent="droga_crm.menu_visit_reports"
        action="action_eod_report_wizard"
        groups="crm_mr"
        sequence="100"/>
</odoo>