<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="droga_crm_doctors_schedule_model_action" model="ir.actions.act_window">
        <field name="name">Doctors schedule</field>
        <field name="res_model">droga.cust.contact.working.hours</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_cust_name': 1}</field>
    </record>

    <record id="droga_crm_doctors_schedule_view_tree" model="ir.ui.view">
        <field name="name">droga.cust.contact.working.hours.tree</field>
        <field name="model">droga.cust.contact.working.hours</field>
        <field name="arch" type="xml">
            <tree string="" expand="1" create="0">
                <!--->
                <field name="cust_name"></field>
                <field name="cust_area"></field>
                <-->
                <field name="customer_name"></field>
                <field name="contact_title"></field>
                <field name="contact_name"></field>
                <field name="day"></field>
                <field name="time_from"></field>
                <field name="time_to"></field>
            </tree>
        </field>
    </record>

    <record id="droga_crm_doctors_schedule_view_search" model="ir.ui.view">
        <field name="name">droga.cust.contact.working.hours.search</field>
        <field name="model">droga.cust.contact.working.hours</field>
        <field name="arch" type="xml">
            <search>
                <field name="customer_name"></field>
                <field name="contact_title"></field>
                <field name="contact_name"></field>
                <field name="day"></field>
                <field name="time_from"></field>
                <field name="time_to"></field>
                <filter name="group_cust_name" string="Cust name" context="{'group_by':'customer_name'}"/>
            </search>
        </field>
    </record>

    <menuitem
        id="droga_crm_contacts_model_schedule_area"
        name="Doctors schedule"
        action="droga_crm_doctors_schedule_model_action"
        parent="menu_vist_log"
        sequence="20"/>

</odoo>