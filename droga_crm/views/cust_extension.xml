<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="droga_cust_contact_extension" model="ir.ui.view">
        <field name="name">customer</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>

        <field name="arch" type="xml">
            <xpath expr="//form/sheet/notebook/page[@name='contact_addresses']" position="replace">
                <page string="Contacts">
                    <field name="contacts" mode="tree,kanban">
                        <tree editable="1" create="1">
                            <field name="specialty" domain="([('status','=','Active')])" options="{'no_create':True,'no_open':True}"/>
                            <field name="contact_name"/>
                            <field name="job_position"/>
                            <field name="gender"/>
                            <field name="mobile"/>
                            <field name="contact_tobe_accessed_by" options="{'no_create':True,'no_open':True}"/>
                            <field name="cont_grade" options="{'no_create':True,'no_open':True}" domain="([('status','=','Active'),('cont_include','=',True)])"/>
                            <field name="days" widget="many2many_tags"/>
                        </tree>
                        <form >
                            <group>
                            <field name="specialty" domain="([('status','=','Active')])" options="{'no_create':True,'no_open':True}"/>
                            <field name="contact_name"/>
                            <field name="job_position"/>
                            <field name="gender"/>
                            <field name="mobile"/>
                            <field name="contact_tobe_accessed_by" options="{'no_create':True,'no_open':True}"/>
                            <field name="cont_grade" options="{'no_create':True,'no_open':True}" domain="([('status','=','Active'),('cont_include','=',True)])"/>
                            <field name="days" widget="many2many_tags"/>
                            </group>
                        </form>
                        <kanban class="o_kanban_mobile">
                            <field name="specialty" domain="([('status','=','Active')])" options="{'no_create':True,'no_open':True}"/>
                            <field name="contact_name"/>
                            <field name="job_position"/>
                            <field name="gender"/>
                            <field name="mobile"/>
                            <field name="contact_tobe_accessed_by" options="{'no_create':True,'no_open':True}"/>
                            <field name="cont_grade" options="{'no_create':True,'no_open':True}" domain="([('status','=','Active'),('cont_include','=',True)])"/>
                            <field name="days" widget="many2many_tags"/>
                            <templates>
                                    <t t-name="kanban-box">
                                        <div t-attf-class="oe_kanban_global_click" on_create="quick_create">
                                            <div class="oe_kanban_details">
                                                <ul>
                                                    <li>
                                                        <field name="contact_name"></field>
                                                    </li>
                                                    <li>
                                                        Specialty:<field name="specialty"></field>
                                                        <span> </span>-<span> </span>
                                                        Job Position: <field name="job_position"></field>
                                                    </li>
                                                    <li>
                                                        Gender:<field name="gender"></field>
                                                        <span> </span>-<span> </span>
                                                        Mobile:<field name="mobile"></field>
                                                    </li>




                                                </ul>

                                            </div>
                                        </div>
                                    </t>
                        </templates>

                        </kanban>
                    </field>
                </page>
            </xpath>

            <xpath expr="//form/sheet/group/group" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <xpath expr="//form/sheet/group/group/field[@name='function']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <xpath expr="//form/sheet/group/group/field[@name='category_id']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <xpath expr="//form/sheet/group/group" position="after">
                <group>

                    <field name="cust_grade" options="{'no_create':True,'no_open':True}"
                           string="Customer grade" domain="([('status','=','Active')])"></field>
                    <field name="cust_type_ext" domain="([('status','=','Active')])" attrs="{'required': True}" options="{'no_create':True,'no_open':True}"
                           string="Customer type"></field>
                    <field name="pr_avail_areas" invisible="1"></field>
                    <field name="pr_sales_logged" invisible="1"></field>
                    <field name="city_name" required="True" domain="([('id', 'in',pr_avail_areas),('status','=','Active')])" options="{'no_create':True,'no_open':True}"
                           string="City/sub-city team"></field>
                    <field name="area" options="{'no_create':True,'no_open':True}" string="Area"
                           domain="([('parent_id','=',city_name),('status','=','Active')])"></field>
                    <field name="location"></field>

                </group>

            </xpath>
            <xpath expr="//form/sheet/group/group/field[@name='website']" position="replace">
                <field name="vat" string="Tin No"></field>
            </xpath>
        </field>
    </record>


    <record id="droga_crm_teams_extension" model="ir.ui.view">
        <field name="name">CRM teams</field>
        <field name="model">crm.team</field>
        <field name="inherit_id" ref="sales_team.crm_team_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group/group/field[@name='active']" position="after">
                <field name="city_name" domain="([('status','=','Active')])"></field>
            </xpath>

        </field>
    </record>
</odoo>