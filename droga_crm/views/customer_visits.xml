<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_crm_customer_visit_view_tree" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.tree</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <list string="" create="1" delete="0">
                <field name="pr_sales" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"/>
                <field name="pr_sales_logged" invisible="1"/>
                <field name="is_record_owner" invisible="1"/>
                <field name="id" invisible="1"/>

                <field name="weeks" invisible="1" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"/>
                <field name="visit_header"/>

                <field name="deadline_in_secs" decoration-muted="1 == 1" widget="counter"/>
                <field name="pr_avail_areas" invisible="1"/>
                <field name="state" decoration-success="state == 'approved'" decoration-warning="state=='requested'" decoration-info="state == 'draft'" widget="badge"/>
                <field name="approver" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}" readonly="True" required="True"/>
                <field name="is_record_owner" invisible="True"/>
                <field name="is_approver" invisible="True"/>
            </list>
        </field>
    </record>

    <record id="droga_crm_customer_visit_view_search" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.search</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <search>
                <field name="visit_header"/>
                <field name="state"/>
                <field name="pr_sales"/>
                <field name="weeks"/>

                <filter name="upcoming" string="Current and upcoming" domain="[('visit_header', 'like', '%Plan%')]"/>

            </search>
        </field>
    </record>

    <record id="droga_crm_customer_visit_view_kanban" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.kanban</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" on_create="quick_create">
                <field name="pr_sales"/>
                <field name="pr_sales_logged"/>
                <field name="is_record_owner"/>
                <field name="id" invisible="1"/>
                <field name="weeks"/>
                <field name="pr_avail_areas"/>
                <field name="city_name"/>
                <field name="state"/>
                <field name="approver"/>
                <field name="is_record_owner"/>
                <field name="is_approver"/>
                <field name="is_readonly"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <field name="is_readonly" invisible="1"/>
                                <ul readonly="(is_readonly == True)">
                                    <li>
                                        <field name="descr"/>
                                    </li>
                                    <li>
                                        <b>Status: </b>
                                        <field name="state" decoration-success="state == 'approved'" decoration-warning="state=='requested'" decoration-info="state == 'draft'" widget="badge"/>
                                    </li>
                                    <li>
                                        <b>Deadline: </b>
                                        <field name="deadline_in_secs" decoration-muted="1 == 1" widget="counter"/>
                                    </li>

                                    <li>
                                        <strong>Approver: </strong>
                                        <field name="approver" options="{&quot;no_open&quot;: True, &quot;no_create&quot;: True}"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="droga_crm_customer_visit_header_view_form_popup" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.form_popup</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <field name="is_approver" invisible="1"/>
                    <field name="is_record_owner" invisible="1"/>
                    <field name="state" invisible="1"/>

                    <div class="oe_button_box" name="button_box">
                        <button type="object" icon="fa-mail-forward" name="request_approval" invisible="(is_record_owner == False) or (state != 'draft')">Request
                                                </button>
                        <button icon="fa-mail-reply" type="object" string=" Revise" name="revise" class="oe_stat_button" invisible="(is_approver == False) or (state != 'requested')"/>

                        <button icon="fa-thumbs-up" type="object" string=" Approve" name="approve" class="oe_stat_button" invisible="(is_approver == False) or (state != 'requested')"/>
                    </div>
                    <field name="is_readonly" invisible="1"/>
                    <group readonly="(is_readonly == True)">
                        <field name="is_readonly" invisible="1"/>
                        <group>
                            <field name="weeks" invisible="1" options="{'no_create':True,'no_open':True}"/>
                            <field name="visit_header" string="Week Description" readonly="True"/>
                            <field name="deadline_in_secs" decoration-muted="1 == 1" widget="counter"/>
                        </group>
                        <group>
                            <field name="approver" readonly="1" options="{'no_create':True,'no_open':True}" required="True"/>
                            <field name="state" decoration-success="state == 'approved'" decoration-warning="state=='requested'" decoration-info="state == 'draft'" widget="badge"/>
                        </group>
                    </group>
                <hr/>
                    <br/>
                    <notebook>
                        <field name="is_readonly" invisible="1"/>
                        <page string="Weekly schedule" readonly="(is_readonly == True)">

                            <field name="weeks_detail" mode="tree,kanban">
                                <list delete="0" editable="bottom" create="0" expand="1">
                                    <field name="is_readonly" invisible="1"/>
                                    <field name="partner_custom" required="True" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    <field name="visit_client" invisible="1" options="{'no_create':True,'no_open':True}" required="True" readonly="(is_readonly == True)"/>
                                    <field name="cont_plan_des" readonly="(is_readonly == True)"/>
                                    <button icon="fa-credit-card-alt" type="object" string=" Contact plan" name="visit_contact_open" class="oe_stat_button"/>

                                    <field name="city_name" invisible="1"/>

                                    <field name="visit_date_descr"/>
                                    <button icon="fa-credit-card-alt" type="object" string=" Duplicate" name="add_visit" class="oe_stat_button"/>
                                    <field name="planned_visit_selection" readonly="(is_readonly == True)"/>
                                    <field name="remark" string="Comment" readonly="(is_readonly == True)"/>
                                </list>
                                <form string="Weekly plan">
                                    <group>
                                        <field name="is_readonly" invisible="1"/>
                                        <field name="partner_custom" required="True" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                        <field name="visit_client" options="{'no_create':True,'no_open':True}" invisible="1" required="True" domain="[('is_company', '=',True),('is_cust_available','=',True),('company_id','=',allowed_company_ids[0])]" readonly="(is_readonly == True)"/>
                                        <field name="visit_date_descr" readonly="(is_readonly == True)"/>
                                        <field name="planned_visit_selection" readonly="(is_readonly == True)"/>
                                        <field name="remark" string="Comment" readonly="(is_readonly == True)"/>

                                        <field name="contacts_schedule" mode="tree,kanban">
                                <list editable="bottom" delete="0">
                                    <field name="is_readonly" invisible="1"/>
                                    <field name="cust" options="{'no_create':True,'no_open':True}" readonly="True"/>
                                    <field name="contact_custom2" domain="([('parent_customer','=',cust),('x_has_access','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    <field name="co_travel_crm" widget="many2many_tags" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>

                                    <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="is_readonly" invisible="1"/>
                                        <field name="cust" options="{'no_create':True,'no_open':True}" readonly="True"/>
                                        <field name="contact_custom2" domain="([('parent_customer','=',cust),('x_has_access','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                        <field name="co_travel_crm" widget="many2many_tags" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>

                                        <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    </group>
                                </form>
                                <kanban create="1">
                                    <field name="is_readonly" invisible="1"/>
                                    <field name="cust" readonly="(is_readonly == True)"/>
                                    <field name="cont_plan_des" readonly="(is_readonly == True)"/>
                                    <field name="contact_custom2" domain="([('parent_customer','=',cust),('x_has_access','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    <field name="co_travel_crm" widget="many2many_tags" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>

                                    <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    <templates>
                                        <t t-name="kanban-box" on_create="quick_create">&gt;
                                            <div t-attf-class="oe_kanban_global_click">
                                                <div class="oe_kanban_details">
                                                    <ul>
                                                        <field name="is_readonly" invisible="1"/>
                                                        <li>
                                                            <strong class="o_kanban_record_title">Contact:
                                                                <field name="contact_custom2" readonly="(is_readonly == True)"/>
                                                            </strong>
                                                            <field name="cont_plan_des" readonly="(is_readonly == True)"/>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>

                                    </group>
                                </form>visit_date
                                <kanban class="o_kanban_mobile" limit="500" create="false">
                                    <field name="partner_custom" required="True" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    <field name="visit_client" invisible="1" options="{'no_create':True,'no_open':True}" required="True" domain="[('is_company', '=',True),('is_cust_available','=',True),('company_id','=',allowed_company_ids[0])]"/>
                                    <field name="cont_plan_des"/>

                                    <field name="city_name" invisible="1"/>
                                    <field name="is_readonly" invisible="1"/>

                                    <field name="visit_date_descr"/>
                                    <field name="remark" string="Comment" readonly="(is_readonly == True)"/>
                                    <field name="planned_visit_selection"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div t-attf-class="oe_kanban_global_click">
                                                <div class="oe_kanban_details">
                                                    <field name="is_readonly" invisible="1"/>
                                                    <ul>
                                                        <li>
                                                            <strong class="o_kanban_record_title">Customer:
                                                                <field name="visit_client" options="{'no_create':True,'no_open':True}" domain="[('is_company', '=',True),('is_cust_available','=',True),('company_id','=',allowed_company_ids[0])]" readonly="(is_readonly == True)"/>
                                                            </strong>
                                                        </li>
                                                        <li>
                                                            Visit Date:
                                                            <field name="visit_date_descr" readonly="(is_readonly == True)"/>
                                                            <span> </span>
                                                            <field name="planned_visit_selection" readonly="(is_readonly == True)"/>
                                                        </li>
                                                        <li>
                                                            Comment:
                                                            <field name="remark" readonly="(is_readonly == True)"/>
                                                        </li>
                                                        <li>
                                                            <field name="cont_plan_des" readonly="(is_readonly == True)"/>
                                                        </li>
                                                        <button icon="fa-credit-card-alt" type="object" string=" Duplicate" name="add_visit" class="oe_stat_button"/>
                                                    </ul>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>


                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_crm_customer_visit_detail_view_form_popup" model="ir.ui.view">
        <field name="name">droga.customer.visit.detail.view.form_popup</field>
        <field name="model">droga.customer.visit.detail</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <notebook>
                        <page string="Contacts schedule">
                            <field name="contacts_schedule" mode="tree,kanban">
                                <list editable="bottom" delete="0">
                                    <field name="is_readonly" invisible="1"/>
                                    <field name="cust" required="True" options="{'no_create':True,'no_open':True}" readonly="True"/>
                                    <field name="contact_custom2" required="True" domain="([('parent_customer','=',cust),('x_has_access','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    <field name="co_travel_crm" widget="many2many_tags" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>

                                    <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="is_readonly" invisible="1"/>
                                        <field name="cust" options="{'no_create':True,'no_open':True}" readonly="True"/>
                                        <field name="contact_custom2" domain="([('parent_customer','=',cust),('x_has_access','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                        <field name="co_travel_crm" widget="many2many_tags" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>

                                        <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    </group>
                                </form>
                                <kanban on_create="quick_create">
                                    <field name="is_readonly" invisible="1"/>
                                    <field name="cust" options="{'no_create':True,'no_open':True}" readonly="True"/>
                                    <field name="cont_plan_des" readonly="(is_readonly == True)"/>
                                    <field name="contact_custom2" domain="([('parent_customer','=',cust),('x_has_access','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    <field name="co_travel_crm" widget="many2many_tags" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>

                                    <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])" options="{'no_create':True,'no_open':True}" readonly="(is_readonly == True)"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div t-attf-class="oe_kanban_global_click" on_create="quick_create">
                                                <div class="oe_kanban_details">
                                                    <ul>
                                                        <field name="is_readonly" invisible="1"/>
                                                        <li>
                                                            <strong class="o_kanban_record_title">Contact:
                                                                <field name="contact_custom2" readonly="(is_readonly == True)"/>
                                                            </strong>
                                                            <field name="cont_plan_des" readonly="(is_readonly == True)"/>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_crm_customer_visit_action" model="ir.actions.act_window">
        <field name="name">Customers visit log book</field>
        <field name="res_model">droga.customer.visit.header</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),                 (0, 0, {'view_mode': 'list', 'view_id': ref('droga_crm_customer_visit_view_tree')}),                 (0, 0, {'view_mode': 'kanban', 'view_id': ref('droga_crm_customer_visit_view_kanban')}),                 (0, 0, {'view_mode': 'form', 'view_id': ref('droga_crm_customer_visit_header_view_form_popup')})]"/>
        <field name="search_view_id" ref="droga_crm_customer_visit_view_search"/>
        <field name="context">{"search_default_upcoming":1}</field>
        <field name="domain">['|',('pr_sales.employee_access_users','=',uid),('approver.employee_access_users','=',uid)]</field>
    </record>

    <menuitem id="menu_vist_log" name="Weekly Plan" parent="crm.crm_menu_root" groups="crm_mr" action="droga_crm_customer_visit_action" active="True" sequence="24"/>

</odoo>
