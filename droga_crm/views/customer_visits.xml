<?xml version="1.0" encoding="utf-8"?>


<odoo>
    <record id="droga_crm_customer_visit_view_tree" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.tree</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <tree string="" create="1" delete="0">
                <field name="pr_sales" options='{"no_open": True, "no_create": True}'></field>
                <field name="pr_sales_logged" invisible="1"></field>
                <field name="is_record_owner" invisible="1"/>
                <field name="id" invisible="1"/>

                <field name="weeks" invisible="1" options='{"no_open": True, "no_create": True}'></field>
                <field name="visit_header"></field>

                <field name="deadline_in_secs" decoration-muted="1 == 1" widget="counter"></field>
                <field name="pr_avail_areas" invisible="1"/>
                <field name="state" decoration-success="state == 'approved'" decoration-warning="state=='requested'" decoration-info="state == 'draft'" widget="badge" ></field>
                <field name="approver" options='{"no_open": True, "no_create": True}' readonly="True" required="True"></field>
                <field name="is_record_owner" invisible="True"></field>
                <field name="is_approver" invisible="True"></field>
            </tree>
        </field>
    </record>

    <record id="droga_crm_customer_visit_view_search" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.search</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <search>
                <field name="visit_header"></field>
                <field name="state"></field>
                <field name="pr_sales"></field>
                <field name="weeks"></field>

                <filter name="upcoming" string="Current and upcoming" domain="[('visit_header', 'like', '%Plan%')]" />

            </search>
        </field>
    </record>

    <record id="droga_crm_customer_visit_view_kanban" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.kanban</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" on_create="quick_create" >
                <field name="pr_sales"></field>
                <field name="pr_sales_logged"></field>
                <field name="is_record_owner"/>
                <field name="id" invisible="1"/>
                <field name="weeks"></field>
                <field name="pr_avail_areas"/>
                <field name="city_name"></field>
                <field name="state"></field>
                <field name="approver"></field>
                <field name="is_record_owner"></field>
                <field name="is_approver"></field>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <ul>
                                    <li>
                                        <field name="descr"></field>
                                    </li>
                                    <li>
                                        <b>Status: </b>
                                        <field name="state" decoration-success="state == 'approved'" decoration-warning="state=='requested'" decoration-info="state == 'draft'" widget="badge" ></field>
                                    </li>
                                    <li>
                                        <b>Deadline: </b>
                                        <field name="deadline_in_secs" decoration-muted="1 == 1" widget="counter"></field>
                                    </li>

                                    <li>
                                        <strong>Approver: </strong>
                                        <field name="approver" options='{"no_open": True, "no_create": True}'></field>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="droga_crm_customer_visit_header_view_form_popup" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.form_popup</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <field name="is_approver" invisible="1"></field>
                    <field name="is_record_owner" invisible="1"></field>
                    <field name="state" invisible="1"></field>

                    <div class="oe_button_box" name="button_box">
                        <button type="object" icon="fa-mail-forward"
                                                        attrs="{'invisible': ['|',('is_record_owner','=',False),('state', '!=', ('draft'))]}"
                                                        name="request_approval">Request
                                                </button>
                        <button icon="fa-mail-reply"
                        attrs="{'invisible': ['|',('is_approver','=',False),('state', '!=', ('requested'))]}"
                        type="object" string=" Revise"
                        name="revise" class="oe_stat_button"/>

                        <button icon="fa-thumbs-up"
                        attrs="{'invisible': ['|',('is_approver','=',False),('state', '!=', ('requested'))]}"
                        type="object" string=" Approve"
                        name="approve" class="oe_stat_button"/>
                    </div>
                    <group>
                        <group>
                            <field name="weeks" invisible="1" options="{'no_create':True,'no_open':True}"></field>
                            <field name="visit_header" string="Week Description" readonly="True"></field>
                            <field name="deadline_in_secs" decoration-muted="1 == 1" widget="counter"></field>
                        </group>
                        <group>
                            <field name="approver" readonly="1" options="{'no_create':True,'no_open':True}" required="True"></field>
                            <field name="state" decoration-success="state == 'approved'" decoration-warning="state=='requested'" decoration-info="state == 'draft'" widget="badge" ></field>
                        </group>
                    </group>
                <hr></hr>
                    <br></br>
                    <notebook>
                        <page string="Weekly schedule">

                            <field name="weeks_detail" mode="tree,kanban">
                                <tree delete="1" editable="true" create="0" expand="1">
                                    <field name="partner_custom" required="True" options="{'no_create':True,'no_open':True}"></field>
                                    <field name="visit_client" invisible="1" options="{'no_create':True,'no_open':True}" required="True"></field>
                                    <field name="cont_plan_des"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Contact plan"
                                            name="visit_contact_open" class="oe_stat_button"/>

                                    <field name="city_name" invisible="1"></field>

                                    <field name="visit_date_descr"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Duplicate"
                                            name="add_visit" class="oe_stat_button"/>
                                    <field name="planned_visit_selection"></field>
                                    <field name="remark" string='Comment'></field>
                                </tree>
                                <form string="Weekly plan">
                                    <group>
                                        <field name="partner_custom" required="True" options="{'no_create':True,'no_open':True}"></field>
                                        <field name="visit_client" options="{'no_create':True,'no_open':True}" invisible="1" required="True"
                                           domain="[('is_company', '=',True),('is_cust_available','=',True),('company_id','=',allowed_company_ids[0])]"></field>
                                        <field name="visit_date_descr"></field>
                                        <field name="planned_visit_selection"></field>
                                        <field name="remark" string='Comment'></field>

                                        <field name="contacts_schedule" mode="tree,kanban">
                                <tree editable="bottom" delete="0">
                                    <field name="cust"/>
                                    <field name="contact_custom" widget="many2many_tags" domain="([('parent_customer','=',cust),('has_access','=',True)])"
                                           options="{'no_create':True,'no_open':True}"></field>
                                    <field name="co_travel_crm" widget="many2many_tags"
                                           options="{'no_create':True,'no_open':True}"/>

                                    <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])"
                                           options="{'no_create':True,'no_open':True}"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="cust"/>
                                        <field name="contact_custom" widget="many2many_tags" domain="([('parent_customer','=',cust),('has_access','=',True)])"
                                               options="{'no_create':True,'no_open':True}"></field>
                                        <field name="co_travel_crm" widget="many2many_tags"
                                               options="{'no_create':True,'no_open':True}"/>

                                        <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])"
                                               options="{'no_create':True,'no_open':True}"/>
                                    </group>
                                </form>
                                <kanban create="1">
                                    <field name="cust"/>
                                    <field name="cont_plan_des"></field>
                                    <field name="contact_custom" widget="many2many_tags" domain="([('parent_customer','=',cust),('has_access','=',True)])"
                                           options="{'no_create':True,'no_open':True}"></field>
                                    <field name="co_travel_crm" widget="many2many_tags"
                                           options="{'no_create':True,'no_open':True}"/>

                                    <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])"
                                           options="{'no_create':True,'no_open':True}"/>
                                    <templates>
                                        <t t-name="kanban-box" on_create="quick_create">>
                                            <div t-attf-class="oe_kanban_global_click" >
                                                <div class="oe_kanban_details">
                                                    <ul>
                                                        <li>
                                                            <strong class="o_kanban_record_title">Contact:
                                                                <field name="contact_custom" widget="many2many_tags"></field>
                                                            </strong>
                                                            <field name="cont_plan_des"></field>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>

                                    </group>
                                </form>visit_date
                                <kanban class="o_kanban_mobile" limit="500" create="false">
                                    <field name="partner_custom" required="True" options="{'no_create':True,'no_open':True}"></field>
                                    <field name="visit_client" invisible="1" options="{'no_create':True,'no_open':True}" required="True"
                                           domain="[('is_company', '=',True),('is_cust_available','=',True),('company_id','=',allowed_company_ids[0])]"></field>
                                    <field name="cont_plan_des"></field>

                                    <field name="city_name" invisible="1"></field>


                                    <field name="visit_date_descr"></field>
                                    <field name="remark" string='Comment'></field>
                                    <field name="planned_visit_selection"></field>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div t-attf-class="oe_kanban_global_click" >
                                                <div class="oe_kanban_details">
                                                    <ul>
                                                        <li>
                                                            <strong class="o_kanban_record_title">Customer:
                                                                <field name="visit_client" options="{'no_create':True,'no_open':True}"
                                           domain="[('is_company', '=',True),('is_cust_available','=',True),('company_id','=',allowed_company_ids[0])]"></field>
                                                            </strong>
                                                        </li>
                                                        <li>
                                                            Visit Date:
                                                            <field name="visit_date_descr"></field>
                                                            <span> </span>
                                                            <field name="planned_visit_selection"></field>
                                                        </li>
                                                        <li>
                                                            Comment:
                                                            <field name="remark"></field>
                                                        </li>
                                                        <li>
                                                            <field name="cont_plan_des"></field>
                                                        </li>
                                                        <button icon="fa-credit-card-alt"
                                                            type="object" string=" Duplicate"
                                                            name="add_visit" class="oe_stat_button"/>
                                                    </ul>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>


                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_crm_customer_visit_detail_view_form_popup" model="ir.ui.view">
        <field name="name">droga.customer.visit.detail.view.form_popup</field>
        <field name="model">droga.customer.visit.detail</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <notebook>
                        <page string="Contacts schedule">
                            <field name="contacts_schedule" mode="tree,kanban">
                                <tree editable="bottom" delete="0">
                                    <field name="cust"/>
                                    <field name="contact_custom" widget="many2many_tags" domain="([('parent_customer','=',cust),('has_access','=',True)])"
                                           options="{'no_create':True,'no_open':True}"></field>
                                    <field name="co_travel_crm" widget="many2many_tags"
                                           options="{'no_create':True,'no_open':True}"/>

                                    <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])"
                                           options="{'no_create':True,'no_open':True}"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="cust"/>
                                        <field name="contact_custom" widget="many2many_tags" domain="([('parent_customer','=',cust),('has_access','=',True)])"
                                               options="{'no_create':True,'no_open':True}"></field>
                                        <field name="co_travel_crm" widget="many2many_tags"
                                               options="{'no_create':True,'no_open':True}"/>

                                        <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])"
                                               options="{'no_create':True,'no_open':True}"/>
                                    </group>
                                </form>
                                <kanban  on_create="quick_create">
                                    <field name="cust"/>
                                    <field name="cont_plan_des"></field>
                                    <field name="contact_custom" widget="many2many_tags" domain="([('parent_customer','=',cust),('has_access','=',True)])"
                                           options="{'no_create':True,'no_open':True}"></field>
                                    <field name="co_travel_crm" widget="many2many_tags"
                                           options="{'no_create':True,'no_open':True}"/>

                                    <field name="core_products" widget="many2many_tags" domain="([('is_prod_available','=',True)])"
                                           options="{'no_create':True,'no_open':True}"/>
                                    <templates>
                                        <t t-name="kanban-box" >
                                            <div t-attf-class="oe_kanban_global_click" on_create="quick_create">
                                                <div class="oe_kanban_details">
                                                    <ul>
                                                        <li>
                                                            <strong class="o_kanban_record_title">Contact:
                                                                <field name="contact_custom" widget="many2many_tags"></field>
                                                            </strong>
                                                            <field name="cont_plan_des"></field>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_crm_customer_visit_action" model="ir.actions.act_window">
        <field name="name">Customers visit log book</field>
        <field name="res_model">droga.customer.visit.header</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_crm_customer_visit_view_tree')}),
                (0, 0, {'view_mode': 'kanban', 'view_id': ref('droga_crm_customer_visit_view_kanban')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('droga_crm_customer_visit_header_view_form_popup')})]"/>
        <field name="search_view_id" ref="droga_crm_customer_visit_view_search"></field>
        <field name="context">{"search_default_upcoming":1}</field>
        <field name="domain">[('is_record_owner','=',True)]</field>
    </record>

    <menuitem
            id="menu_vist_log"
            name="Weekly Plan"
            parent="crm.crm_menu_root"
            groups="crm_mr"
            action="droga_crm_customer_visit_action"
            active="True"
            sequence="24"/>

</odoo>
