<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="droga_crm_customer_visit_action" model="ir.actions.act_window">
        <field name="name">Customers visit log book</field>
        <field name="res_model">droga.customer.visit.header</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="droga_crm_customer_visit_view_tree" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.tree</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <tree string="" editable="top" >
                <field name="pr_sales"></field>
                <field name="pr_sales_logged" invisible="False"></field>
                <field name="is_record_owner" invisible="False"/>
                <field name="month"></field>
                <field name="year"></field>
                <field name="city_name" options="{'no_create':True,'no_open':True}"></field>
                <field name="state"></field>

                <button icon="fa-credit-card-alt"
                        attrs="{'invisible': [('state', 'not in', ('draft','requested','approved'))]}"
                        type="object" string=" Visit detail"
                        name="visit_detail_open" class="oe_stat_button"/>
                <button icon="fa-credit-card-alt"
                        attrs="{'invisible': [('state', '!=', ('draft'))]}"
                        type="object" string=" Request approval"
                        name="request_approval" class="oe_stat_button"/>
                <button icon="fa-credit-card-alt"
                        type="object" string=" Plan analysis"
                        name="plan_analysis" class="oe_stat_button"/>
                <button icon="fa-credit-card-alt"
                        attrs="{'invisible': [('state', '!=', ('requested'))]}"
                        type="object" string=" Approve"
                        name="approve" class="oe_stat_button"/>
            </tree>

        </field>
    </record>

    <record id="droga_crm_customer_visit_detail_action" model="ir.actions.act_window">
        <field name="name">Customers visit detail log book</field>
        <field name="res_model">droga.customer.visit.detail</field>
        <field name="view_mode">tree</field>
    </record>

    <record id="droga_crm_customer_visit_header_view_form" model="ir.ui.view">
        <field name="name">droga.customer.visit.header.view.form</field>
        <field name="model">droga.customer.visit.header</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button icon="fa-credit-card-alt"
                        type="object" string=" Plan analysis"
                        name="plan_analysis" class="oe_stat_button"/>
                    </div>
                    <notebook>
                        <page string="Week 1 schedule">
                            <div>
                                <field name="wk1_from" readonly="1"></field>
                                    -
                                <field name="wk1_to" readonly="1"></field>
                            </div>
                            <field name="week_1_domain" mode="tree">
                                <tree editable="top" delete="1" expand="1">
                                    <field name="visit_client" options="{'no_create':True,'no_open':True}"
                                           domain="[('is_company', '=',True),('city_name', '=',city_name)]"></field>
                                    <field name="cont_plan_des"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Plan"
                                            name="visit_contact_open" class="oe_stat_button"/>

                                    <field name="city_name" invisible="1"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Schedule"
                                            name="visit_schedule_open" class="oe_stat_button"/>
                                    
                                    <field name="visit_date"></field>
                                    <field name="planned_visit_selection"></field>
                                    <field name="remark" string='Comment'></field>
                                </tree>
                            </field>
                        </page>
                        <page string="Week 2 schedule">
                            <div>
                                <field name="wk2_from" readonly="1"></field>
                                    -
                                <field name="wk2_to" readonly="1"></field>
                            </div>
                            <field name="week_2_domain" mode="tree">
                                <tree editable="top" delete="1" expand="1">
                                    <field name="visit_client" options="{'no_create':True,'no_open':True}"
                                           domain="[('is_company', '=',True),('city_name', '=',city_name)]"></field>
                                    <field name="cont_plan_des"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Plan"
                                            name="visit_contact_open" class="oe_stat_button"/>

                                    <field name="city_name" invisible="1"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Schedule"
                                            name="visit_schedule_open" class="oe_stat_button"/>
                                    
                                    <field name="visit_date"></field>
                                    <field name="planned_visit_selection"></field>
                                    <field name="remark" string='Comment'></field>
                                </tree>
                            </field>
                        </page>
                        <page string="Week 3 schedule">
                            <div>
                                <field name="wk3_from" readonly="1"></field>
                                    -
                                <field name="wk3_to" readonly="1"></field>
                            </div>
                            <field name="week_3_domain" mode="tree">
                                <tree editable="top" delete="1" expand="1">
                                    <field name="visit_client" options="{'no_create':True,'no_open':True}"
                                           domain="[('is_company', '=',True),('city_name', '=',city_name)]"></field>
                                    <field name="cont_plan_des"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Plan"
                                            name="visit_contact_open" class="oe_stat_button"/>

                                    <field name="city_name" invisible="1"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Schedule"
                                            name="visit_schedule_open" class="oe_stat_button"/>
                                    
                                    <field name="visit_date"></field>
                                    <field name="planned_visit_selection"></field>
                                    <field name="remark" string='Comment'></field>
                                </tree>
                            </field>
                        </page>
                        <page string="Week 4 schedule">
                            <div>
                                <field name="wk4_from" readonly="1"></field>
                                    -
                                <field name="wk4_to" readonly="1"></field>
                            </div>
                            <field name="week_4_domain" mode="tree">
                                <tree editable="top" delete="1" expand="1">
                                    <field name="visit_client" options="{'no_create':True,'no_open':True}"
                                           domain="[('is_company', '=',True),('city_name', '=',city_name)]"></field>
                                    <field name="cont_plan_des"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Plan"
                                            name="visit_contact_open" class="oe_stat_button"/>

                                    <field name="city_name" invisible="1"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Schedule"
                                            name="visit_schedule_open" class="oe_stat_button"/>
                                    
                                    <field name="visit_date"></field>
                                    <field name="planned_visit_selection"></field>
                                    <field name="remark" string='Comment'></field>
                                </tree>
                            </field>
                        </page>
                        <field name="week_5_count" invisible="1"/>
                        <page string="Week 5 schedule" attrs="{'invisible': [('week_5_count', '=', 0)]}">
                            <div>
                                <field name="wk5_from" readonly="1"></field>
                                    -
                                <field name="wk5_to" readonly="1"></field>
                            </div>
                            <field name="week_5_domain" mode="tree">
                                <tree editable="top" delete="1" expand="1">
                                    <field name="visit_client" options="{'no_create':True,'no_open':True}"
                                           domain="[('is_company', '=',True),('city_name', '=',city_name)]"></field>
                                    <field name="cont_plan_des"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Plan"
                                            name="visit_contact_open" class="oe_stat_button"/>

                                    <field name="city_name" invisible="1"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Schedule"
                                            name="visit_schedule_open" class="oe_stat_button"/>
                                    
                                    <field name="visit_date"></field>
                                    <field name="planned_visit_selection"></field>
                                    <field name="remark" string='Comment'></field>
                                </tree>
                            </field>
                        </page>
                        <page string="All weeks">
                            <field name="plan_detail" mode="tree">
                                <tree editable="top" delete="1" expand="1">
                                    <field name="visit_client" options="{'no_create':True,'no_open':True}"
                                           domain="[('is_company', '=',True),('city_name', '=',city_name)]"></field>
                                    <field name="cont_plan_des"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Plan"
                                            name="visit_contact_open" class="oe_stat_button"/>

                                    <field name="city_name" invisible="1"></field>
                                    <button icon="fa-credit-card-alt"
                                            type="object" string=" Schedule"
                                            name="visit_schedule_open" class="oe_stat_button"/>
                                    
                                    <field name="visit_date"></field>
                                    <field name="week_num"></field>
                                    <field name="planned_visit_selection"></field>
                                    <field name="remark" string='Comment'></field>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_crm_customer_visit_detail_view_form" model="ir.ui.view">
        <field name="name">droga.customer.visit.detail.view.form</field>
        <field name="model">droga.customer.visit.detail</field>
        <field name="arch" type="xml">
            <form delete="0">
                <sheet>
                    <notebook>
                        <page string="Contacts schedule">
                            <field name="contacts_schedule" mode="tree">
                                <tree editable="bottom">
                                    <field name="cust"/>
                                    <field name="contact_custom" domain="([('parent_customer','=',cust)])"
                                           options="{'no_create':True,'no_open':True}"></field>
                                    <field name="co_travel" widget="many2many_tags" options="{'no_create':True,'no_open':True}"/>
                                    <field name="phone_no"/>
                                    <field name="core_products" widget="many2many_tags" options="{'no_create':True,'no_open':True}"/>/>
                                </tree>
                    </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem
            id="menu_vist_log"
            name="Visit plan and target"
            parent="crm.crm_menu_root"
            sequence="24"/>

    <menuitem
            id="droga_crm_customer_visit"
            name="Customer visit log prepare"
            action="droga_crm_customer_visit_action"
            parent="menu_vist_log"
            sequence="18"/>
</odoo>
