<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="product_template_crm_inventory_extension" model="ir.ui.view">
        <field name="name">product.template.product.crm.inventory.extension.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="priority" eval="100000000"/>
        <field name="arch" type="xml">

            <xpath expr="//form/sheet/notebook/page/group/group/field[@name='taxes_id']" position="before">
                <field name="crm_group" options="{'no_create':True,'no_open':True}"
                       groups="droga_crm.crm_sr"/>
                <field name="pharmacy_group_id"></field>
            </xpath>

        </field>
    </record>

</odoo>


