<?xml version='1.0' encoding='utf-8'?>
<odoo>
    action.<record id="action_report_account_loan" model="ir.actions.report">
        <field name="name">Payment Report</field>
        <field name="model">account.loan</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">account.loan.report_template_payment</field>
        <field name="report_file">account.loan.report_template_payment</field>
        <field name="print_report_name">'%s' % object.name</field>
        <field name="binding_model_id" ref="model_action_name"/>
        <field name="binding_type">report</field>
    </record>
    <template id="report_template_payment">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>