<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_pharma_sales_pharmacy_pivot" model="ir.ui.view">
        <field name="name">sale.order.pivot.pharmacy.invoice</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <pivot>
                <field name="wareh" type="row"/>
                <field name="amount_total" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- graph -->
    <record id="droga_pharma_sales_pharmacy_graph" model="ir.ui.view">
        <field name="name">sale.order.graph.pharmacy.invoice</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <graph>
                <field name="wareh"/>
                <field name="amount_total" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="droga_pharma_sales_pharmacy_tree" model="ir.ui.view">
        <field name="name">sale.order.tree.pharmacy.invoice</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <list string="Sales order" delete="false" create="false">
                <field name="name"/>
                <field name="emp_descr"/>
                <field name="date_order"/>
                <field name="wareh" string="Branch"/>
                <field name="payment_term_id" string="Branch"/>
                <field name="amount_untaxed" sum="Total before tax"/>
                <field name="amount_tax" sum="Total tax" optional="hide"/>
                <field name="amount_total" sum="Total" optional="hide"/>
                <field name="state" decoration-success="state == 'dispense'" decoration-info="state == 'sale'" decoration-warning="state == 'draft'" widget="badge"/>
                <field name="invoice_status" decoration-success="invoice_status == 'invoiced' or (invoice_status=='no' and state=='dispense')" decoration-info="invoice_status == 'to invoice'" decoration-warning="invoice_status == 'upselling'" widget="badge" optional="show"/>
                <field name="invoice_printed" decoration-success="invoice_printed == 'Yes'" decoration-warning="invoice_printed == 'No'" widget="badge" optional="show"/>
                <button icon="fa-credit-card-alt" type="object" name="open_sales" class="oe_stat_button"/>
            </list>
        </field>
    </record>

    <record id="droga_pharma_sales_pharmacy_search" model="ir.ui.view">
        <field name="name">sale.order.search.pharma.by.pharmacy</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <search string="Sales order">
                <field name="name"/>
                <field name="wareh"/>
                <field name="emp_descr"/>
                <field name="state"/>
                <field name="date_order"/>
                <field name="invoice_status"/>

                <filter string="Today sales" domain="[('date_order', '&gt;=', context_today().strftime('%Y-%m-%d')), ('date_order', '&lt;', (context_today() + relativedelta(days=1)).strftime('%Y-%m-%d'))]" name="today_sales"/>

                <filter string="Yesterday sales" domain="[('date_order', '&gt;=', (context_today()-relativedelta(days=1)).strftime('%Y-%m-%d')), ('date_order', '&lt;', context_today().strftime('%Y-%m-%d'))]" name="yesterday_sales"/>

                <filter string="Current week sales" domain="[                         ('date_order', '&gt;=', (datetime.datetime.combine(context_today() + relativedelta(weeks=-1,days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S')),                         ('date_order', '&lt;', (datetime.datetime.combine(context_today() + relativedelta(days=1,weekday=0), datetime.time(0,0,0)).to_utc()).strftime('%Y-%m-%d %H:%M:%S'))]" name="current_week_sales"/>

                <filter string="Previous week sales" domain="[                     ('date_order', '&lt;', (context_today() + relativedelta(weeks=-1, weekday=6)).strftime('%Y-%m-%d 00:00:00')),                     ('date_order', '&gt;', (context_today() + relativedelta(weeks=-2, weekday=6)).strftime('%Y-%m-%d 00:00:00'))]" name="previous_week_sales"/>

                <filter string="Current month sales" domain="[('date_order','&lt;',(context_today()+relativedelta(months=1)).strftime('%%Y-%%m-01')),                         ('date_order','&gt;=',time.strftime('%%Y-%%m-01'))]" name="current_month_sales"/>

                <filter string="Previous month sales" domain="[('date_order','&gt;=',(context_today()-relativedelta(months=1)).strftime('%%Y-%%m-01')),                         ('date_order','&lt;',time.strftime('%%Y-%%m-01'))]" name="previous_month_sales"/>

                <separator/>

                <filter name="group_pharmacy" string="Group by pharmacy" context="{'group_by':'wareh'}"/>

                <separator/>
                <filter string="To Invoice" domain="[('invoice_status', '=','to invoice')]" name="to_invoice"/>
                <filter string="Invoice printed" domain="[('invoice_printed', '=','Yes')]" name="inv_printed"/>
                <separator/>

                <filter string="Printed not dispensed" domain="[('invoice_printed', '=','Yes'),('state','=','sale')]" name="to_dispense"/>
                <filter string="Invoiced not printed" domain="[('invoice_status', '=','invoiced'),('invoice_printed','=','No')]" name="invoiced_not_printed"/>

                <searchpanel>
                    <field name="wareh" string="Branches"/>
                </searchpanel>

            </search>
        </field>
    </record>

    <record id="droga_pharma_sales_pharmacy_action" model="ir.actions.act_window">
        <field name="name">Sales order per pharmacy - summary</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="limit">200</field>
        <field name="context">{'search_default_today_sales':1,'search_default_inv_printed':1}
        </field>
        <field name="domain">[('order_from','like','PH'),('has_pharma_access','=',True)]</field>
        <field name="search_view_id" ref="droga_pharma_sales_pharmacy_search"/>
        <field name="view_ids" eval="[(5, 0, 0),                           (0, 0, {'view_mode': 'graph', 'view_id': ref('droga_pharma_sales_pharmacy_graph')}),                           (0, 0, {'view_mode': 'pivot', 'view_id': ref('droga_pharma_sales_pharmacy_pivot')}),                           (0, 0, {'view_mode': 'list', 'view_id': ref('droga_pharma_sales_pharmacy_tree')})]"/>
    </record>

</odoo>