<odoo>
    <!-- English Version -->
    <template id="report_mtm_plan">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <!-- Use external_layout with proper structure -->
                <t t-call="web.external_layout">
                    <t t-call="droga_pharma.droga_pharma_header_layout"/>
                    <t t-set="doc" t-value="doc"/>
                    <div class="page">
                        <div class="oe_structure"/>
                        <div class="row mt32">
                            <div class="col-12">
                                <h2>Patient's Program of Action</h2>
                                <h5>Date: <span t-field="doc.date_follow_up"/></h5>
                                <br/>
                                <h5>Based on what I've discussed with the pharmacist, I will complete these things.</h5>
                                <br/>

                                <table style="border-collapse: separate; border-spacing: 0 5px; width: 100%;">
                                    <tbody>
                                        <!-- Section 1 -->
                                        <tr>
                                            <th style="text-align:left; text-decoration: underline; font-weight: bold; padding-top:5px;">
                                                Plans and goals for next followup
                                            </th>
                                        </tr>
                                        <t t-foreach="doc.plan.split('\n')" t-as="line">
                                            <tr><td><t t-raw="line"/></td></tr>
                                        </t>

                                        <!-- Section 2 -->
<!--                                        <tr>-->
<!--                                            <th style="text-align:left; text-decoration: underline; font-weight: bold; padding-top:10px;">-->
<!--                                                Assessment and care plan-->
<!--                                            </th>-->
<!--                                        </tr>-->
<!--                                        <t t-foreach="doc.asses_care_plan.split('\n')" t-as="line">-->
<!--                                            <tr><td><t t-raw="line"/></td></tr>-->
<!--                                        </t>-->

<!--                                        &lt;!&ndash; Section 3 &ndash;&gt;-->
<!--                                        <tr>-->
<!--                                            <th style="text-align:left; text-decoration: underline; font-weight: bold; padding-top:10px;">-->
<!--                                                Recommendations / Interventions-->
<!--                                            </th>-->
<!--                                        </tr>-->
<!--                                        <t t-foreach="doc.recs_inter.split('\n')" t-as="line">-->
<!--                                            <tr><td><t t-raw="line"/></td></tr>-->
<!--                                        </t>-->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
                <!-- Custom footer called separately -->
                <t t-call="droga_pharma.droga_pharma_footer_layout"/>
            </t>
        </t>
    </template>

