<odoo>
    <template id="report_prescription">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="display: flex;">
                            <h1 style="display: inline; margin-right: 20%;">Prescription Paper</h1>
                            <p style="display: inline;">Code: <span t-field="doc.code"/></p>
                        </div>
                        <br/>
                        <div style="display: flex;">
                          <p style="display: inline; margin-right: 10%;">Institution's name: <span t-field="doc.institution"/></p>
                          <p style="display: inline;">Tel. NO: <span t-field="doc.tel"/></p>
                        </div>
                        <br/>
                        <div style="display: flex;">
                        <p>Patient's full name: <span t-field="doc.patient_fullname"/></p>
                        </div>
                        <div style="display: flex;">
                            <p style="display: inline; margin-right: 10%;">Sex: <span t-field="doc.gender"/></p>
                            <p style="display: inline; margin-right: 10%;">Age: <span t-field="doc.age"/></p>
                            <p style="display: inline; margin-right: 10%;">Weight: <span t-field="doc.weight"/></p>
                            <p style="display: inline;">Card No.: <span t-field="doc.card_no"/></p>
                        </div>
                        <br/>
                        <div style="display: flex;">
                            <p style="display: inline; margin-right: 10%;">Region: <span t-field="doc.region"/></p>
                            <p style="display: inline; margin-right: 10%;">Town: <span t-field="doc.town"/></p>
                            <p style="display: inline; margin-right: 10%;">Wereda: <span t-field="doc.wereda"/></p>
                            <p style="display: inline;">Kebele: <span t-field="doc.kebele"/></p>
                        </div>
                        <br/>
                        <div style="display: flex;">
                            <p style="display: inline; margin-right: 10%;">House No.: <span t-field="doc.house_no"/></p>
                            <p style="display: inline; margin-right: 10%;">Tel. NO: <span t-field="doc.mobile"/></p>
                            <p style="display: inline; margin-right: 10%;">Inpatient: <span t-field="doc.inpatient"/></p>
                            <p style="display: inline;">Outpatient: <span t-field="doc.outpatient"/></p>
                        </div>
                        <br/>
                        <div style="display: flex;">
                            <p>Diagnosis, if not ICD: <span t-field="doc.diagnosis"/></p>
                        </div>

                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Drug name, Stregnth, Dosage form, Dose, Frequency, Duration, Quantity, How to use and other information</th>
                                    <th>Price(dispensers use only)</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="total_price" t-value="0.0"/>
                                <t t-foreach="doc.prescription_drugs" t-as="related_record">
                                    <tr>
                                        <td><t t-esc="related_record.drug"/></td>
                                        <td><t t-esc="related_record.price"/></td>
                                    </tr>
                                    <t t-set="total_price" t-value="total_price + related_record.price"/>
                                </t>
                                <tr>
                                    <td style="padding-left: 70%; font-weight: bold;">Total Price</td>
                                    <td><t t-esc="total_price"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>