<odoo>
    <template id="blood_pressure_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="droga_pharma.droga_pharma_header_layout"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure"/>
                        <div class="row mt32">
                            <div class="col-12">
                                <div style="display: flex;">
                                    <h2 style="display: inline; margin-right: 40%;">Blood Pressure Report</h2>
                                    <p style="display: inline;"><span t-field="doc.id"/></p>
                                </div>
                                <br/>
                                <br/>
                                <div style="display: flex;">
                                    <h5 style="display: inline; margin-right: 20%;">Name: <span t-field="doc.client_id"/></h5>
                                    <h5 style="display: inline;">Age: <span t-field="doc.age"/></h5>
                                </div>
                                <br/>
                                <div style="display: flex;">
                                    <h5 style="display: inline; margin-right: 20%;">Mobile: <span t-field="doc.mobile"/></h5>
                                    <h5 style="display: inline;">Sex: <span t-field="doc.sex"/></h5>
                                </div>
                                <br/>
                                <div style="display: flex;">
                                    <h5 style="display: inline; margin-right: 20%;">Weight (KG): <span t-field="doc.weight"/></h5>
                                    <h5 style="display: inline;">Patient Condition: <span t-field="doc.patient_condition"/></h5>
                                </div>
                                <br/>
                                <div>
                                    <h5>Blood Pressure Readings:</h5>
                                    <table style="border-collapse: separate; border-spacing: 10%; width: 100%; border: 1px solid black;">
                                        <thead>
                                            <tr>
                                                <th style="border-bottom: 1px solid black;">Systolic BP (mmHg)</th>
                                                <th style="border-bottom: 1px solid black;">Diastolic BP (mmHg)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td style="text-align: center;"><span t-field="doc.bp_systolic"/></td>
                                                <td style="text-align: center;"><span t-field="doc.bp_diastolic"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                    <t t-call="droga_pharma.droga_pharma_footer_layout"/>
                </t>
            </t>
        </t>
    </template>
</odoo>
