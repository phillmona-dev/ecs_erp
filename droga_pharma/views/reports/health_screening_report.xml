<odoo>
    <record id="droga_blood_pressure_action" model="ir.actions.report">
        <field name="name">Blood Pressure</field>
        <field name="model">droga.health.screening</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">droga_pharma.blood_pressure_report</field>
        <field name="report_file">droga_pharma.blood_pressure_report</field>
        <field name="binding_model_id" ref="model_droga_health_screening"/>
        <field name="binding_type">report</field>
    </record>
    <record id="droga_weight_report_action" model="ir.actions.report">
        <field name="name">Weight Report</field>
        <field name="model">droga.health.screening</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">droga_pharma.weight_report</field>
        <field name="report_file">droga_pharma.weight_report</field>
        <field name="binding_model_id" ref="model_droga_health_screening"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Glucose Report -->
    <record id="droga_glucose_report_action" model="ir.actions.report">
        <field name="name">Glucose Report</field>
        <field name="model">droga.health.screening</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">droga_pharma.glucose_report</field>
        <field name="report_file">droga_pharma.glucose_report</field>
        <field name="binding_model_id" ref="model_droga_health_screening"/>
        <field name="binding_type">report</field>
    </record>

</odoo>