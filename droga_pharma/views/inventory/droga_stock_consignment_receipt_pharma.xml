<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_inventory_consignment_receipt_action_pharmacy" model="ir.actions.act_window">
        <field name="name">Store consignment receipt order</field>
        <field name="res_model">droga.inventory.consignment.receive.pharma</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('create_uid','=',uid),('issue_type','=','CONR')]</field>
    </record>

    <record id="droga_inventory_consignment_receipt_action_pharmacy_report" model="ir.actions.act_window">
        <field name="name">Store consignment receipt order</field>
        <field name="res_model">droga.inventory.consignment.receive.pharma</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','!=','draft'),('issue_type','=','CONR')]</field>
    </record>

    <record id="droga_inventory_consignment_receive_view_tree_pharmacy" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.receive.view.tree</field>
        <field name="model">droga.inventory.consignment.receive.pharma</field>
        <field name="arch" type="xml">
            <list string="" delete="0">
                <field name="name"/>
                <field name="supplier"/>
                <field name="cons_ref" widget="many2many_tags" readonly="1" invisible="(cons_ref == False)"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="droga_inventory_consignment_receive_view_form_pharmacy" model="ir.ui.view">
        <field name="name">droga.inventory.consignment.receive.view.form</field>
        <field name="model">droga.inventory.consignment.receive.pharma</field>
        <field name="arch" type="xml">
            <form string="Consignment receipt" delete="0">
                <header>
                    <button name="request" string="Request" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>
                    <button name="scm_approve" groups="droga_pharma.pharma_supply_chain_manager" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['scm'])"/>
                    <button name="amend" groups="droga_pharma.pharma_supply_chain_manager" string="Amend" type="object" class="oe_highlight btn-warning" data-hotkey="v" invisible="(state not in ['scm'])"/>
                    <button name="action_cancel" string="Cancel" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,stmg,waiting,done"/>
                </header>
                <sheet>
                    <field name="state" invisible="1"/>
                    <field name="issue_type" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                    <button name="taskPaymentRequest" string="Payment Request" type="object" class="oe_stat_button" icon="fa-list" invisible="(issue_type not in ['CONR']) or (state not in ['done'])"/>
                    <button name="cons_return" string="Consignment Return" type="object" class="oe_stat_button" icon="fa-list" invisible="(issue_type not in ['CONR']) or (state not in ['done'])"/>
                    </div>
                    <group string="Store receive request">
                        <group>
                            <field name="supplier" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])"/>
                            <field name="issue_type" required="True" readonly="1"/>
                            <field name="cons_ref" widget="many2many_tags" readonly="1" invisible="(cons_ref == False)"/>
                        </group>
                        <group>
                            <field name="receipt_date" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])"/>
                            <field name="remark"/>
                            <field name="warehouse_id" domain="[('x_has_access','=',True)]" options="{'no_create':True,'no_open':True}" string="Receipt warehouse" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])"/>
                            <field name="supply_chain_manager"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="detail_entries" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])">
                                <list editable="bottom">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_id" options="{'no_create':True,'no_open':True}" required="1" context="{'default_detailed_type': 'product'}"/>
                                    <field name="product_uom" options="{'no_create':True,'no_open':True}"/>
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="product_uom_qty" string="Quantity"/>
                                    <field name="selling_price"/>
                                    <field name="price_unit_cons"/>
                                    <field name="amount" sum="Total"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_pharma_task_payment_request_inherited_form" model="ir.ui.view">
        <field name="name">droga.pharma.payment.request.inherited</field>
        <field name="model">droga.account.payment.request</field>
        <field name="inherit_id" ref="droga_finance.droga_account_payment_request_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group/group/field[1]" position="after">
                <field name="cons_ref_pay" invisible="(cons_ref_pay == False)"/>
            </xpath>
        </field>
    </record>

</odoo>