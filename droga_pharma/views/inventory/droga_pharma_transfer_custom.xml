<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_pharma_transfer_custom_view_tree" model="ir.ui.view">
        <field name="name">droga.pharma.transfer.custom.view.tree</field>
        <field name="model">droga.inventory.transfer.custom</field>
        <field name="arch" type="xml">
            <list string="" delete="0">
                <field name="name"/>
                <field name="transfer_picking" widget="many2many_tags"/>
                <field name="location_dest_id"/>
                <field name="location_id"/>
                <field name="state"/>

            </list>
        </field>
    </record>

    <record id="droga_pharma_transfer_custom_view_form" model="ir.ui.view">
        <field name="name">droga.pharma.transfer.custom.view.form</field>
        <field name="model">droga.inventory.transfer.custom</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <form string="Transfers" delete="0">
                <header>
                    <button name="request_ph" string="Request" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>
                    <button name="confirm_ph" groups="droga_pharma.pharma_supply_chain_manager" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['phmg'])"/>
                    <button name="confirm_im" groups="droga_inventory.stores_manager,droga_inventory.stores_manager_ws" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['stmgp'])"/>
                    <button name="confirm_im" groups="droga_inventory.stores_manager,droga_inventory.stores_manager_ws" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['stmg'])"/>
                    <button name="reset_order" groups="droga_pharma.pharma_supply_chain_manager,droga_inventory.stores_manager,droga_inventory.stores_manager_ws" string="Reset to draft" type="object" class="oe_highlight btn-warning" data-hotkey="v" invisible="(state not in ['phmg', 'stmg'])"/>
                    <button name="action_cancel" string="Cancel" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,phmg,stmgp,waiting,processed,done"/>
                </header>
                <sheet>
                    <group string="Store transfer request">
                        <group>
                            <field name="location_filter" invisible="1"/>
                            <field name="location_dest_id" options="{'no_create':True,'no_open':True}" domain="([('x_has_access','=',True),('con_type','=','SRL')])" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])"/>
                            <field name="location_id" options="{'no_create':True,'no_open':True}" domain="(['|',('has_no_access','=',True),('has_dispensary_location','=',False)])" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])"/>
                        </group>
                        <group>
                            <field name="request_date" readonly="(state in ['waiting', 'reject', 'cancel', 'processed', 'done'])"/>
                            <field name="consignment_item" readonly="(state in ['waiting', 'reject', 'cancel', 'processed', 'done'])"/>
                            <field name="transfer_picking" readonly="1" widget="many2many_tags" invisible="(state in ['draft'])"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="detail_entries" readonly="(state in ['waiting', 'reject', 'cancel', 'done', 'processed'])">
                                <list editable="bottom">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_id" required="1" options="{'no_create':True,'no_open':True}" context="{'default_detailed_type': 'product'}"/>
                                    <field name="product_uom" domain="['|',('id', '=', import_uom),('id','=',pharma_uom)]"/>
                                    <field name="cons_price" column_invisible="(parent.consignment_item == False)"/>
                                    <field name="product_uom_qty" string="Request"/>
                                    <field name="available_qty" groups="droga_inventory.stores_manager,droga_inventory.stores_manager_ws"/>
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="import_uom" invisible="1"/>
                                    <field name="pharma_uom" invisible="1"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                    <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
                </sheet>

            </form>
        </field>
    </record>

    <record id="droga_inventory_transfer_custom_view_form_inherit" model="ir.ui.view">
        <field name="name">Inter-store approval</field>
        <field name="model">droga.inventory.transfer.custom</field>
        <field name="inherit_id" ref="droga_inventory.droga_inventory_transfer_custom_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='amend']" position="after">
                <button name="confirm_ph" groups="droga_pharma.pharma_supply_chain_manager" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['phmg'])"/>
                <button name="confirm_im" groups="droga_inventory.stores_manager,droga_inventory.stores_manager_ws" string="Approve" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['stmgp'])"/>
            </xpath>

        </field>
    </record>

    <record id="droga_pharma_transfer_custom_action" model="ir.actions.act_window">
        <field name="name">Store transfer request</field>
        <field name="res_model">droga.inventory.transfer.custom</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'show_title': True}</field>
        <field name="view_ids" eval="[(5, 0, 0),         (0, 0, {'view_mode': 'list', 'view_id': ref('droga_pharma.droga_pharma_transfer_custom_view_tree')}),          (0, 0, {'view_mode': 'form', 'view_id': ref('droga_pharma.droga_pharma_transfer_custom_view_form')})]"/>
        <field name="domain">[('create_uid','=',uid)]</field>
    </record>
</odoo>