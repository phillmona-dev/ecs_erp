<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <record id="droga_pharma_children_cust" model="ir.ui.view">
        <field name="name">droga.pharma.children.cust.form</field>
        <field name="model">res.partner</field>
        <field name="priority">400</field>
        <field name="arch" type="xml">

            <form delete="0" editable="bottom">

                <sheet>
                    <notebook>
                        <page string="Children">
                            <field name="childs" mode="tree">
                                <list delete="0" editable="bottom" multi_line="1">

                                    <field name="child_name"/>
                                    <field name="gender"/>
                                    <field name="child_dob"/>
                                    <field name="breast_feed_days"/>

                                </list>
                            </field>

                        </page>

                    </notebook>
                </sheet>

            </form>
        </field>

    </record>

    <record id="droga_pharma_res_partner2" model="ir.ui.view">
        <field name="name">form.res.partner.pharma2</field>
        <field name="model">res.partner.pharma2</field>
        <field name="priority">400</field>
        <field name="arch" type="xml">

            <form delete="0" editable="bottom">

                <sheet>
                    <group>
                        <field name="name_reg" required="True"/>
                        <field name="phone_reg"/>
                    </group>
                </sheet>

            </form>
        </field>

    </record>

    <record id="droga_pharma_customers_create_popup" model="ir.ui.view">
        <field name="name">droga.pharma.cust.employees.view.form.popup</field>
        <field name="model">droga.pharma.cust.employees</field>
        <field name="priority">200</field>
        <field name="arch" type="xml">
            <form string="" delete="0">
                <sheet>
                    <div class="oe_button_box" name="button_box">

                        <button icon="fa-credit-card-alt" type="object" string="Children" name="open_children" class="oe_stat_button"/>

                    </div>
                    <group string="Patient information">
                        <group>
                            <field name="employee_name"/>
                            <field name="parent_customer" required="True"/>
                            <field name="phone_no"/>
                            <field name="cust_id"/>
                        </group>
                        <group>
                            <field name="dob"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="profession"/>
                        </group>
                    </group>

                    <group string="Past history">
                        <group>
                            <field name="medical_history"/>
                            <field name="medication_history"/>
                        </group>
                        <group>
                            <field name="adr_allergy"/>
                            <field name="immunization"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>
</odoo>