<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="pharma_partner_view" model="ir.ui.view">
        <field name="name">res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <form string="Partners">
                <div class="alert alert-warning oe_edit_only" role="alert"
                     attrs="{'invisible': [('same_vat_partner_id', '=', False)]}">
                    A partner with the same
                    <span>
                        <span class="o_vat_label">Tax ID</span>
                    </span>
                    already exists (<field name="same_vat_partner_id"/>), are you sure to create a new one?
                </div>
                <div class="alert alert-warning oe_edit_only" role="alert"
                     attrs="{'invisible': [('same_company_registry_partner_id', '=', False)]}">
                    A partner with the same
                    <span>
                        <span class="o_vat_label">Company Registry</span>
                    </span>
                    already exists (<field name="same_company_registry_partner_id"/>), are you sure to create a new one?
                </div>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>
                    <field name="avatar_128" invisible="1"/>
                    <field name="image_1920" widget='image' class="oe_avatar"
                           options='{"preview_image": "avatar_128"}'/>
                    <div class="oe_title mb24">
                        <field name="is_company" invisible="1"/>
                        <field name="commercial_partner_id" invisible="1"/>
                        <field name="active" invisible="1"/>
                        <field name="company_id" invisible="1"/>
                        <field name="country_code" invisible="1"/>
                        <field name="company_type" widget="radio" options="{'horizontal': true}"/>
                        <h1>
                            <field id="company" class="text-break" name="name" default_focus="1"
                                   placeholder="e.g. Bank of Abyssinia"
                                   attrs="{  'invisible': [('is_company','=', False)]}"/>
                            <field id="individual" class="text-break" name="name" default_focus="1"
                                   placeholder="e.g. Ato Kebede"
                                   attrs="{  'invisible': [('is_company','=', True)]}"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="vat" placeholder="e.g. 1000004356"/>
                        </group>
                        <group>
                            <field name="phone" widget="phone"/>
                            <field name="mobile" widget="phone"/>
                        </group>
                    </group>

                    <notebook >
                        <page string="Employees" attrs="{'invisible': [('is_company','=', False)]}"
                      groups="droga_pharma.pharma_br_admin,droga_pharma.pharma_dp_admin,droga_pharma.pharma_di_admin">
                    <field name="employees" mode="tree,kanban">
                        <tree editable="1" create="1">
                            <field name="employee_name"/>
                            <field name="gender"/>
                            <field name="cust_id"/>
                            <field name="profession"></field>
                            <field name="phone_no"/>
                            <field name="dob"/>
                            <field name="age"/>
                        </tree>
                        <form>
                            <group>
                                <field name="employee_name"/>
                                <field name="job_position"/>
                                <field name="gender"/>
                                <field name="cust_id"/>
                                <field name="profession"></field>
                                <field name="mobile"/>
                                <field name="dob"/>
                                <field name="age"/>
                            </group>
                        </form>
                        <kanban class="o_kanban_mobile">
                            <field name="employee_name"/>
                            <field name="job_position"/>
                            <field name="gender"/>
                            <field name="cust_id"/>
                            <field name="profession"></field>
                            <field name="mobile"/>
                            <field name="dob"/>
                            <field name="age"/>
                            <templates>
                                <t t-name="kanban-box">
                                    <div t-attf-class="oe_kanban_global_click" on_create="quick_create">
                                        <div class="oe_kanban_details">
                                            <ul>
                                                <li>
                                                    <field name="employee_name"></field>
                                                </li>
                                                <li>
                                                    <span></span>
                                                    Job Position:
                                                    <field name="job_position"></field>

                                                    <span></span>
                                                    Profession:
                                                    <field name="profession"></field>
                                                    <span></span>
                                                    Customer ID:
                                                    <field name="cust_id"/>
                                                </li>
                                                <li>
                                                    Gender:
                                                    <field name="gender"></field>
                                                    <span></span>-
                                                    <span></span>
                                                    Mobile:
                                                    <field name="mobile"></field>
                                                </li>


                                            </ul>

                                        </div>
                                    </div>
                                </t>
                            </templates>

                        </kanban>
                    </field>
                </page>
                <page string="Memberships" attrs="{'invisible': [('is_company','=', True)]}"
                      groups="droga_pharma.pharma_br_admin,droga_pharma.pharma_dp_admin,droga_pharma.pharma_di_admin">
                    <field name="memberships_partner" mode="tree,kanban">
                        <tree editable="0" create="0">
                            <field name="prod"/>
                            <field name="prod_descr"/>
                            <field name="sales_ref"/>
                            <field name="paid_amount"></field>
                            <field name="left_amount"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="status"/>
                        </tree>
                        <form>
                            <group>
                                <field name="prod"/>
                            <field name="prod_descr"/>
                            <field name="sales_ref"/>
                            <field name="paid_amount"></field>
                            <field name="left_amount"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="status"/>
                                <button icon="fa-credit-card-alt" type="object" attrs="{'invisible': [('status', '!=', 'Active')]}" string="Sales Order" name="sales_req"
                        class="oe_stat_button"></button>
                            </group>
                        </form>
                        <kanban class="o_kanban_mobile">
                            <field name="prod"/>
                            <field name="prod_descr"/>
                            <field name="sales_ref"/>
                            <field name="paid_amount"></field>
                            <field name="left_amount"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="status"/>
                            <templates>
                                <t t-name="kanban-box">
                                    <div t-attf-class="oe_kanban_global_click" on_create="quick_create">
                                        <div class="oe_kanban_details">
                                            <ul>
                                                <li>
                                                    <field name="prod_descr"></field>
                                                </li>
                                                <li>
                                                    <span></span>
                                                    Sales ref:
                                                    <field name="sales_ref"></field>

                                                    <span></span>
                                                    Paid amount:
                                                    <field name="paid_amount"></field>
                                                    <span></span>
                                                    Left amount:
                                                    <field name="left_amount"/>
                                                </li>
                                                <li>
                                                    Date from:
                                                    <field name="date_from"></field>
                                                    <span></span>-
                                                    <span></span>
                                                    Date to:
                                                    <field name="date_to"></field>
                                                </li>


                                            </ul>

                                        </div>
                                    </div>
                                </t>
                            </templates>

                        </kanban>
                    </field>
                </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>