<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_pharma_follow_up_form" model="ir.ui.view">
        <field name="name">droga.pharma.mtm.follow_up.form</field>
        <field name="model">droga.pharma.mtm.follow_up</field>
        <field name="arch" type="xml">
            <form string="" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="date_follow_up"/>
                            <field name="time"/>
                            <field name="current_status"/>
                        </group>
                        <group>
                            <field name="plan"/>
                            <field name="referral"/>
                        </group>
                    </group>
                    <hr/>
                    <group string="Assessment, plan and recommendations">--&gt;
                        <field name="asses_care_plan"/>
                        <field name="recs_inter"/>
                    </group>
                    <notebook>
                        <page string="MTM Detail">
                            <field name="from_sales_order" invisible="1"/>
                            <field name="follow_up_detail" mode="tree">
                                <list editable="bottom" create="1">
                                    <field name="drug_therapy_problem"/>
                                    <field name="drug_therapy_cause"/>
                                    <field name="intervention" invisible="(parent.from_sales_order == True)"/>
                                    <field name="intervention_implemented" invisible="(parent.from_sales_order == True)"/>
                                    <field name="outcome" invisible="(parent.from_sales_order == True)"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <hr/>
                    <group>
                        <field name="eff_saf_med"/>
                        <field name="int_imple"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>