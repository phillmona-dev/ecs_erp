<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="droga_bp_tree" model="ir.ui.view">
        <field name="name">droga.bp.tree</field>
        <field name="model">droga.health.screening</field>
        <field name="arch" type="xml">
            <tree string="Blood Pressure Records" create="1" delete="1">
                <field name="client_id"/>
                <field name="mobile"/>
                <field name="age"/>
                <field name="sex"/>
                <field name="create_date" string="Date"/>
                <field name="patient_condition"/>
                <field name="weight"/>
                <field name="bp_systolic"/>
                <field name="bp_diastolic"/>
            </tree>
        </field>
    </record>

    <record id="droga_bp_form" model="ir.ui.view">
        <field name="name">droga.bp.form</field>
        <field name="model">droga.health.screening</field>
        <field name="arch" type="xml">
           <form string="Blood Pressure Form" delete="1">
            <sheet>

                <group>
                    <group string="Patient's Personal Info">
                        <field name="client_id" options='{"no_open":True,"no_create": True}'/>
                        <field name="age"/>
                        <field name="mobile"/>
                        <field name="sex"/>
                        <field name="wareh"/>
                    </group>
                    <group string="Blood Pressure Details">
                        <field name="patient_condition"/>
                        <field name="bp_systolic"/>
                        <field name="bp_diastolic"/>
                        <field name="screening_type"/>
                    </group>
                </group>
            </sheet>
        </form>
        </field>
    </record>

    <record id="droga_bp_action" model="ir.actions.act_window">
        <field name="name">Blood Pressure</field>
        <field name="res_model">droga.health.screening</field>
         <field name="domain">[('screening_type', '=', 'bp')]</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5,0,0), (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_bp_tree')}), (0, 0, {'view_mode': 'form', 'view_id': ref('droga_bp_form')})]"/>
    </record>

</odoo>