<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <record id="droga_glucose_tree" model="ir.ui.view">
        <field name="name">droga.glucose.tree</field>
        <field name="model">droga.health.screening</field>
        <field name="arch" type="xml">
            <tree string="Glucose Records" create="1" delete="1">
                <field name="client_id"/>
                <field name="age"/>
                <field name="sex"/>
                <field name="create_date" string="Date"/>
                <field name="mobile"/>
                <field name="patient_condition"/>
                <field name="weight"/>
                <field name="bp_systolic"/>
                <field name="bp_diastolic"/>
                <field name="fasting_glucose"/>
                <field name="rbs_glucose"/>
            </tree>
        </field>
    </record>

    <record id="droga_glucose_form" model="ir.ui.view">
        <field name="name">droga.health.screening.form</field>
        <field name="model">droga.health.screening</field>
        <field name="arch" type="xml">
           <form string="Glucose Form" delete="1">
            <sheet>
                <div class="oe_button_box" name="button_box">
                                        <button icon="fa-credit-card-alt"
                                                name="action_create_payment"
                                                type="object"
                                                string="Initiate Sales"
                                                class="oe_stat_button"/>


                    </div>
                    <field name="sale_order_id" invisible="1"/>
                <group>
                    <group string="Patient's Personal Info">
                        <field name="client_id" options='{"no_open":True,"no_create": True}'/>
                        <field name="age"/>
                        <field name="mobile"/>
                        <field name="sex"/>
                        <field name="patient_condition"/>
                        <field name="wareh"/>
                    </group>
                    <group string="Medical Details">
                        <field name="weight"/>
                        <field name="bp_systolic"/>
                        <field name="bp_diastolic"/>
                        <field name="fasting_glucose" attrs="{'readonly': [('sale_order_id', '=', False)]}"/>
                        <field name="rbs_glucose" attrs="{'readonly': [('sale_order_id', '=', False)]}"/>
                        <field name="screening_type"/>
                        <field name="sale_order_id" invisible="1"/>      <!-- Added -->
                        <field name="invoice_id" invisible="1"/>
                    </group>
                </group>
            </sheet>
        </form>
        </field>
    </record>


    <record id="droga_glucose_action" model="ir.actions.act_window">
        <field name="name">Glucose</field>
        <field name="res_model">droga.health.screening</field>
         <field name="domain">[('screening_type', '=', 'glucose')]</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5,0,0), (0, 0, {'view_mode': 'tree', 'view_id': ref('droga_glucose_tree')}), (0, 0, {'view_mode': 'form', 'view_id': ref('droga_glucose_form')})]"/>

    </record>

</odoo>