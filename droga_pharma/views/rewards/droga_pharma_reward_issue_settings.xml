<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_pharma_rewards_issue_action" model="ir.actions.act_window">
        <field name="name">Discount settings per issue settings</field>
        <field name="res_model">droga.pharma.reward.issue</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="droga_pharma_rewards_issue_tree" model="ir.ui.view">
        <field name="name">droga.pharma.reward.issue.view.tree</field>
        <field name="model">droga.pharma.reward.issue</field>
        <field name="arch" type="xml">
            <list string="" delete="0">
                <field name="reward_pct"/>
                <field name="prod_group" widget="many2many_tags"/>
                <field name="prod_template"/>
                <field name="type"/>
                <field name="reward_req_points" string="Req points"/>
                <field name="reward_req_frequ" string="Frequency (Days)"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="droga_pharma_rewards_issue_form" model="ir.ui.view">
        <field name="name">droga.pharma.reward.issue.view.form</field>
        <field name="model">droga.pharma.reward.issue</field>
        <field name="arch" type="xml">
            <form string="" delete="0">
                <sheet>
                    <group>
                        <field name="reward_pct"/>
                        <field name="prod_group" widget="many2many_tags" domain="[('avail_in_product_master', '=',True)]" options="{'no_create':True,'no_open':True}"/>
                        <field name="prod_template" options="{'no_create':True,'no_open':True}"/>
                        <field name="uom"/>
                        <field name="quantity"/>
                        <field name="type"/>
                        <field name="reward_req_points"/>
                        <field name="reward_req_frequ"/>
                        <field name="remark"/>
                        <field name="status"/>
                    </group>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
</odoo>