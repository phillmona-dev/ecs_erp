<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="pharma_partner_kanban_view" model="ir.ui.view">
            <field name="name">res.partner.kanban.inherit.pharma</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.res_partner_kanban_view"/>
            <field name="priority" eval="10"/>
            <field name="arch" type="xml">
                <xpath expr="//kanban/field[@name='active']" position="after">
                    <field name="state" invisible="1"/>
                </xpath>
                <xpath expr="//t[@t-name='card']//field[@name='complete_name']" position="after">
                    <br/>
                    <field name="state" invisible="1"/>
                    <button type="object" groups="droga_pharma.pharma_director" class="btn btn-primary btn-sm" name="visit_detail_open" invisible="(state != 'requested')">Open customer
                                                </button>

                </xpath>
            </field>
        </record>
</odoo>
