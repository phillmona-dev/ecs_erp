<?xml version='1.0' encoding='utf-8'?>
<odoo>
     <record id="droga_inventory_reward_issue_view_form" model="ir.ui.view">
        <field name="name">droga.inventory.reward.issue.view.form</field>
        <field name="model">droga.inventory.consignment.issue</field>
        <field name="arch" type="xml">
            <form string="Reward issue" delete="0">
                <header>
                    <!-- Sales and crm header part  -->
                    <field name="menu_from" invisible="1"/>
                    <button name="dispense_products" string="Dispense items" type="object" class="oe_highlight" data-hotkey="v" invisible="(state not in ['draft'])"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,processed"/>

                </header>
                <sheet>
                    <group string="Reward items issue">
                        <group>
                            <field name="customer" readonly="1"/>
                            <field name="issue_type" required="True" readonly="1"/>
                            <field name="remark"/>
                        </group>
                        <group>
                            <field name="issue_date" readonly="1"/>
                            <field name="cons_ref" widget="many2many_tags" readonly="1" invisible="(cons_ref == False)"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="state" invisible="1"/>
                            <field name="detail_entries" readonly="(state in ['waiting', 'reject', 'cancel', 'done'])">
                                <list create="0" delete="0">
                                    <field name="company_id" invisible="1"/>
                                    <field name="product_id" required="1" options="{'no_create':True,'no_open':True}" context="{'default_detailed_type': 'product'}"/>
                                    <field name="product_uom" invisible="1"/>
                                    <field name="product_uom_pharma" options="{'no_create':True,'no_open':True}"/>
                                    <field name="product_uom_category_id" invisible="1"/>
                                    <field name="state" invisible="1"/>
                                    <field name="product_uom_qty" string="Quantity"/>
                                    <field name="warehouse_id" string="Issuer warehouse" options="{'no_create':True,'no_open':True}"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
</odoo>