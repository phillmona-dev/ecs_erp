<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <menuitem id="pharma_main_menu" name="Pharmacy chain" sequence="10"/>

    <record id="droga_pharma_customers_list_tree" model="ir.ui.view">
        <field name="name">droga.pharma.cust.employees.view.tree</field>
        <field name="model">droga.pharma.cust.employees</field>
        <field name="arch" type="xml">
            <list string="" delete="0">
                <field name="employee_name"/>
                <field name="parent_customer"/>
                <field name="phone_no"/>
                <field name="gender"/>
                <field name="dob"/>
                <field name="age"/>
            </list>
        </field>
    </record>

    <record id="droga_pharma_customers_list_form" model="ir.ui.view">
        <field name="name">droga.pharma.cust.employees.view.form</field>
        <field name="model">droga.pharma.cust.employees</field>
        <field name="priority">300</field>
        <field name="arch" type="xml">
            <form string="" delete="0">
                <sheet>
                    <div class="oe_button_box" name="button_box">

                        <button icon="fa-credit-card-alt" type="object" string="Children" name="open_children" class="oe_stat_button"/>

                    </div>
                    <group string="Patient information">
                        <group>
                            <field name="employee_name"/>
                            <field name="parent_customer" required="True"/>
                            <field name="phone_no"/>
                            <field name="cust_id"/>
                        </group>
                        <group>

                            <label for="dob" string="Date of birth"/>
                            <div class="o_row">

                                <field name="dob" class="oe_inline"/>

                                <label for="age" string="Age"/>
                                <field name="age" class="oe_inline"/>
                            </div>

                            <field name="gender"/>
                            <field name="profession"/>

                            <field name="company_limit" invisible="1"/>
                            <field name="employee_credit_limit" invisible="(company_limit == 0)"/>
                        </group>
                    </group>

                    <group string="Past history">
                        <group>
                            <field name="medical_history"/>
                            <field name="medication_history"/>
                        </group>
                        <group>
                            <field name="adr_allergy"/>
                            <field name="immunization"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Customer transaction">
                            <field name="sales_detail">
                                <list default_order="order_id desc" string="Customer transaction">
                                    <field name="order_id"/>
                                    <field name="name"/>
                                    <field name="product_uom"/>
                                    <field name="product_uom_qty"/>
                                    <field name="qty_invoiced"/>
                                    <field name="invoiced_amt"/>
                                </list>
                            </field>
                        </page>
                        <page string="Memberships" groups="droga_pharma.pharma_br_admin,droga_pharma.pharma_dp_admin,droga_pharma.pharma_di_admin" invisible="(1 &gt; 0)">
                            <field name="memberships_employee" mode="tree,kanban">
                                <list create="0">
                                    <field name="prod"/>
                                    <field name="prod_descr"/>
                                    <field name="sales_ref"/>
                                    <field name="paid_amount"/>
                                    <field name="left_amount"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="status"/>
                                    <button icon="fa-credit-card-alt" type="object" string="Sales Order" name="sales_req" class="oe_stat_button" invisible="(status != 'Active')"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="prod"/>
                                        <field name="prod_descr"/>
                                        <field name="sales_ref"/>
                                        <field name="paid_amount"/>
                                        <field name="left_amount"/>
                                        <field name="date_from"/>
                                        <field name="date_to"/>
                                        <field name="status"/>
                                    </group>
                                </form>
                                <kanban class="o_kanban_mobile">
                                    <field name="prod"/>
                                    <field name="prod_descr"/>
                                    <field name="sales_ref"/>
                                    <field name="paid_amount"/>
                                    <field name="left_amount"/>
                                    <field name="date_from"/>
                                    <field name="date_to"/>
                                    <field name="status"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div t-attf-class="oe_kanban_global_click" on_create="quick_create">
                                                <div class="oe_kanban_details">
                                                    <ul>
                                                        <li>
                                                            <field name="prod_descr"/>
                                                        </li>
                                                        <li>
                                                            <span/>
                                                            Sales ref:
                                                            <field name="sales_ref"/>

                                                            <span/>
                                                            Paid amount:
                                                            <field name="paid_amount"/>
                                                            <span/>
                                                            Left amount:
                                                            <field name="left_amount"/>
                                                        </li>
                                                        <li>
                                                            Date from:
                                                            <field name="date_from"/>
                                                            <span/>-
                                                            <span/>
                                                            Date to:
                                                            <field name="date_to"/>
                                                        </li>


                                                    </ul>

                                                </div>
                                            </div>
                                        </t>
                                    </templates>

                                </kanban>
                            </field>
                        </page>
                    </notebook>

                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="droga_pharma_customers_list" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">droga.pharma.cust.employees</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),             (0, 0, {'view_mode': 'list', 'view_id': ref('droga_pharma.droga_pharma_customers_list_tree')}),             (0, 0, {'view_mode': 'form', 'view_id': ref('droga_pharma.droga_pharma_customers_list_form')}),         ]"/>
    </record>

    <record id="res_partner_company_customer" model="ir.actions.act_window">
        <field name="name">Company customers</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),         (0, 0, {'view_mode': 'kanban', 'view_id': ref('base.res_partner_kanban_view')}),         (0, 0, {'view_mode': 'list', 'view_id': ref('base.view_partner_tree')}),          (0, 0, {'view_mode': 'form', 'view_id': ref('pharma_partner_view')})]"/>
        <field name="context">{'search_default_customer': 1,'res_partner_search_mode': 'customer', 'default_is_company':
            True,'default_company_type':'company', 'default_customer_rank': 1}
        </field>
        <field name="domain">[('is_company','=',True)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new customer in your address book
            </p>
            <p>
                Odoo helps you easily track all activities related to a customer.
            </p>
        </field>
    </record>

    <record id="res_partner_individual_customer" model="ir.actions.act_window">
        <field name="name">Individual customers</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),         (0, 0, {'view_mode': 'kanban', 'view_id': ref('base.res_partner_kanban_view')}),         (0, 0, {'view_mode': 'list', 'view_id': ref('base.view_partner_tree')}),          (0, 0, {'view_mode': 'form', 'view_id': ref('pharma_partner_view')})]"/>
        <field name="context">{'search_default_customer': 1,'res_partner_search_mode': 'customer', 'default_is_company':
            False,'default_company_type':'person', 'default_customer_rank': 1}
        </field>
        <field name="domain">[('is_company','=',False)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new customer in your address book
            </p>
            <p>
                Odoo helps you easily track all activities related to a customer.
            </p>
        </field>
    </record>

    <record id="res_partner_individual_customer_form" model="ir.actions.act_window">
        <field name="name">Individual customers</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="pharma_partner_view"/>
        <field name="domain">[('is_company','=',False)]</field>
        <field name="context">{'search_default_customer': 1,'res_partner_search_mode': 'customer', 'default_is_company':
            False,'default_company_type':'person', 'default_customer_rank': 1}
        </field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new customer in your address book
            </p>
            <p>
                Odoo helps you easily track all activities related to a customer.
            </p>
        </field>
    </record>

    <menuitem id="droga_pharma_customers_comp_list_menu" name="Clients" parent="droga_pharma.pharma_main_menu" groups="droga_pharma.pharma_dp_admin,droga_pharma.pharma_br_admin" sequence="30"/>

    <menuitem id="droga_pharma_customers_list_menu" name="Employees" action="droga_pharma_customers_list" parent="droga_pharma.droga_pharma_customers_comp_list_menu" groups="droga_pharma.pharma_dp_admin,droga_pharma.pharma_br_admin" sequence="29"/>

    <menuitem id="droga_pharma_partners_list_menu" action="droga_pharma.res_partner_company_customer" name="Company customers" parent="droga_pharma.droga_pharma_customers_comp_list_menu" groups="droga_pharma.pharma_dp_admin,droga_pharma.pharma_br_admin" sequence="31"/>

    <menuitem id="droga_pharma_one_time_list_menu" action="droga_pharma.res_partner_individual_customer" name="Individual customers" parent="droga_pharma.droga_pharma_customers_comp_list_menu" groups="droga_pharma.pharma_dp_admin,droga_pharma.pharma_br_admin" sequence="32"/>
</odoo>
