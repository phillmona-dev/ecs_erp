<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="droga_pharma_price_list_tree" model="ir.ui.view">
        <field name="name">Price list</field>
        <field name="model">droga.pharma.price.list.header</field>
        <field name="arch" type="xml">
            <list string="" create="1" delete="0">
                <field name="contract_no"/>
                <field name="customer"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="status"/>

            </list>
        </field>
    </record>

    <record id="droga_pharma_price_list_form" model="ir.ui.view">
        <field name="name">droga.pharma.price.list.header.form</field>
        <field name="model">droga.pharma.price.list.header</field>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <form string="Price list" delete="0">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="status" invisible="1"/>
                        <button icon="fa-credit-card-alt" type="object" string="Populate items" name="populate_items" class="oe_stat_button" invisible="(status != 'Offer')"/>
                        <button icon="fa-credit-card-alt" type="object" string="Generate report" name="generate_report" class="oe_stat_button"/>
                    </div>
                    <group string="Price list">
                        <group>
                            <field name="customer" readonly="1"/>
                            <field name="date_from"/>
                            <field name="contract_no"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="date_to"/>
                            <field name="pharmacy_group_id" widget="many2many_tags" options="{'no_create':True,'no_open':True}"/>

                            <label for="margin" string="Margin"/>
                            <div class="o_row">
                                <field name="status" invisible="1"/>
                                <field name="margin"/>
                                <button name="update_margin" type="object" string="Update margin" invisible="(status != 'Offer')"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Product Details">
                            <field name="products_detail">
                                <list editable="bottom" limit="500">
                                    <field name="product" required="True" options="{'no_create':True,'no_open':True}"/>
                                    <field name="uom"/>
                                    <field name="pharmacy_group_id"/>
                                    <field name="selling_price" readonly="1"/>
                                    <field name="margin"/>
                                    <field name="rev_selling_price"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                    <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
                </sheet>

            </form>
        </field>
    </record>
</odoo>