<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- My Purchase Requests Action -->
    <record id="action_my_purchase_requests" model="ir.actions.act_window">
        <field name="name">My Purchase Requests</field>
        <field name="res_model">ecs.purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('create_uid', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Submit your first Purchase Request here.
            </p>
        </field>
    </record>

    <record id="action_my_payment_requests" model="ir.actions.act_window">
        <field name="name">My Payment Requests</field>
        <field name="res_model">ecs.finance.payment.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('create_uid', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Submit your first Payment Request here.
            </p>
        </field>
    </record>

    <record id="action_my_store_requisitions" model="ir.actions.act_window">
        <field name="name">My Store Requisitions</field>
        <field name="res_model">ecs.inventory.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('create_uid', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Request internal store supplies or stock here.
            </p>
        </field>
    </record>

    <!-- My Headcount Requests Action -->
    <record id="action_my_headcount_requests" model="ir.actions.act_window">
        <field name="name">My Headcount Requests</field>
        <field name="res_model">ecs.hr.headcount.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('create_uid', '=', uid)]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Submit headcount budget addition requests here.
            </p>
        </field>
    </record>
</odoo>
