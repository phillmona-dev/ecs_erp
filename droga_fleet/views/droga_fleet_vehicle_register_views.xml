<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_scheduler_notification_action" model="ir.cron">
            <field name="name">Due date notification</field>
            <field name="model_id" ref="model_fleet_vehicle"/>
            <field name="state">code</field>
            <field name="code">model.send_insurance_reminder()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
        </record>
    </data>

    <record id="droga_fleet_vehicle_custom" model="ir.ui.view">
        <field name="name">Custom droga fleet vehicle</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <header>
                <field name="maintenance_status" widget="statusbar"/>
            </header>
            <xpath expr="//page[1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!--        <page string="Tax Info" position="attributes">-->
            <!--            <attribute name='invisible'>1</attribute>-->
            <!--        </page>-->
            <xpath expr="//field[@name='location']" position="after">
                <field name="vehicle_status" groups="droga_fleet.droga_fleet_manager"/>
                <field name="available"/>

            </xpath>


            <xpath expr="//field[@name='tag_ids']" position="after">
                <button type="object" name="add_to_maintenance" string="Add To Maintenance" class="btn-danger" invisible="(maintenance_status != 'maintenance_completed')"/>
                <button type="object" name="remove_from_maintenance" string="Maintenance Completed" class="oe_highlight" invisible="(maintenance_status != 'in_maintenance')"/>
            </xpath>


            <xpath expr="//field[@name='horsepower']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='horsepower_tax']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//field[@name='co2_standard']" position="after">
                <field name="cc" groups="droga_fleet.droga_fleet_manager"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="droga_rent_contract" string="Rent Contarct" groups="droga_fleet.droga_fleet_manager" invisible="(vehicle_status != 'rented')">
                    <group>
                        <group>
                            <field name="four_wheels"/>
                            <field name="mud_flaps"/>
                            <field name="spare_tire"/>
                            <field name="radio_tape"/>
                            <field name="wheel_screw"/>
                            <field name="molded_carpet"/>
                            <field name="car_jack"/>
                            <field name="side_mirror"/>
                            <field name="antenna"/>
                        </group>
                        <group>
                            <field name="car_type"/>
                            <field name="plate_number"/>
                            <field name="fuel_amount"/>
                            <field name="rent_type"/>
                            <field name="with_driver"/>
                            <field name="return_place"/>
                            <field name="rent_fee"/>
                            <field name="additional_info"/>
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page name="droga_fleet_insurance" string="Insurance">
                    <group>
                        <group>
                            <field name="bolo_renewal_date" groups="droga_fleet.droga_fleet_manager" invisible="(vehicle_status != 'owned')"/>
                            <field name="bolo_due_date" groups="droga_fleet.droga_fleet_manager" invisible="(vehicle_status != 'owned')"/>

                            <field name="service_details" groups="droga_fleet.droga_fleet_manager">
                                <list>
                                    <field name="service_due_date"/>
                                    <field name="service_date"/>

                                </list>
                            </field>

                        </group>
                        <group>
                            <field name="insurance_renewal_date" groups="droga_fleet.droga_fleet_manager" invisible="(vehicle_status != 'owned')"/>
                            <field name="insurance_due_date" groups="droga_fleet.droga_fleet_manager" invisible="(vehicle_status != 'owned')"/>

                            <field name="contract_details" groups="droga_fleet.droga_fleet_manager" invisible="(vehicle_status == 'owned')">
                                <list>
                                    <field name="contract_renewal_date"/>
                                    <field name="contract_due_date"/>

                                </list>
                            </field>
                        </group>


                    </group>
                </page>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="droga_vehicle_tasks" string="Current Tasks">
                    <group>
                        <field name="tasks" widget="many2many_tags"/>
                    </group>


                </page>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="droga_vehicle_finances" string="Vehicle Finances">
                    <group>


                        <group>
                              <field name="rent_fee" groups="droga_fleet.droga_fleet_manager" invisible="(vehicle_status == 'owned')"/>

                        </group>


                        <group>
                              <field name="fuel_consumption_per_quota" groups="droga_fleet.droga_fleet_manager"/>

                        </group>


                    </group><br/><br/>
                    <group>
                        <group>
                            <field name="maintenance_fees" groups="droga_fleet.droga_fleet_manager">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="cost"/>
                                    <field name="type"/>
                                </list>
                            </field>



                        </group>

                        <group>

                        </group>
                    </group>


                </page>
            </xpath>


        </field>
    </record>

</odoo>