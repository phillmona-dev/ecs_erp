<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="module_category_ecs_construction" model="ir.module.category">
            <field name="name">ECS Construction</field>
            <field name="sequence">45</field>
        </record>

        <record id="group_construction_user" model="res.groups">
            <field name="name">Construction User</field>
            <field name="category_id" ref="module_category_ecs_construction"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_construction_manager" model="res.groups">
            <field name="name">Construction Manager</field>
            <field name="category_id" ref="module_category_ecs_construction"/>
            <field name="implied_ids" eval="[(4, ref('group_construction_user'))]"/>
        </record>

        <!-- Company Isolation Rules -->
        <record id="rule_boq_company" model="ir.rule">
            <field name="name">BOQ: Company Isolation</field>
            <field name="model_id" ref="model_ecs_construction_boq"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_contract_company" model="ir.rule">
            <field name="name">Construction Contract: Company Isolation</field>
            <field name="model_id" ref="model_ecs_construction_contract"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="rule_progress_billing_company" model="ir.rule">
            <field name="name">Progress Billing: Company Isolation</field>
            <field name="model_id" ref="model_ecs_progress_billing"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
