<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_progress_billing_tree" model="ir.ui.view">
        <field name="name">ecs.progress.billing.tree</field>
        <field name="model">ecs.progress.billing</field>
        <field name="arch" type="xml">
            <list string="Progress Billing Certificates"
                  decoration-info="state == 'submitted'"
                  decoration-warning="state == 'approved'"
                  decoration-success="state == 'invoiced'"
                  decoration-danger="state == 'cancel'">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="billing_date"/>
                <field name="gross_amount"/>
                <field name="retention_amount"/>
                <field name="net_amount"/>
                <field name="state" widget="badge"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_progress_billing_form" model="ir.ui.view">
        <field name="name">ecs.progress.billing.form</field>
        <field name="model">ecs.progress.billing</field>
        <field name="arch" type="xml">
            <form string="Progress Billing Certificate">
                <header>
                    <button name="action_submit" string="Submit" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object"
                            class="btn-success" invisible="state != 'submitted'"
                            groups="ecs_construction.group_construction_manager"/>
                    <button name="action_create_invoice" string="Create Invoice" type="object"
                            class="btn-primary" invisible="state != 'approved'"
                            groups="ecs_construction.group_construction_manager"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('invoiced','cancel')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,invoiced"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Reference">
                            <field name="contract_id" readonly="state != 'draft'"/>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="billing_date" readonly="state != 'draft'"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="invoice_id" invisible="not invoice_id"/>
                        </group>
                        <group string="Financial Summary">
                            <field name="gross_amount"/>
                            <field name="retention_amount"/>
                            <field name="net_amount" class="oe_subtotal_footer_separator"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Work Done Details" name="billing_lines">
                            <field name="line_ids" readonly="state not in ('draft',)">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="quantity_done"/>
                                    <field name="uom_id" readonly="1"/>
                                    <field name="unit_price"/>
                                    <field name="subtotal" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_progress_billing" model="ir.actions.act_window">
        <field name="name">Progress Billing Certificates</field>
        <field name="res_model">ecs.progress.billing</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
