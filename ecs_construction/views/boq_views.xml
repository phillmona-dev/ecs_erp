<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_boq_tree" model="ir.ui.view">
        <field name="name">ecs.construction.boq.tree</field>
        <field name="model">ecs.construction.boq</field>
        <field name="arch" type="xml">
            <list string="Bill of Quantities">
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="total_amount"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_boq_form" model="ir.ui.view">
        <field name="name">ecs.construction.boq.form</field>
        <field name="model">ecs.construction.boq</field>
        <field name="arch" type="xml">
            <form string="Bill of Quantities">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. BOQ - Foundation Works"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="task_id"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="BOQ Items" name="boq_items">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="uom_id" readonly="1"/>
                                    <field name="unit_price"/>
                                    <field name="subtotal" readonly="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_amount" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_boq" model="ir.actions.act_window">
        <field name="name">Bill of Quantities</field>
        <field name="res_model">ecs.construction.boq</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
